#. ---- All other strings (menu items, help text, headers, buttons) ----
msgid "Pick a colour"
msgstr "Farbe wählen"

msgid "Cancel"
msgstr "Abbrechen"

msgid "Apply"
msgstr "Anwenden"

#, lua-format
msgid "Brightness: %d%%"
msgstr "Helligkeit: %d%%"

msgid "Enter hex"
msgstr "Hex eingeben"

msgid "Enter hex colour code"
msgstr "Hex-Farbcode eingeben"

msgid "Invalid hex code. Use format: #RRGGBB"
msgstr "Ungültiger Hex-Code. Format verwenden: #RRGGBB"

msgid "Delete all custom presets"
msgstr "Alle eigenen Voreinstellungen löschen"

msgid "Permanently removes all custom presets you've created. The built-in\n'Default' preset will remain. This cannot be undone."
msgstr "Entfernt dauerhaft alle selbst erstellten Voreinstellungen. Die integrierte Voreinstellung 'Standard' bleibt erhalten. Dies kann nicht rückgängig gemacht werden."

msgid "Are you sure you want to delete all custom presets? (built-in presets\nwill remain)"
msgstr "Alle eigenen Voreinstellungen wirklich löschen? (integrierte Voreinstellungen bleiben erhalten)"

msgid "Delete"
msgstr "Löschen"

msgid "All custom presets deleted. Built-in presets remain."
msgstr "Alle eigenen Voreinstellungen gelöscht. Integrierte Voreinstellungen bleiben erhalten."

msgid "Sleep screen orientation"
msgstr "Ausrichtung des Sperrbildschirms"

msgid "Force the sleep screen to display in a specific orientation, regardless\nof how the device is held."
msgstr "Den Sperrbildschirm in einer bestimmten Ausrichtung anzeigen, unabhängig davon, wie das Gerät gehalten wird."

msgid "Auto (follow device)"
msgstr "Automatisch (Gerät folgen)"

msgid "Use whatever orientation the device is currently in."
msgstr "Die aktuelle Ausrichtung des Geräts verwenden."

msgid "Force portrait"
msgstr "Hochformat erzwingen"

msgid "Always display the sleep screen in portrait mode."
msgstr "Den Sperrbildschirm immer im Hochformat anzeigen."

msgid "Force landscape"
msgstr "Querformat erzwingen"

msgid "Always display the sleep screen in landscape mode."
msgstr "Den Sperrbildschirm immer im Querformat anzeigen."

msgid "Force upside-down portrait"
msgstr "Umgekehrtes Hochformat erzwingen"

msgid "Always display the sleep screen in inverted portrait mode."
msgstr "Den Sperrbildschirm immer im umgekehrten Hochformat anzeigen."

msgid "Force upside-down landscape"
msgstr "Umgekehrtes Querformat erzwingen"

msgid "Always display the sleep screen in inverted landscape mode."
msgstr "Den Sperrbildschirm immer im umgekehrten Querformat anzeigen."

msgid "Battery time calculation"
msgstr "Akkulaufzeitberechnung"

msgid "Method used to estimate remaining battery life."
msgstr "Methode zur Schätzung der verbleibenden Akkulaufzeit."

msgid "Since last charge"
msgstr "Seit letzter Ladung"

msgid "Uses combined awake and sleeping battery drain since last charge"
msgstr "Kombinierter Akkuverbrauch im Wach- und Schlafmodus seit letzter Ladung"

msgid "Awake since last charge"
msgstr "Wachzeit seit letzter Ladung"

msgid "Uses only active reading battery drain (more conservative estimate)"
msgstr "Nur Akkuverbrauch beim aktiven Lesen (konservativere Schätzung)"

msgid "Sleeping since last charge"
msgstr "Schlafzeit seit letzter Ladung"

msgid "Uses only sleep mode battery drain"
msgstr "Nur Akkuverbrauch im Schlafmodus"

msgid "Manual calculation"
msgstr "Manuelle Berechnung"

msgid "Use a custom battery drain rate (1-10% per hour)"
msgstr "Benutzerdefinierten Akkuverbrauch verwenden (1–10 % pro Stunde)"

msgid "Set manual drain rate"
msgstr "Manuellen Verbrauch festlegen"

msgid "Battery drain rate (% per hour)"
msgstr "Akkuverbrauch (% pro Stunde)"

msgid "Typical devices drain 1-5% per hour while reading."
msgstr "Typische Geräte verbrauchen beim Lesen 1–5 % pro Stunde."

msgid "Daily statistics scope"
msgstr "Bereich der Tagesstatistik"

msgid "Controls whether today's reading time and page count applies to the\ncurrent book only, or all books read today. Note: reading streak and\nweekly goal achievement always reflect all books regardless of this\nsetting."
msgstr "Legt fest, ob die heutige Lesezeit und Seitenanzahl nur für das aktuelle Buch oder für alle heute gelesenen Bücher gilt. Hinweis: Leseserie und wöchentliche Zielerreichung beziehen sich immer auf alle Bücher, unabhängig von dieser Einstellung."

msgid "All books"
msgstr "Alle Bücher"

msgid "Today's reading time and page count across all books read today"
msgstr "Heutige Lesezeit und Seitenanzahl für alle heute gelesenen Bücher"

msgid "Current book only"
msgstr "Nur aktuelles Buch"

msgid "Today's reading time and page count for the current book only"
msgstr "Heutige Lesezeit und Seitenanzahl nur für das aktuelle Buch"

msgid "Show in file manager (outside of book)"
msgstr "Im Dateimanager anzeigen (außerhalb eines Buches)"

msgid "When enabled, the customisable sleep screen will display in file manager\nusing the last saved book data."
msgstr "Wenn aktiviert, zeigt der anpassbare Sperrbildschirm im Dateimanager die zuletzt gespeicherten Buchdaten an."

msgid "Hide built-in presets (except Default)"
msgstr "Integrierte Voreinstellungen ausblenden (außer Standard)"

msgid "Hide the built-in presets from the preset list, keeping only the Default\npreset and your custom presets visible."
msgstr "Integrierte Voreinstellungen aus der Liste ausblenden; nur die Standardvoreinstellung und eigene Voreinstellungen bleiben sichtbar."

msgid "Setting saved. Preset list will update when you reopen this menu."
msgstr "Einstellung gespeichert. Die Liste aktualisiert sich beim erneuten Öffnen dieses Menüs."

msgid "Export sleep screen to file"
msgstr "Sperrbildschirm in Datei exportieren"

msgid "When enabled, a screenshot of the sleep screen will be saved as
'screensaver.png' in the selected export folder each time a book is
closed."
msgstr "Wenn aktiviert, wird bei jedem Schließen eines Buches ein Screenshot des Sperrbildschirms als
'screensaver.png' im ausgewählten Exportordner gespeichert."

msgid "Sleep screen export disabled."
msgstr "Sperrbildschirm-Export deaktiviert."

msgid "No export folder set. Please set an export folder first."
msgstr "Kein Exportordner festgelegt. Bitte zuerst einen Exportordner auswählen."

#, lua-format
msgid "Sleep screen will be exported to:
%s/screensaver.png"
msgstr "Sperrbildschirm wird exportiert nach:
%s/screensaver.png"

msgid "Set export folder"
msgstr "Exportordner festlegen"

msgid "Choose the folder where screensaver.png will be saved."
msgstr "Ordner auswählen, in dem screensaver.png gespeichert wird."

#, lua-format
msgid "Export folder set to:
%s"
msgstr "Exportordner festgelegt auf:
%s"

msgid "Presets"
msgstr "Voreinstellungen"

msgid "Save, load, and manage presets."
msgstr "Voreinstellungen speichern, laden und verwalten."

msgid "Display modes"
msgstr "Anzeigemodi"

msgid "Global appearance settings."
msgstr "Globale Erscheinungsbildeinstellungen."

msgid "Contents"
msgstr "Inhalt"

msgid "Control which sections appear and what information they display."
msgstr "Steuern, welche Bereiche angezeigt werden und welche Informationen sie zeigen."

msgid "Layout & Spacing"
msgstr "Layout & Abstände"

msgid "Adjust the spatial settings of the information box."
msgstr "Räumliche Einstellungen der Informationsbox anpassen."

msgid "Colours, Icons & Bars"
msgstr "Farben, Symbole & Balken"

msgid "Customise section colours, icon appearance, and progress bar styling."
msgstr "Bereichsfarben, Symboldarstellung und Fortschrittsbalken-Stil anpassen."

msgid "Fonts & Text"
msgstr "Schriften & Text"

msgid "Configure text appearance."
msgstr "Textdarstellung konfigurieren."

msgid "Background"
msgstr "Hintergrund"

msgid "Choose what appears behind the information box."
msgstr "Auswählen, was hinter der Informationsbox erscheint."

msgid "Advanced"
msgstr "Erweitert"

msgid "Advanced configuration options."
msgstr "Erweiterte Konfigurationsoptionen."

msgid "About"
msgstr "Über"

#, lua-format
msgid "%s\nVersion: %s\n\nFor updates and issues:\ngithub.com/%s"
msgstr "%s\nVersion: %s\n\nFür Updates und Fehlerberichte:\ngithub.com/%s"

msgid "Top left"
msgstr "Oben links"

msgid "Top centre"
msgstr "Oben mitte"

msgid "Top right"
msgstr "Oben rechts"

msgid "Middle left"
msgstr "Mitte links"

msgid "Centre"
msgstr "Mitte"

msgid "Middle right"
msgstr "Mitte rechts"

msgid "Bottom left"
msgstr "Unten links"

msgid "Bottom centre"
msgstr "Unten mitte"

msgid "Bottom right"
msgstr "Unten rechts"

msgid "Dark mode"
msgstr "Dunkelmodus"

msgid "Inverts the colour scheme. Text becomes white and backgrounds becomes\nblack. Useful for reading in low-light conditions. Can be combined with\nmonochrome mode."
msgstr "Kehrt das Farbschema um. Text wird weiß, Hintergründe werden schwarz. Nützlich beim Lesen bei schwachem Licht. Kann mit dem Monochrommodus kombiniert werden."

msgid "Monochrome mode"
msgstr "Monochrommodus"

msgid "Suitable for B&W e-readers. Assigns one colour to all sections using\nmonochrome light or monochrome dark hex values. Overwrites individual\nassigned section colours. Can be combined with dark mode."
msgstr "Geeignet für Schwarz-Weiß-E-Reader. Weist allen Bereichen eine Farbe zu, unter Verwendung von Monochrom-Hell- oder -Dunkel-Hexadezimalwerten. Überschreibt einzeln zugewiesene Bereichsfarben. Kann mit dem Dunkelmodus kombiniert werden."

msgid "Section gaps"
msgstr "Bereichsabstände"

msgid "Add transparent gaps between sections to make each appear as a separate\nbox"
msgstr "Transparente Abstände zwischen Bereichen hinzufügen, damit jeder als separate Box erscheint"

msgid "Enable section gaps"
msgstr "Bereichsabstände aktivieren"

msgid "Section gap size"
msgstr "Bereichsabstandsgröße"

msgid "Spacing between sections when gaps are enabled."
msgstr "Abstand zwischen Bereichen, wenn Abstände aktiviert sind."

msgid "Section gap size (pixels)"
msgstr "Bereichsabstandsgröße (Pixel)"

msgid "10–20px gives a subtle separation. 30–50px makes sections feel like\ndistinct cards."
msgstr "10–20 px ergibt eine dezente Trennung. 30–50 px lässt Bereiche wie eigenständige Karten wirken."

msgid "Position"
msgstr "Position"

msgid "Screen location where the information box appears."
msgstr "Bildschirmposition der Informationsbox."

msgid "Position offset"
msgstr "Positionsversatz"

msgid "Nudge the box from its anchor position. Useful for pushing rounded
corners off-screen."
msgstr "Box von ihrer Ankerposition verschieben. Nützlich, um abgerundete
Ecken aus dem Bildschirm zu schieben."

msgid "Horizontal offset (px)"
msgstr "Horizontaler Versatz (px)"

msgid "Nudges the box left (-) or right (+) from its anchor. Useful for pushing
rounded corners off-screen."
msgstr "Verschiebt die Box nach links (-) oder rechts (+) von ihrem Anker. Nützlich, um
abgerundete Ecken aus dem Bildschirm zu schieben."

msgid "Vertical offset (px)"
msgstr "Vertikaler Versatz (px)"

msgid "Nudges the box up (+) or down (-) from its anchor. Useful for pushing
rounded corners off-screen."
msgstr "Verschiebt die Box nach oben (+) oder unten (-) von ihrem Anker. Nützlich, um
abgerundete Ecken aus dem Bildschirm zu schieben."

msgid "Width"
msgstr "Breite"

msgid "Horizontal width of the information box as a percentage of screen width."
msgstr "Horizontale Breite der Informationsbox als Prozentsatz der Bildschirmbreite."

msgid "Box width (%)"
msgstr "Boxbreite (%)"

msgid "60–70% suits portrait screens."
msgstr "60–70 % eignet sich für Hochformatbildschirme."

msgid "Opacity"
msgstr "Deckkraft"

msgid "Transparency of the information box."
msgstr "Transparenz der Informationsbox."

msgid "Opacity (%)"
msgstr "Deckkraft (%)"

msgid "75% is semi-transparent. 100% is fully opaque."
msgstr "75 % ist halbtransparent. 100 % ist vollständig undurchsichtig."

msgid "Border size"
msgstr "Rahmengröße"

msgid "Thickness of the primary border around sections."
msgstr "Dicke des primären Rahmens um die Bereiche."

msgid "Border size (px)"
msgstr "Rahmengröße (px)"

msgid "0 for no border. 1–2px is subtle, 4–6px is bold and visible."
msgstr "0 für keinen Rahmen. 1–2 px ist dezent, 4–6 px ist kräftig und sichtbar."

msgid "Border trim size"
msgstr "Rahmenziergröße"

msgid "Secondary decorative border surrounding the primary border."
msgstr "Sekundärer dekorativer Rahmen um den primären Rahmen."

msgid "Border trim size (px)"
msgstr "Rahmenziergröße (px)"

msgid "0 for no trim. 1–2px is subtle, 4–6px is a bold decorative outline
around the primary border."
msgstr "0 für keine Zierlinie. 1–2 px ist dezent, 4–6 px ist eine kräftige dekorative Umrandung
um den primären Rahmen."

msgid "Corner radius"
msgstr "Eckenradius"

msgid "Round the corners of the info box. Also moves progress bars inline with
the text when active."
msgstr "Ecken der Infobox abrunden. Verschiebt Fortschrittsbalken bei Aktivierung auch inline
mit dem Text."

msgid "Corner radius (px)"
msgstr "Eckenradius (px)"

msgid "0 for square corners. 15–30px for softly rounded. 150px+ for a
pill-shaped box (depending on the section box height)."
msgstr "0 für eckige Ecken. 15–30 px für sanft gerundete. 150 px+ für eine
pillenförmige Box (abhängig von der Bereichshöhe)."

msgid "Internal padding"
msgstr "Innenabstand"

msgid "Space between section borders and their content, configurable per side."
msgstr "Abstand zwischen Bereichsrahmen und Inhalt, pro Seite konfigurierbar."

msgid "Top"
msgstr "Oben"

msgid "Internal padding — top (px)"
msgstr "Innenabstand — oben (px)"

msgid "Space above section content."
msgstr "Abstand über dem Bereichsinhalt."

msgid "Bottom"
msgstr "Unten"

msgid "Internal padding — bottom (px)"
msgstr "Innenabstand — unten (px)"

msgid "Space below section content."
msgstr "Abstand unter dem Bereichsinhalt."

msgid "Left"
msgstr "Links"

msgid "Internal padding — left (px)"
msgstr "Innenabstand — links (px)"

msgid "Space to the left of section content. Increase when using large corner
radii."
msgstr "Abstand links vom Bereichsinhalt. Bei großen Eckenradien vergrößern."

msgid "Right"
msgstr "Rechts"

msgid "Internal padding — right (px)"
msgstr "Innenabstand — rechts (px)"

msgid "Space to the right of section content. Increase when using large corner
radii."
msgstr "Abstand rechts vom Bereichsinhalt. Bei großen Eckenradien vergrößern."

msgid "Set all sides equally"
msgstr "Alle Seiten gleich setzen"

msgid "Internal padding — all sides (px)"
msgstr "Innenabstand — alle Seiten (px)"

msgid "Sets top, bottom, left and right padding to the same value in one step."
msgstr "Setzt den Innenabstand oben, unten, links und rechts in einem Schritt auf denselben Wert."

msgid "Icon to text gap"
msgstr "Symbol-zu-Text-Abstand"

msgid "Horizontal spacing between section icons and their accompanying text."
msgstr "Horizontaler Abstand zwischen Bereichssymbolen und zugehörigem Text."

msgid "Icon to text gap (px)"
msgstr "Symbol-Text-Abstand (px)"

msgid "8–12px gives comfortable breathing room between icon and text. 0 is
flush."
msgstr "8–12 px gibt angenehmen Abstand zwischen Symbol und Text. 0 ist
bündig."

msgid "No icon sets found in customisablesleepscreen.koplugin/icons/"
msgstr "Keine Symbolsätze gefunden in customisablesleepscreen.koplugin/icons/"

msgid "Colours (progress bars)"
msgstr "Farben (Fortschrittsbalken)"

msgid "Set the progress bar colours for each section."
msgstr "Legt die Farben der Fortschrittsbalken für jeden Abschnitt fest."

msgid "Use saved colours for icon fill"
msgstr "Gespeicherte Farben für Symbolfüllung verwenden"

msgid "When enabled, icons will match the colour of their section's progress\nbar."
msgstr "Wenn aktiviert, entsprechen Symbole der Farbe des Fortschrittsbalkens ihres Bereichs."

msgid "Book section"
msgstr "Buchbereich"

msgid "Chapter section"
msgstr "Kapitelbereich"

msgid "Daily goal section"
msgstr "Tageszielebereich"

msgid "Battery section (High)"
msgstr "Akkubereich (Hoch)"

msgid "Battery section (Med)"
msgstr "Akkubereich (Mittel)"

msgid "Battery section (Low)"
msgstr "Akkubereich (Niedrig)"

msgid "Battery section (Charging)"
msgstr "Akkubereich (Lädt)"

msgid "Message section"
msgstr "Nachrichtenbereich"

msgid "Colours (modes)"
msgstr "Farben (Modi)"

msgid "Configure colours for monochrome mode, infobox background, and text.\nLight and dark correspond to the current dark mode setting. Monochrome\nreplaces all colours with that single chosen color."
msgstr "Farben für den Monochrom-Modus, den Infobox-Hintergrund und Text konfigurieren. Hell und Dunkel entsprechen der aktuellen Dunkel-Modus-Einstellung. Monochrom ersetzt alle Farben durch die gewählte Einzelfarbe."

msgid "Monochrome mode (light)"
msgstr "Monochrommodus (Hell)"

msgid "Monochrome mode (dark)"
msgstr "Monochrommodus (Dunkel)"

msgid "Background (light)"
msgstr "Hintergrund (Hell)"

msgid "Background (dark)"
msgstr "Hintergrund (Dunkel)"

msgid "Text (light)"
msgstr "Text (Hell)"

msgid "Text (dark)"
msgstr "Text (Dunkel)"

msgid "Icon set"
msgstr "Symbolsatz"

msgid "Choose from different icon styles."
msgstr "Aus verschiedenen Symbolstilen wählen."

msgid "Icon size"
msgstr "Symbolgröße"

msgid "Size of section icons."
msgstr "Größe der Bereichssymbole."

msgid "Icon size (px)"
msgstr "Symbolgröße (px)"

msgid "32–48px suits most layouts."
msgstr "32–48 px eignet sich für die meisten Layouts."

msgid "Progress bar height"
msgstr "Fortschrittsbalken-Höhe"

msgid "Thickness of the horizontal progress bars shown in each section."
msgstr "Dicke der horizontalen Fortschrittsbalken in jedem Bereich."

msgid "Bar height (px)"
msgstr "Balkenhöhe (px)"

msgid "4–8px is subtle. 12–16px is standard. 20+px is heavy."
msgstr "4–8 px ist dezent. 12–16 px ist Standard. 20+ px ist kräftig."

msgid "Show icons"
msgstr "Symbole anzeigen"

msgid "Display decorative icons at the start of each section."
msgstr "Dekorative Symbole am Anfang jedes Bereichs anzeigen."

msgid "Show progress bars"
msgstr "Fortschrittsbalken anzeigen"

msgid "Display horizontal progress bars showing completion percentage."
msgstr "Horizontale Fortschrittsbalken mit dem Fertigstellungsprozentsatz anzeigen."

msgid "Show decorative bar on message section"
msgstr "Dekorationsbalken im Nachrichtenbereich anzeigen"

msgid "Displays a purely decorative progress bar under the message section,\nmatching the message section colour and the progress bars in other\nsections."
msgstr "Zeigt einen rein dekorativen Fortschrittsbalken unter dem Nachrichtenbereich an, der die Farbe des Nachrichtenbereichs und der Fortschrittsbalken in anderen Bereichen übernimmt."

msgid "Inline progress bars"
msgstr "Inline-Fortschrittsbalken"

msgid "Progress bars sit inside the text area rather than spanning the full
section width. Automatically enabled when corner radius > 0."
msgstr "Fortschrittsbalken befinden sich im Textbereich statt über die volle
Bereichsbreite zu verlaufen. Automatisch aktiviert wenn Eckenradius > 0."

msgid "Enable inline bars"
msgstr "Inline-Balken aktivieren"

msgid "When section gaps are enabled and corner radius > 0, inline bars are automatically enabled."
msgstr "Wenn Abschnittslücken aktiviert sind und der Eckenradius > 0 ist, werden Inline-Balken automatisch aktiviert."

msgid "Inline bars are force-enabled because section gaps and corner radius are both set. Set corner radius to 0 or disable section gaps to toggle inline bars independently."
msgstr "Inline-Balken sind zwangsweise aktiviert, da Abschnittslücken und Eckenradius gesetzt sind. Eckenradius auf 0 setzen oder Abschnittslücken deaktivieren, um Inline-Balken unabhängig umzuschalten."

msgid "Inline bar border size"
msgstr "Inline-Balken-Rahmengröße"

msgid "Thickness of the border around the inline progress bar."
msgstr "Dicke des Rahmens um den Inline-Fortschrittsbalken."

msgid "Inline bar border size (px)"
msgstr "Inline-Balken-Rahmengröße (px)"

msgid "0 for no border. 1–2px adds a subtle outline around the bar."
msgstr "0 für keinen Rahmen. 1–2 px fügt eine dezente Umrandung um den Balken hinzu."

msgid "Bar width"
msgstr "Balkenbreite"

msgid "Width of the inline progress bar as a percentage of the available text
column. Alignment follows the text alignment setting."
msgstr "Breite des Inline-Fortschrittsbalkens als Prozentsatz der verfügbaren
Textspalte. Ausrichtung folgt der Textausrichtungseinstellung."

msgid "Inline bar width (%)"
msgstr "Inline-Balkenbreite (%)"

msgid "100% fills the text column. The bar is aligned to match your text
alignment setting."
msgstr "100 % füllt die Textspalte. Der Balken wird entsprechend der
Textausrichtungseinstellung ausgerichtet."

msgid "Title font face"
msgstr "Titelschriftart"

msgid "Choose the font face for the main heading text in each section"
msgstr "Schriftart für den Hauptüberschriftstext in jedem Bereich wählen"

msgid "Title font size"
msgstr "Titelschriftgröße"

msgid "Choose the font size for the main heading text in each section."
msgstr "Schriftgröße für den Hauptüberschriftstext in jedem Bereich wählen."

msgid "10–12px works well for most screens."
msgstr "10–12 px funktioniert gut für die meisten Bildschirme."

msgid "Subtitle font face"
msgstr "Untertitelschriftart"

msgid "Choose the font face for the information below the main heading text."
msgstr "Schriftart für die Informationen unter dem Hauptüberschriftstext wählen."

msgid "Subtitle font size"
msgstr "Untertitelschriftgröße"

msgid "Choose the font size for the information below the main heading text."
msgstr "Schriftgröße für die Informationen unter dem Hauptüberschriftstext wählen."

msgid "9–11px works well for most screens."
msgstr "9–11 px funktioniert gut für die meisten Bildschirme."

msgid "Text alignment"
msgstr "Textausrichtung"

msgid "Horizontal alignment of all text within sections."
msgstr "Horizontale Ausrichtung des gesamten Textes in den Bereichen."

msgid "Book multiline titles"
msgstr "Buchtitel mehrzeilig"

msgid "If deselected book titles will be truncated to a single line with an\nellipsis"
msgstr "Wenn deaktiviert, werden Buchtitel auf eine Zeile mit Auslassungspunkten gekürzt"

msgid "Chapter multiline titles"
msgstr "Kapiteltitel mehrzeilig"

msgid "If deselected chapter titles will be truncated to a single line with an\nellipsis"
msgstr "Wenn deaktiviert, werden Kapiteltitel auf eine Zeile mit Auslassungspunkten gekürzt"

msgid "Clean chapter titles"
msgstr "Kapiteltitel bereinigen"

msgid "Removes structural prefixes like 'Chapter 5:' or 'Part II' from chapter\ntitles and normalises capitalisation. Only works correctly with English\nchapter titles - disable for non-English books."
msgstr "Entfernt strukturelle Präfixe wie 'Kapitel 5:' oder 'Teil II' aus Kapiteltiteln und normalisiert die Großschreibung. Funktioniert nur korrekt mit englischen Kapiteltiteln – für nicht-englische Bücher deaktivieren."

msgid "Make titles bold"
msgstr "Titel fett darstellen"

msgid "Display the section titles in bold font weight for extra emphasis."
msgstr "Bereichstitel zur stärkeren Hervorhebung in Fettschrift anzeigen."

msgid "No background"
msgstr "Kein Hintergrund"

msgid "Book cover"
msgstr "Buchcover"

msgid "Solid colour"
msgstr "Volltonfarbe"

msgid "Random image from folder"
msgstr "Zufälliges Bild aus Ordner"

msgid "Stretch book cover to fill"
msgstr "Buchcover auf Vollbild strecken"

msgid "When disabled, book cover will be scaled to fit within the screen while\npreserving aspect ratio."
msgstr "Wenn deaktiviert, wird das Buchcover unter Beibehaltung des Seitenverhältnisses an den Bildschirm angepasst."

msgid "Cover fill colour"
msgstr "Cover-Füllfarbe"

msgid "Background colour for non-stretched covers."
msgstr "Hintergrundfarbe für nicht gestreckte Cover."

msgid "Pick cover fill colour"
msgstr "Cover-Füllfarbe wählen"

msgid "Cover alignment"
msgstr "Cover-Ausrichtung"

msgid "Horizontal alignment of the cover image when not stretched."
msgstr "Horizontale Ausrichtung des Cover-Bildes wenn nicht gestreckt."

msgid "Solid background colour"
msgstr "Einfarbiger Hintergrund"

msgid "Pick background colour"
msgstr "Hintergrundfarbe wählen"

msgid "Background folder path"
msgstr "Hintergrundordnerpfad"

msgid "No images found in the selected folder. No background will be shown."
msgstr "Keine Bilder im ausgewählten Ordner gefunden. Es wird kein Hintergrund angezeigt."

msgid "Background type"
msgstr "Hintergrundtyp"

msgid "Background overlay"
msgstr "Hintergrundüberlagerung"

msgid "Add a colour layer over the background to reduce contrast."
msgstr "Eine Farbschicht über den Hintergrund legen, um den Kontrast zu reduzieren."

msgid "Overlay colour"
msgstr "Überlagerungsfarbe"

msgid "Background overlay colour"
msgstr "Hintergrundüberlagerungsfarbe"

msgid "Overlay opacity"
msgstr "Überlagerungsdeckkraft"

msgid "Overlay opacity (%)"
msgstr "Überlagerungsdeckkraft (%)"

msgid "0% is no overlay. 20–40% adds a soft tint. 100% is fully opaque."
msgstr "0 % ist keine Überlagerung. 20–40 % fügt eine sanfte Tönung hinzu. 100 % ist vollständig undurchsichtig."

msgid "Reset layout & spacing settings to default"
msgstr "Layout- & Abstandseinstellungen zurücksetzen"

