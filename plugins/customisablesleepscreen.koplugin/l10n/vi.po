#. ---- All other strings (menu items, help text, headers, buttons) ----

msgid "Pick a colour"
msgstr "Chọn màu"

msgid "Cancel"
msgstr "Hủy"

msgid "Apply"
msgstr "Áp dụng"

#, lua-format
msgid "Brightness: %d%%"
msgstr "Độ sáng: %d%%"

msgid "Enter hex"
msgstr "Nhập mã hex"

msgid "Enter hex colour code"
msgstr "Nhập mã màu hex"

msgid "Invalid hex code. Use format: #RRGGBB"
msgstr "Mã hex không hợp lệ. Dùng định dạng: #RRGGBB"

msgid "Delete all custom presets"
msgstr "Xóa tất cả cấu hình tùy chỉnh"

msgid ""
"Permanently removes all custom presets you've created. The built-in\n"
"'Default' preset will remain. This cannot be undone."
msgstr ""
"Xóa vĩnh viễn tất cả cấu hình tùy chỉnh bạn đã tạo. Cấu hình tích hợp\n"
"'Mặc định' sẽ vẫn còn. Thao tác này không thể hoàn tác."

msgid ""
"Are you sure you want to delete all custom presets? (built-in presets\n"
"will remain)"
msgstr ""
"Bạn có chắc muốn xóa tất cả cấu hình tùy chỉnh không?\n"
"(Các cấu hình tích hợp sẽ vẫn còn)"

msgid "Delete"
msgstr "Xóa"

msgid "All custom presets deleted. Built-in presets remain."
msgstr "Đã xóa tất cả cấu hình tùy chỉnh. Các cấu hình tích hợp vẫn còn."

msgid "Sleep screen orientation"
msgstr "Hướng màn hình chờ"

msgid ""
"Force the sleep screen to display in a specific orientation, regardless\n"
"of how the device is held."
msgstr ""
"Buộc màn hình chờ hiển thị theo hướng cụ thể, bất kể thiết bị được\n"
"cầm theo chiều nào."

msgid "Auto (follow device)"
msgstr "Tự động (theo thiết bị)"

msgid "Use whatever orientation the device is currently in."
msgstr "Dùng hướng hiện tại của thiết bị."

msgid "Force portrait"
msgstr "Buộc dọc"

msgid "Always display the sleep screen in portrait mode."
msgstr "Luôn hiển thị màn hình chờ theo chiều dọc."

msgid "Force landscape"
msgstr "Buộc ngang"

msgid "Always display the sleep screen in landscape mode."
msgstr "Luôn hiển thị màn hình chờ theo chiều ngang."

msgid "Force upside-down portrait"
msgstr "Buộc dọc ngược"

msgid "Always display the sleep screen in inverted portrait mode."
msgstr "Luôn hiển thị màn hình chờ theo chiều dọc ngược."

msgid "Force upside-down landscape"
msgstr "Buộc ngang ngược"

msgid "Always display the sleep screen in inverted landscape mode."
msgstr "Luôn hiển thị màn hình chờ theo chiều ngang ngược."

msgid "Battery time calculation"
msgstr "Tính thời gian pin"

msgid "Method used to estimate remaining battery life."
msgstr "Phương pháp ước tính thời gian pin còn lại."

msgid "Since last charge"
msgstr "Kể từ lần sạc cuối"

msgid "Uses combined awake and sleeping battery drain since last charge"
msgstr "Dùng mức tiêu hao pin kết hợp khi hoạt động và ngủ kể từ lần sạc cuối"

msgid "Awake since last charge"
msgstr "Thời gian hoạt động kể từ lần sạc cuối"

msgid "Uses only active reading battery drain (more conservative estimate)"
msgstr "Chỉ dùng mức tiêu hao pin khi đọc sách (ước tính thận trọng hơn)"

msgid "Sleeping since last charge"
msgstr "Thời gian ngủ kể từ lần sạc cuối"

msgid "Uses only sleep mode battery drain"
msgstr "Chỉ dùng mức tiêu hao pin ở chế độ ngủ"

msgid "Manual calculation"
msgstr "Tính thủ công"

msgid "Use a custom battery drain rate (1-10% per hour)"
msgstr "Dùng tốc độ tiêu hao pin tùy chỉnh (1–10%/giờ)"

msgid "Set manual drain rate"
msgstr "Đặt tốc độ tiêu hao thủ công"

msgid "Battery drain rate (% per hour)"
msgstr "Tốc độ tiêu hao pin (%/giờ)"

msgid "Typical devices drain 1-5% per hour while reading."
msgstr "Thiết bị thông thường tiêu hao 1–5%/giờ khi đọc sách."

msgid "Daily statistics scope"
msgstr "Phạm vi thống kê hàng ngày"

msgid ""
"Controls whether today's reading time and page count applies to the\n"
"current book only, or all books read today. Note: reading streak and\n"
"weekly goal achievement always reflect all books regardless of this\n"
"setting."
msgstr ""
"Kiểm soát xem thời gian đọc và số trang hôm nay áp dụng chỉ cho sách\n"
"hiện tại hay tất cả sách đã đọc hôm nay. Lưu ý: chuỗi đọc sách và hoàn\n"
"thành mục tiêu hàng tuần luôn phản ánh tất cả sách bất kể cài đặt này."

msgid "All books"
msgstr "Tất cả sách"

msgid "Today's reading time and page count across all books read today"
msgstr "Thời gian đọc và số trang hôm nay cho tất cả sách đã đọc hôm nay"

msgid "Current book only"
msgstr "Chỉ sách hiện tại"

msgid "Today's reading time and page count for the current book only"
msgstr "Thời gian đọc và số trang hôm nay chỉ cho sách hiện tại"

msgid "Show in file manager (outside of book)"
msgstr "Hiển thị trong trình quản lý tệp (ngoài sách)"

msgid ""
"When enabled, the customisable sleep screen will display in file manager\n"
"using the last saved book data."
msgstr ""
"Khi bật, màn hình chờ tùy chỉnh sẽ hiển thị trong trình quản lý tệp\n"
"bằng dữ liệu sách đã lưu gần nhất."

msgid "Hide built-in presets (except Default)"
msgstr "Ẩn cấu hình tích hợp (trừ Mặc định)"

msgid ""
"Hide the built-in presets from the preset list, keeping only the Default\n"
"preset and your custom presets visible."
msgstr ""
"Ẩn các cấu hình tích hợp khỏi danh sách, chỉ hiển thị cấu hình Mặc định\n"
"và các cấu hình tùy chỉnh của bạn."

msgid "Setting saved. Preset list will update when you reopen this menu."
msgstr "Đã lưu cài đặt. Danh sách cấu hình sẽ cập nhật khi bạn mở lại menu này."

msgid "Export sleep screen to file"
msgstr "Xuất màn hình chờ ra tệp"

msgid ""
"When enabled, a screenshot of the sleep screen will be saved as\n"
"'screensaver.png' in the selected export folder each time a book is\n"
"closed."
msgstr ""
"Khi bật, ảnh chụp màn hình chờ sẽ được lưu dưới dạng 'screensaver.png'\n"
"vào thư mục xuất đã chọn mỗi khi đóng sách."

msgid "Sleep screen export disabled."
msgstr "Xuất màn hình chờ đã tắt."

msgid "No export folder set. Please set an export folder first."
msgstr "Chưa đặt thư mục xuất. Vui lòng đặt thư mục xuất trước."

#, lua-format
msgid ""
"Sleep screen will be exported to:\n"
"%s/screensaver.png"
msgstr ""
"Màn hình chờ sẽ được xuất đến:\n"
"%s/screensaver.png"

msgid "Set export folder"
msgstr "Đặt thư mục xuất"

msgid "Choose the folder where screensaver.png will be saved."
msgstr "Chọn thư mục nơi screensaver.png sẽ được lưu."

#, lua-format
msgid ""
"Export folder set to:\n"
"%s"
msgstr ""
"Thư mục xuất đã đặt thành:\n"
"%s"

msgid "Presets"
msgstr "Cấu hình"

msgid "Save, load, and manage presets."
msgstr "Lưu, tải và quản lý các cấu hình."

msgid "Display modes"
msgstr "Chế độ hiển thị"

msgid "Global appearance settings."
msgstr "Cài đặt giao diện toàn cục."

msgid "Contents"
msgstr "Nội dung"

msgid "Control which sections appear and what information they display."
msgstr "Kiểm soát các phần hiển thị và thông tin chúng hiện thị."

msgid "Layout & Spacing"
msgstr "Bố cục & Khoảng cách"

msgid "Adjust the spatial settings of the information box."
msgstr "Điều chỉnh cài đặt không gian của hộp thông tin."

msgid "Colours, Icons & Bars"
msgstr "Màu sắc, Biểu tượng & Thanh"

msgid ""
"Customise section colours, icon appearance, and progress bar styling."
msgstr "Tùy chỉnh màu sắc phần, giao diện biểu tượng và kiểu thanh tiến trình."

msgid "Fonts & Text"
msgstr "Phông chữ & Văn bản"

msgid "Configure text appearance."
msgstr "Cấu hình giao diện văn bản."

msgid "Background"
msgstr "Nền"

msgid "Choose what appears behind the information box."
msgstr "Chọn nội dung hiển thị phía sau hộp thông tin."

msgid "Advanced"
msgstr "Nâng cao"

msgid "Advanced configuration options."
msgstr "Tùy chọn cấu hình nâng cao."

msgid "About"
msgstr "Giới thiệu"

#, lua-format
msgid ""
"%s\n"
"Version: %s\n"
"\n"
"For updates and issues:\n"
"github.com/%s"
msgstr ""
"%s\n"
"Phiên bản: %s\n"
"\n"
"Cập nhật và báo lỗi:\n"
"github.com/%s"

msgid "Top left"
msgstr "Trên trái"

msgid "Top centre"
msgstr "Trên giữa"

msgid "Top right"
msgstr "Trên phải"

msgid "Middle left"
msgstr "Giữa trái"

msgid "Centre"
msgstr "Giữa"

msgid "Middle right"
msgstr "Giữa phải"

msgid "Bottom left"
msgstr "Dưới trái"

msgid "Bottom centre"
msgstr "Dưới giữa"

msgid "Bottom right"
msgstr "Dưới phải"

msgid "Dark mode"
msgstr "Chế độ tối"

msgid ""
"Inverts the colour scheme. Text becomes white and backgrounds becomes\n"
"black. Useful for reading in low-light conditions. Can be combined with\n"
"monochrome mode."
msgstr ""
"Đảo ngược bảng màu. Văn bản chuyển thành màu trắng, nền chuyển thành màu\n"
"đen. Hữu ích khi đọc trong điều kiện ánh sáng yếu. Có thể kết hợp với\n"
"chế độ đơn sắc."

msgid "Monochrome mode"
msgstr "Chế độ đơn sắc"

msgid ""
"Suitable for B&W e-readers. Assigns one colour to all sections using\n"
"monochrome light or monochrome dark hex values. Overwrites individual\n"
"assigned section colours. Can be combined with dark mode."
msgstr ""
"Phù hợp với máy đọc sách đen trắng. Gán một màu cho tất cả các phần bằng\n"
"cách sử dụng giá trị hex đơn sắc sáng hoặc đơn sắc tối. Ghi đè màu phần\n"
"riêng lẻ. Có thể kết hợp với chế độ tối."

msgid "Section gaps"
msgstr "Khoảng cách giữa các phần"

msgid ""
"Add transparent gaps between sections to make each appear as a separate\n"
"box"
msgstr ""
"Thêm khoảng cách trong suốt giữa các phần để mỗi phần hiển thị như\n"
"một hộp riêng biệt"

msgid "Enable section gaps"
msgstr "Bật khoảng cách giữa các phần"

msgid "Section gap size"
msgstr "Kích thước khoảng cách phần"

msgid "Spacing between sections when gaps are enabled."
msgstr "Khoảng cách giữa các phần khi bật khoảng cách."

msgid "Section gap size (pixels)"
msgstr "Kích thước khoảng cách phần (pixel)"

msgid ""
"10–20px gives a subtle separation. 30–50px makes sections feel like\n"
"distinct cards."
msgstr ""
"10–20px tạo sự phân cách tinh tế. 30–50px khiến các phần trông như\n"
"những thẻ riêng biệt."

msgid "Position"
msgstr "Vị trí"

msgid "Screen location where the information box appears."
msgstr "Vị trí trên màn hình nơi hộp thông tin hiển thị."

msgid "Position offset"
msgstr "Độ lệch vị trí"

msgid ""
"Nudge the box from its anchor position. Useful for pushing rounded\n"
"corners off-screen."
msgstr ""
"Dịch chuyển hộp khỏi vị trí neo. Hữu ích để đẩy các góc bo tròn ra\n"
"ngoài màn hình."

msgid "Horizontal offset (px)"
msgstr "Độ lệch ngang (px)"

msgid ""
"Nudges the box left (-) or right (+) from its anchor. Useful for pushing\n"
"rounded corners off-screen."
msgstr ""
"Dịch chuyển hộp sang trái (-) hoặc phải (+) từ điểm neo. Hữu ích để đẩy\n"
"các góc bo tròn ra ngoài màn hình."

msgid "Vertical offset (px)"
msgstr "Độ lệch dọc (px)"

msgid ""
"Nudges the box up (+) or down (-) from its anchor. Useful for pushing\n"
"rounded corners off-screen."
msgstr ""
"Dịch chuyển hộp lên (+) hoặc xuống (-) từ điểm neo. Hữu ích để đẩy\n"
"các góc bo tròn ra ngoài màn hình."

msgid "Width"
msgstr "Chiều rộng"

msgid ""
"Horizontal width of the information box as a percentage of screen width."
msgstr "Chiều rộng ngang của hộp thông tin theo phần trăm chiều rộng màn hình."

msgid "Box width (%)"
msgstr "Chiều rộng hộp (%)"

msgid "60–70% suits portrait screens."
msgstr "60–70% phù hợp với màn hình dọc."

msgid "Opacity"
msgstr "Độ mờ"

msgid "Transparency of the information box."
msgstr "Độ trong suốt của hộp thông tin."

msgid "Opacity (%)"
msgstr "Độ mờ (%)"

msgid "75% is semi-transparent. 100% is fully opaque."
msgstr "75% là nửa trong suốt. 100% là hoàn toàn mờ đục."

msgid "Border size"
msgstr "Kích thước viền"

msgid "Thickness of the primary border around sections."
msgstr "Độ dày của viền chính quanh các phần."

msgid "Border size (px)"
msgstr "Kích thước viền (px)"

msgid "0 for no border. 1–2px is subtle, 4–6px is bold and visible."
msgstr "0 là không viền. 1–2px tinh tế, 4–6px đậm và rõ ràng."

msgid "Border trim size"
msgstr "Kích thước viền trang trí"

msgid "Secondary decorative border surrounding the primary border."
msgstr "Viền trang trí phụ bao quanh viền chính."

msgid "Border trim size (px)"
msgstr "Kích thước viền trang trí (px)"

msgid ""
"0 for no trim. 1–2px is subtle, 4–6px is a bold decorative outline\n"
"around the primary border."
msgstr ""
"0 là không có viền trang trí. 1–2px tinh tế, 4–6px là đường viền trang\n"
"trí đậm xung quanh viền chính."

msgid "Corner radius"
msgstr "Bán kính góc"

msgid ""
"Round the corners of the info box. Also moves progress bars inline with\n"
"the text when active."
msgstr ""
"Bo tròn các góc của hộp thông tin. Khi bật cũng chuyển thanh tiến trình\n"
"vào cùng dòng với văn bản."

msgid "Corner radius (px)"
msgstr "Bán kính góc (px)"

msgid ""
"0 for square corners. 15–30px for softly rounded. 150px+ for a\n"
"pill-shaped box (depending on the section box height)."
msgstr ""
"0 là góc vuông. 15–30px bo tròn nhẹ. 150px+ tạo hộp hình viên thuốc\n"
"(tùy thuộc vào chiều cao hộp phần)."

msgid "Internal padding"
msgstr "Đệm bên trong"

msgid ""
"Space between section borders and their content, configurable per side."
msgstr "Khoảng cách giữa viền phần và nội dung, có thể cấu hình từng mặt riêng."

msgid "Top"
msgstr "Trên"

msgid "Internal padding — top (px)"
msgstr "Đệm bên trong — trên (px)"

msgid "Space above section content."
msgstr "Khoảng cách phía trên nội dung phần."

msgid "Bottom"
msgstr "Dưới"

msgid "Internal padding — bottom (px)"
msgstr "Đệm bên trong — dưới (px)"

msgid "Space below section content."
msgstr "Khoảng cách phía dưới nội dung phần."

msgid "Left"
msgstr "Trái"

msgid "Internal padding — left (px)"
msgstr "Đệm bên trong — trái (px)"

msgid ""
"Space to the left of section content. Increase when using large corner\n"
"radii."
msgstr ""
"Khoảng cách bên trái nội dung phần. Tăng khi dùng bán kính góc lớn."

msgid "Right"
msgstr "Phải"

msgid "Internal padding — right (px)"
msgstr "Đệm bên trong — phải (px)"

msgid ""
"Space to the right of section content. Increase when using large corner\n"
"radii."
msgstr ""
"Khoảng cách bên phải nội dung phần. Tăng khi dùng bán kính góc lớn."

msgid "Set all sides equally"
msgstr "Đặt tất cả các mặt bằng nhau"

msgid "Internal padding — all sides (px)"
msgstr "Đệm bên trong — tất cả các mặt (px)"

msgid "Sets top, bottom, left and right padding to the same value in one step."
msgstr "Đặt đệm trên, dưới, trái và phải về cùng một giá trị trong một bước."

msgid "Icon to text gap"
msgstr "Khoảng cách biểu tượng - văn bản"

msgid ""
"Horizontal spacing between section icons and their accompanying text."
msgstr "Khoảng cách ngang giữa biểu tượng phần và văn bản đi kèm."

msgid "Icon to text gap (px)"
msgstr "Khoảng cách biểu tượng - văn bản (px)"

msgid ""
"8–12px gives comfortable breathing room between icon and text. 0 is\n"
"flush."
msgstr ""
"8–12px tạo khoảng cách thoải mái giữa biểu tượng và văn bản. 0 là sát."

msgid "No icon sets found in customisablesleepscreen.koplugin/icons/"
msgstr "Không tìm thấy bộ biểu tượng trong customisablesleepscreen.koplugin/icons/"

msgid "Colours (progress bars)"
msgstr "Màu sắc (thanh tiến trình)"

msgid "Set the progress bar colours for each section."
msgstr "Đặt màu thanh tiến trình cho từng phần."

msgid "Use saved colours for icon fill"
msgstr "Dùng màu đã lưu để tô biểu tượng"

msgid ""
"When enabled, icons will match the colour of their section's progress\n"
"bar."
msgstr ""
"Khi bật, biểu tượng sẽ khớp màu với thanh tiến trình của phần đó."

msgid "Book section"
msgstr "Phần sách"

msgid "Chapter section"
msgstr "Phần chương"

msgid "Daily goal section"
msgstr "Phần mục tiêu hàng ngày"

msgid "Battery section (High)"
msgstr "Phần pin (Cao)"

msgid "Battery section (Med)"
msgstr "Phần pin (Trung bình)"

msgid "Battery section (Low)"
msgstr "Phần pin (Thấp)"

msgid "Battery section (Charging)"
msgstr "Phần pin (Đang sạc)"

msgid "Message section"
msgstr "Phần tin nhắn"

msgid "Colours (modes)"
msgstr "Màu sắc (chế độ)"

msgid ""
"Configure colours for monochrome mode, infobox background, and text.\n"
"Light and dark correspond to the current dark mode setting. Monochrome\n"
"replaces all colours with that single chosen color."
msgstr ""
"Cấu hình màu sắc cho chế độ đơn sắc, nền hộp thông tin và văn bản.\n"
"Sáng và tối tương ứng với cài đặt chế độ tối hiện tại. Đơn sắc thay thế\n"
"tất cả màu sắc bằng một màu đã chọn."

msgid "Monochrome mode (light)"
msgstr "Chế độ đơn sắc (sáng)"

msgid "Monochrome mode (dark)"
msgstr "Chế độ đơn sắc (tối)"

msgid "Background (light)"
msgstr "Nền (sáng)"

msgid "Background (dark)"
msgstr "Nền (tối)"

msgid "Text (light)"
msgstr "Văn bản (sáng)"

msgid "Text (dark)"
msgstr "Văn bản (tối)"

msgid "Icon set"
msgstr "Bộ biểu tượng"

msgid "Choose from different icon styles."
msgstr "Chọn từ các kiểu biểu tượng khác nhau."

msgid "Icon size"
msgstr "Kích thước biểu tượng"

msgid "Size of section icons."
msgstr "Kích thước biểu tượng phần."

msgid "Icon size (px)"
msgstr "Kích thước biểu tượng (px)"

msgid "32–48px suits most layouts."
msgstr "32–48px phù hợp với hầu hết các bố cục."

msgid "Progress bar height"
msgstr "Chiều cao thanh tiến trình"

msgid "Thickness of the horizontal progress bars shown in each section."
msgstr "Độ dày của các thanh tiến trình ngang hiển thị trong mỗi phần."

msgid "Bar height (px)"
msgstr "Chiều cao thanh (px)"

msgid "4–8px is subtle. 12–16px is standard. 20+px is heavy."
msgstr "4–8px tinh tế. 12–16px tiêu chuẩn. 20px+ nặng."

msgid "Show icons"
msgstr "Hiển thị biểu tượng"

msgid "Display decorative icons at the start of each section."
msgstr "Hiển thị biểu tượng trang trí ở đầu mỗi phần."

msgid "Show progress bars"
msgstr "Hiển thị thanh tiến trình"

msgid "Display horizontal progress bars showing completion percentage."
msgstr "Hiển thị các thanh tiến trình ngang cho thấy phần trăm hoàn thành."

msgid "Show decorative bar on message section"
msgstr "Hiển thị thanh trang trí trong phần tin nhắn"

msgid ""
"Displays a purely decorative progress bar under the message section,\n"
"matching the message section colour and the progress bars in other\n"
"sections."
msgstr ""
"Hiển thị thanh tiến trình thuần trang trí bên dưới phần thông điệp,\n"
"khớp với màu của phần thông điệp và các thanh tiến trình ở các phần khác."

msgid "Inline progress bars"
msgstr "Thanh tiến trình nội tuyến"

msgid ""
"Progress bars sit inside the text area rather than spanning the full\n"
"section width. Automatically enabled when corner radius > 0."
msgstr ""
"Thanh tiến trình nằm bên trong vùng văn bản thay vì trải dài toàn bộ\n"
"chiều rộng phần. Tự động bật khi bán kính góc > 0."

msgid "Enable inline bars"
msgstr "Bật thanh nội tuyến"

msgid "When section gaps are enabled and corner radius > 0, inline bars are automatically enabled."
msgstr "Khi khoảng cách phần được bật và bán kính góc > 0, các thanh nội tuyến sẽ tự động được bật."

msgid "Inline bars are force-enabled because section gaps and corner radius are both set. Set corner radius to 0 or disable section gaps to toggle inline bars independently."
msgstr "Các thanh nội tuyến bị bật bắt buộc vì khoảng cách phần và bán kính góc đều được đặt. Đặt bán kính góc về 0 hoặc tắt khoảng cách phần để bật tắt các thanh nội tuyến một cách độc lập."

msgid "Inline bar border size"
msgstr "Kích thước viền thanh nội tuyến"

msgid "Thickness of the border around the inline progress bar."
msgstr "Độ dày của viền xung quanh thanh tiến trình nội tuyến."

msgid "Inline bar border size (px)"
msgstr "Kích thước viền thanh nội tuyến (px)"

msgid "0 for no border. 1–2px adds a subtle outline around the bar."
msgstr "0 là không viền. 1–2px thêm đường viền tinh tế xung quanh thanh."

msgid "Bar width"
msgstr "Chiều rộng thanh"

msgid ""
"Width of the inline progress bar as a percentage of the available text\n"
"column. Alignment follows the text alignment setting."
msgstr ""
"Chiều rộng của thanh tiến trình nội tuyến theo phần trăm cột văn bản\n"
"có sẵn. Căn chỉnh theo cài đặt căn chỉnh văn bản."

msgid "Inline bar width (%)"
msgstr "Chiều rộng thanh nội tuyến (%)"

msgid ""
"100% fills the text column. The bar is aligned to match your text\n"
"alignment setting."
msgstr ""
"100% lấp đầy cột văn bản. Thanh được căn chỉnh theo cài đặt căn chỉnh\n"
"văn bản của bạn."

msgid "Title font face"
msgstr "Phông chữ tiêu đề"

msgid "Choose the font face for the main heading text in each section"
msgstr "Chọn phông chữ cho văn bản tiêu đề chính trong mỗi phần"

msgid "Title font size"
msgstr "Cỡ chữ tiêu đề"

msgid "Choose the font size for the main heading text in each section."
msgstr "Chọn cỡ chữ cho văn bản tiêu đề chính trong mỗi phần."

msgid "10–12px works well for most screens."
msgstr "10–12px phù hợp với hầu hết các màn hình."

msgid "Subtitle font face"
msgstr "Phông chữ phụ đề"

msgid ""
"Choose the font face for the information below the main heading text."
msgstr "Chọn phông chữ cho thông tin bên dưới văn bản tiêu đề chính."

msgid "Subtitle font size"
msgstr "Cỡ chữ phụ đề"

msgid ""
"Choose the font size for the information below the main heading text."
msgstr "Chọn cỡ chữ cho thông tin bên dưới văn bản tiêu đề chính."

msgid "9–11px works well for most screens."
msgstr "9–11px phù hợp với hầu hết các màn hình."

msgid "Text alignment"
msgstr "Căn chỉnh văn bản"

msgid "Horizontal alignment of all text within sections."
msgstr "Căn chỉnh ngang của tất cả văn bản trong các phần."

msgid "Book multiline titles"
msgstr "Tiêu đề sách nhiều dòng"

msgid ""
"If deselected book titles will be truncated to a single line with an\n"
"ellipsis"
msgstr ""
"Nếu bỏ chọn, tiêu đề sách sẽ bị cắt thành một dòng với dấu chấm lửng"

msgid "Chapter multiline titles"
msgstr "Tiêu đề chương nhiều dòng"

msgid ""
"If deselected chapter titles will be truncated to a single line with an\n"
"ellipsis"
msgstr ""
"Nếu bỏ chọn, tiêu đề chương sẽ bị cắt thành một dòng với dấu chấm lửng"

msgid "Clean chapter titles"
msgstr "Làm sạch tiêu đề chương"

msgid ""
"Removes structural prefixes like 'Chapter 5:' or 'Part II' from chapter\n"
"titles and normalises capitalisation. Only works correctly with English\n"
"chapter titles - disable for non-English books."
msgstr ""
"Xóa các tiền tố cấu trúc như 'Chapter 5:' hoặc 'Part II' khỏi tiêu đề\n"
"chương và chuẩn hóa chữ hoa. Chỉ hoạt động chính xác với tiêu đề chương\n"
"tiếng Anh — tắt đi cho sách không phải tiếng Anh."

msgid "Make titles bold"
msgstr "In đậm tiêu đề"

msgid ""
"Display the section titles in bold font weight for extra emphasis."
msgstr "Hiển thị tiêu đề phần bằng phông chữ đậm để nhấn mạnh thêm."

msgid "No background"
msgstr "Không có nền"

msgid "Book cover"
msgstr "Bìa sách"

msgid "Solid colour"
msgstr "Màu đơn sắc"

msgid "Random image from folder"
msgstr "Hình ảnh ngẫu nhiên từ thư mục"

msgid "Stretch book cover to fill"
msgstr "Kéo giãn bìa sách để lấp đầy"

msgid ""
"When disabled, book cover will be scaled to fit within the screen while\n"
"preserving aspect ratio."
msgstr ""
"Khi tắt, bìa sách sẽ được thu nhỏ/phóng to để vừa với màn hình trong\n"
"khi giữ nguyên tỷ lệ khung hình."

msgid "Cover fill colour"
msgstr "Màu nền bìa sách"

msgid "Background colour for non-stretched covers."
msgstr "Màu nền cho bìa không kéo giãn."

msgid "Pick cover fill colour"
msgstr "Chọn màu nền bìa sách"

msgid "Cover alignment"
msgstr "Căn chỉnh bìa sách"

msgid "Horizontal alignment of the cover image when not stretched."
msgstr "Căn chỉnh ngang của ảnh bìa khi không kéo dài."

msgid "Solid background colour"
msgstr "Màu nền đơn sắc"

msgid "Pick background colour"
msgstr "Chọn màu nền"

msgid "Background folder path"
msgstr "Đường dẫn thư mục nền"

msgid ""
"No images found in the selected folder. No background will be shown."
msgstr "Không tìm thấy hình ảnh trong thư mục đã chọn. Sẽ không hiển thị nền."

msgid "Background type"
msgstr "Loại nền"

msgid "Background overlay"
msgstr "Lớp phủ nền"

msgid "Add a colour layer over the background to reduce contrast."
msgstr "Thêm lớp màu lên nền để giảm độ tương phản."

msgid "Overlay colour"
msgstr "Màu phủ"

msgid "Background overlay colour"
msgstr "Màu phủ nền"

msgid "Overlay opacity"
msgstr "Độ mờ lớp phủ"

msgid "Overlay opacity (%)"
msgstr "Độ mờ lớp phủ (%)"

msgid "0% is no overlay. 20–40% adds a soft tint. 100% is fully opaque."
msgstr "0% là không có lớp phủ. 20–40% thêm màu nhạt mềm. 100% là hoàn toàn mờ đục."

msgid "Reset layout & spacing settings to default"
msgstr "Đặt lại cài đặt bố cục & khoảng cách"

msgid "Are you sure you want to reset layout & spacing settings?"
msgstr "Bạn có chắc muốn đặt lại cài đặt bố cục & khoảng cách không?"

msgid "Layout & spacing settings reset to defaults"
msgstr "Đã đặt lại cài đặt bố cục & khoảng cách"

msgid "Reset contents settings to default"
msgstr "Đặt lại cài đặt nội dung"

msgid "Are you sure you want to reset contents settings?"
msgstr "Bạn có chắc muốn đặt lại cài đặt nội dung không?"

msgid "Contents settings reset to defaults"
msgstr "Đã đặt lại cài đặt nội dung"

msgid "Reset colours, icons & bars settings to default"
msgstr "Đặt lại cài đặt màu sắc, biểu tượng & thanh"

msgid "Are you sure you want to reset colours, icons & bars settings?"
msgstr "Bạn có chắc muốn đặt lại cài đặt màu sắc, biểu tượng & thanh không?"

msgid "Colours, icons & bars settings reset to defaults"
msgstr "Đã đặt lại cài đặt màu sắc, biểu tượng & thanh"

msgid "Reset fonts & text settings to default"
msgstr "Đặt lại cài đặt phông chữ & văn bản"

msgid "Are you sure you want to reset fonts & text settings?"
msgstr "Bạn có chắc muốn đặt lại cài đặt phông chữ & văn bản không?"

msgid "Fonts & text settings reset to defaults"
msgstr "Đã đặt lại cài đặt phông chữ & văn bản"

msgid "Reset background settings to default"
msgstr "Đặt lại cài đặt nền"

msgid "Are you sure you want to reset background settings?"
msgstr "Bạn có chắc muốn đặt lại cài đặt nền không?"

msgid "Background settings reset to defaults"
msgstr "Đã đặt lại cài đặt nền"

msgid "Reset the settings in this part of the menu to their defaults."
msgstr "Đặt lại cài đặt trong phần menu này về mặc định."

msgid "factory defaults"
msgstr "cài đặt mặc định của nhà máy"

#, lua-format
msgid "Values will be restored from: %s"
msgstr "Các giá trị sẽ được khôi phục từ: %s"

msgid "Reset"
msgstr "Đặt lại"

msgid "Save"
msgstr "Lưu"

msgid "None"
msgstr "Không có"

msgid "Active preset: "
msgstr "Cấu hình đang dùng: "

msgid "Save current settings as new preset"
msgstr "Lưu cài đặt hiện tại làm cấu hình mới"

#, lua-format
msgid "What would you like to do with preset '%s'?"
msgstr "Bạn muốn làm gì với cấu hình '%s'?"

msgid "Update"
msgstr "Cập nhật"

#, lua-format
msgid "Are you sure you want to overwrite preset '%s' with current settings?"
msgstr "Bạn có chắc muốn ghi đè cấu hình '%s' bằng cài đặt hiện tại không?"

#, lua-format
msgid "Preset '%s' was updated with current settings"
msgstr "Cấu hình '%s' đã được cập nhật bằng cài đặt hiện tại"

#, lua-format
msgid "Are you sure you want to delete preset '%s'?"
msgstr "Bạn có chắc muốn xóa cấu hình '%s' không?"

msgid "Rename"
msgstr "Đổi tên"

msgid "Enter new preset name"
msgstr "Nhập tên cấu hình mới"

msgid "[ Built-in Presets ]"
msgstr "[ Cấu hình tích hợp ]"

msgid "[ Your Custom Presets ]"
msgstr "[ Cấu hình tùy chỉnh của bạn ]"

msgid "Book info"
msgstr "Thông tin sách"

msgid "Chapter info"
msgstr "Thông tin chương"

msgid "Daily info"
msgstr "Thông tin hàng ngày"

msgid "Battery info"
msgstr "Thông tin pin"

msgid "Message info"
msgstr "Thông tin tin nhắn"

msgid "Reorder sections"
msgstr "Sắp xếp lại các phần"

msgid "Section order"
msgstr "Thứ tự phần"

msgid "At least one section must remain visible."
msgstr "Ít nhất một phần phải hiển thị."

msgid "Show cover image above book info"
msgstr "Hiển thị ảnh bìa trên thông tin sách"

msgid ""
"Display the book's cover image above the title and progress in the book\n"
"section."
msgstr ""
"Hiển thị ảnh bìa sách phía trên tiêu đề và tiến trình trong phần sách."

msgid "Cover image size"
msgstr "Kích thước ảnh bìa"

msgid "Height limit for the cover image in pixels."
msgstr "Giới hạn chiều cao của ảnh bìa tính bằng pixel."

msgid "Cover image size (pixels)"
msgstr "Kích thước ảnh bìa (pixel)"

msgid ""
"100–150px fits neatly in most layouts. Go up to 250px+ for a prominent\n"
"cover."
msgstr ""
"100–150px vừa vặn trong hầu hết các bố cục. Lên đến 250px+ để có\n"
"bìa nổi bật."

msgid "Cover border size"
msgstr "Kích thước viền bìa"

msgid ""
"Width of the border drawn around the cover image. Set to 0 for no\n"
"border."
msgstr ""
"Độ rộng của viền vẽ xung quanh ảnh bìa. Đặt thành 0 để không có viền."

msgid "Cover border size (pixels)"
msgstr "Kích thước viền bìa (pixel)"

msgid "1–3px for a subtle outline. 0 to disable."
msgstr "1–3px cho đường viền tinh tế. 0 để tắt."

msgid "Align cover to text alignment"
msgstr "Căn bìa theo căn chỉnh văn bản"

msgid ""
"When enabled, the cover image follows the text alignment setting instead\n"
"of always being centered."
msgstr ""
"Khi bật, ảnh bìa theo cài đặt căn chỉnh văn bản thay vì luôn căn giữa."

msgid "Cover image"
msgstr "Ảnh bìa"

msgid "Configure the book cover image shown above the book section."
msgstr "Cấu hình ảnh bìa sách hiển thị phía trên phần sách."

msgid "Show book author"
msgstr "Hiển thị tác giả sách"

msgid "Display the author name below the book title."
msgstr "Hiển thị tên tác giả bên dưới tiêu đề sách."

msgid "Show series name"
msgstr "Hiển thị tên bộ sách"

msgid "Display the book's series name and index below the title."
msgstr "Hiển thị tên bộ sách và số thứ tự bên dưới tiêu đề."

msgid "Show book pages (pg x of x)"
msgstr "Hiển thị số trang sách (tr. x / x)"

msgid "Display total page count for the entire book."
msgstr "Hiển thị tổng số trang của toàn bộ cuốn sách."

msgid "Show book time remaining"
msgstr "Hiển thị thời gian đọc còn lại"

msgid ""
"Estimated reading time left to finish the book, based on your average\n"
"reading speed."
msgstr ""
"Thời gian đọc ước tính còn lại để hoàn thành cuốn sách, dựa trên tốc độ\n"
"đọc trung bình của bạn."

msgid "Show chapter count (ch x of x)"
msgstr "Hiển thị số chương (ch. x / x)"

msgid ""
"Display current chapter number and total chapters (e.g., 'Chapter 5 of\n"
"12')."
msgstr ""
"Hiển thị số chương hiện tại và tổng số chương (ví dụ: 'Chương 5 / 12')."

msgid "Show chapter pages (pg x of x)"
msgstr "Hiển thị số trang chương (tr. x / x)"

msgid "Display the number of pages in the current chapter."
msgstr "Hiển thị số trang trong chương hiện tại."

msgid "Show chapter time remaining"
msgstr "Hiển thị thời gian còn lại của chương"

msgid ""
"Estimated time to finish the current chapter, based on your reading\n"
"speed."
msgstr ""
"Thời gian ước tính để hoàn thành chương hiện tại, dựa trên tốc độ đọc\n"
"của bạn."

msgid "Title Line"
msgstr "Dòng tiêu đề"

msgid "Choose what the top line of the daily info section displays."
msgstr "Chọn nội dung hiển thị ở dòng đầu của phần thông tin hàng ngày."

msgid "Pages read today"
msgstr "Số trang đọc hôm nay"

msgid "e.g. '35 pages read today'"
msgstr "vd: '35 trang đã đọc hôm nay'"

msgid "Time read today"
msgstr "Thời gian đọc hôm nay"

msgid "e.g. '42 mins read today'"
msgstr "vd: '42 phút đã đọc hôm nay'"

msgid "Pages and time read today"
msgstr "Số trang và thời gian đọc hôm nay"

msgid "e.g. '35 pgs & 42 mins read today'"
msgstr "vd: '35 tr. & 42 phút đã đọc hôm nay'"

msgid "Goal type"
msgstr "Loại mục tiêu"

msgid ""
"Choose whether your daily goal tracks pages read or time spent reading."
msgstr "Chọn xem mục tiêu hàng ngày theo dõi số trang đọc hay thời gian đọc."

msgid "Page goal"
msgstr "Mục tiêu trang"

msgid "Track daily progress by number of pages read."
msgstr "Theo dõi tiến độ hàng ngày theo số trang đã đọc."

msgid "Time goal"
msgstr "Mục tiêu thời gian"

msgid "Track daily progress by minutes spent reading."
msgstr "Theo dõi tiến độ hàng ngày theo số phút đọc sách."

msgid "Daily page goal"
msgstr "Mục tiêu trang hàng ngày"

msgid "Set how many pages you aim to read each day."
msgstr "Đặt số trang bạn muốn đọc mỗi ngày."

msgid "Daily page goal (pages)"
msgstr "Mục tiêu trang hàng ngày (trang)"

msgid "20–50 pages for a daily habit. 50–100 for dedicated reading sessions."
msgstr "20–50 trang cho thói quen hàng ngày. 50–100 cho các buổi đọc chuyên tâm."

msgid "Daily time goal"
msgstr "Mục tiêu thời gian hàng ngày"

msgid "Set how many minutes you aim to read each day."
msgstr "Đặt số phút bạn muốn đọc mỗi ngày."

msgid "Daily time goal (minutes)"
msgstr "Mục tiêu thời gian hàng ngày (phút)"

msgid ""
"20–30 mins for a daily habit. 60+ mins for dedicated reading sessions."
msgstr "20–30 phút cho thói quen hàng ngày. 60+ phút cho các buổi đọc chuyên tâm."

msgid "Show current reading streak"
msgstr "Hiển thị chuỗi đọc sách hiện tại"

msgid "Display consecutive days you've met your reading goal."
msgstr "Hiển thị số ngày liên tiếp bạn đạt mục tiêu đọc sách."

msgid "Show weekly progress"
msgstr "Hiển thị tiến độ hàng tuần"

msgid ""
"Days this week you have met your reading goal, shown as completed days\n"
"out of the current weekday (Monday = 1... Sunday = 7). For example:\n"
"Thursday with goals met on Monday and Tuesday will show 2/4."
msgstr ""
"Số ngày trong tuần bạn đạt mục tiêu đọc sách, hiển thị dưới dạng ngày\n"
"hoàn thành trên tổng ngày đến ngày hiện tại trong tuần (Thứ Hai = 1...\n"
"Chủ Nhật = 7). Ví dụ: Thứ Năm với mục tiêu đạt vào Thứ Hai và Thứ Ba\n"
"sẽ hiển thị 2/4."

msgid "Show daily goal"
msgstr "Hiển thị mục tiêu hàng ngày"

msgid ""
"Target page mode: e.g. 50 page goal. Target time mode: e.g. 1hr 15min\n"
"time goal."
msgstr ""
"Chế độ mục tiêu trang: vd. mục tiêu 50 trang. Chế độ mục tiêu thời\n"
"gian: vd. mục tiêu 1 giờ 15 phút."

msgid "Show current time/date on separate line"
msgstr "Hiển thị giờ/ngày hiện tại trên dòng riêng"

msgid ""
"Display time/date on its own line below battery percentage instead of\n"
"inline."
msgstr ""
"Hiển thị giờ/ngày trên dòng riêng bên dưới phần trăm pin thay vì hiển\n"
"thị cùng dòng."

msgid "Enable 'Show battery time remaining' to use this option"
msgstr "Bật 'Hiển thị thời gian pin còn lại' để sử dụng tùy chọn này"

msgid "Show date instead of time"
msgstr "Hiển thị ngày thay vì giờ"

msgid ""
"Display current date (e.g. '29th Jan') instead of time in battery\n"
"section"
msgstr ""
"Hiển thị ngày hiện tại (ví dụ: '29 tháng 1') thay vì giờ trong phần pin"

msgid "Show battery consumption rate"
msgstr "Hiển thị tốc độ tiêu hao pin"

msgid ""
"Display battery drain percentage per hour based on recent usage or\n"
"manual input (see advanced menu)"
msgstr ""
"Hiển thị phần trăm tiêu hao pin mỗi giờ dựa trên mức sử dụng gần đây\n"
"hoặc nhập thủ công (xem menu nâng cao)"

msgid "Show battery time remaining"
msgstr "Hiển thị thời gian pin còn lại"

msgid ""
"Estimated hours and minutes until battery is depleted, based on current\n"
"drain rate."
msgstr ""
"Số giờ và phút ước tính cho đến khi hết pin, dựa trên tốc độ tiêu hao\n"
"hiện tại."

msgid "Custom message"
msgstr "Tin nhắn tùy chỉnh"

msgid "Use a separate custom message just for Customisable Sleep Screen"
msgstr "Dùng tin nhắn tùy chỉnh riêng chỉ cho màn hình chờ tùy chỉnh"

msgid "Book highlights"
msgstr "Đánh dấu trong sách"

msgid "Show a random highlight from the current book"
msgstr "Hiển thị một đánh dấu ngẫu nhiên từ cuốn sách hiện tại"

msgid "Custom quotes"
msgstr "Trích dẫn tùy chỉnh"

msgid ""
"Show a random quote from the custom_quotes.lua file in the plugin\n"
"folder."
msgstr ""
"Hiển thị một trích dẫn ngẫu nhiên từ tệp custom_quotes.lua trong thư\n"
"mục plugin."

msgid "KOReader sleep message"
msgstr "Tin nhắn màn hình chờ KOReader"

msgid ""
"Uses KOReaders own sleep screen message function. Enable 'Add custom\n"
"message to sleep screen' to use this (Settings → Screen → Sleep screen\n"
"→ Sleep screen message)."
msgstr ""
"Sử dụng chức năng tin nhắn màn hình chờ riêng của KOReader. Bật 'Thêm\n"
"tin nhắn tùy chỉnh vào màn hình chờ' để sử dụng (Cài đặt → Màn hình →\n"
"Màn hình chờ → Tin nhắn màn hình chờ)."

msgid "Show message header"
msgstr "Hiển thị tiêu đề tin nhắn"

msgid "Show or hide the header label above the message text."
msgstr "Hiển thị hoặc ẩn nhãn tiêu đề phía trên văn bản tin nhắn."

msgid "Message header"
msgstr "Tiêu đề tin nhắn"

msgid ""
"Custom header text displayed above the message. Supports variables: %d,\n"
"%y, %t, %b, %r."
msgstr ""
"Văn bản tiêu đề tùy chỉnh hiển thị phía trên tin nhắn. Hỗ trợ biến:\n"
"%d, %y, %t, %b, %r."

msgid "Change custom message header"
msgstr "Thay đổi tiêu đề tin nhắn tùy chỉnh"

msgid "Edit custom message"
msgstr "Chỉnh sửa tin nhắn tùy chỉnh"

msgid ""
"Write your custom message text. Only active when 'Custom message' is\n"
"selected. Supports variables: %d, %y, %t, %b, %r."
msgstr ""
"Nhập văn bản tin nhắn tùy chỉnh. Chỉ hoạt động khi chọn 'Tin nhắn tùy\n"
"chỉnh'. Hỗ trợ biến: %d, %y, %t, %b, %r."

msgid "Custom Customisable Sleep Screen message"
msgstr "Tin nhắn tùy chỉnh màn hình chờ tùy chỉnh"

msgid "Book highlight maximum length"
msgstr "Độ dài tối đa đánh dấu sách"

msgid "Maximum characters to display for highlights (0 = no limit)."
msgstr "Số ký tự tối đa để hiển thị đánh dấu (0 = không giới hạn)."

msgid "Maximum highlight length (characters)"
msgstr "Độ dài đánh dấu tối đa (ký tự)"

msgid ""
"100–150 chars keeps highlights readable. Set to 0 to show the full\n"
"highlight."
msgstr ""
"100–150 ký tự giữ đánh dấu dễ đọc. Đặt thành 0 để hiển thị đầy đủ\n"
"đánh dấu."

msgid "Add quotation marks to highlights"
msgstr "Thêm dấu ngoặc kép vào đánh dấu"

msgid ""
"Wraps all highlights in curly double quotes, removing any pre-existing\n"
"quotation marks."
msgstr ""
"Bọc tất cả đánh dấu trong dấu ngoặc kép cong, xóa bỏ các dấu ngoặc kép\n"
"có sẵn."

msgid "Show highlight location"
msgstr "Hiển thị vị trí đánh dấu"

msgid ""
"Display the chapter title and page number where the highlight is found,\n"
"shown below the highlight text."
msgstr ""
"Hiển thị tiêu đề chương và số trang nơi đánh dấu được tìm thấy, hiển\n"
"thị bên dưới văn bản đánh dấu."

msgid "Show quote attribution"
msgstr "Hiển thị nguồn trích dẫn"

msgid ""
"Display the author and book name below the quote, if provided in\n"
"custom_quotes.lua."
msgstr ""
"Hiển thị tác giả và tên sách bên dưới trích dẫn, nếu được cung cấp\n"
"trong custom_quotes.lua."

msgid "Show titles (top line)"
msgstr "Hiển thị tiêu đề (dòng trên)"

msgid ""
"Display the main heading text in each section. At least one of titles or\n"
"subtitles must be visible."
msgstr ""
"Hiển thị văn bản tiêu đề chính trong mỗi phần. Ít nhất một trong tiêu\n"
"đề hoặc phụ đề phải hiển thị."

msgid "Cannot hide both titles and subtitles. At least one must be visible."
msgstr "Không thể ẩn cả tiêu đề và phụ đề. Ít nhất một cái phải hiển thị."

msgid "Show subtitles (bottom lines)"
msgstr "Hiển thị phụ đề (dòng dưới)"

msgid ""
"Display information below main heading text in each section. At least\n"
"one of titles or subtitles must be visible."
msgstr ""
"Hiển thị thông tin bên dưới văn bản tiêu đề chính trong mỗi phần. Ít\n"
"nhất một trong tiêu đề hoặc phụ đề phải hiển thị."

msgid "Displayed sections"
msgstr "Các phần hiển thị"

msgid ""
"Toggle which sections show on the sleep screen. At least one must be\n"
"visible."
msgstr ""
"Bật/tắt các phần hiển thị trên màn hình chờ. Ít nhất một phần phải\n"
"hiển thị."

msgid "[ Section Content ]"
msgstr "[ Nội dung phần ]"

msgid "Configure book-specific details."
msgstr "Cấu hình chi tiết riêng của sách."

msgid "Configure chapter-specific details"
msgstr "Cấu hình chi tiết riêng của chương"

msgid "Configure reading goal details"
msgstr "Cấu hình chi tiết mục tiêu đọc sách"

msgid "Battery section"
msgstr "Phần pin"

msgid "Configure battery & time/date details"
msgstr "Cấu hình chi tiết pin & giờ/ngày"

msgid "Configure message-specific details"
msgstr "Cấu hình chi tiết riêng của tin nhắn"

msgid "Customisable sleep screen settings"
msgstr "Cài đặt màn hình chờ tùy chỉnh"

msgid "Customisable sleep screen presets"
msgstr "Cấu hình màn hình chờ tùy chỉnh"

msgid "Cycle through customisable sleep screen presets"
msgstr "Chuyển vòng qua các cấu hình màn hình chờ tùy chỉnh"

msgid "Customisable sleep screen"
msgstr "Màn hình chờ tùy chỉnh"

msgid "Enable customisable sleep screen"
msgstr "Bật màn hình chờ tùy chỉnh"

msgid ""
"Customisable Sleep Screen: no book data found.\n"
"\n"
"Open a book and trigger the sleep screen at least once before it will\n"
"work in the file manager."
msgstr ""
"Màn hình ngủ tùy chỉnh: không tìm thấy dữ liệu sách.\n"
"\n"
"Hãy mở sách và kích hoạt màn hình ngủ ít nhất một lần trước khi nó\n"
"hoạt động trong trình quản lý tệp."
