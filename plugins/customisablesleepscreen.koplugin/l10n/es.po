#. ---- All other strings (menu items, help text, headers, buttons) ----
msgid "Pick a colour"
msgstr "Seleccionar color"

msgid "Cancel"
msgstr "Cancelar"

msgid "Apply"
msgstr "Aplicar"

#, lua-format
msgid "Brightness: %d%%"
msgstr "Brillo: %d%%"

msgid "Enter hex"
msgstr "Introducir hex"

msgid "Enter hex colour code"
msgstr "Introducir código de color hex"

msgid "Invalid hex code. Use format: #RRGGBB"
msgstr "Código hex inválido. Usar formato: #RRGGBB"

msgid "Delete all custom presets"
msgstr "Eliminar todos los preajustes personalizados"

msgid "Permanently removes all custom presets you've created. The built-in\n'Default' preset will remain. This cannot be undone."
msgstr "Elimina permanentemente todos los preajustes personalizados creados. El preajuste integrado 'Predeterminado' permanecerá. Esta acción no se puede deshacer."

msgid "Are you sure you want to delete all custom presets? (built-in presets\nwill remain)"
msgstr "¿Eliminar todos los preajustes personalizados? (los preajustes integrados permanecerán)"

msgid "Delete"
msgstr "Eliminar"

msgid "All custom presets deleted. Built-in presets remain."
msgstr "Todos los preajustes personalizados eliminados. Los preajustes integrados permanecen."

msgid "Sleep screen orientation"
msgstr "Orientación de la pantalla de reposo"

msgid "Force the sleep screen to display in a specific orientation, regardless\nof how the device is held."
msgstr "Fuerza la orientación de la pantalla de reposo independientemente de cómo se sostenga el dispositivo."

msgid "Auto (follow device)"
msgstr "Automático (seguir dispositivo)"

msgid "Use whatever orientation the device is currently in."
msgstr "Usar la orientación actual del dispositivo."

msgid "Force portrait"
msgstr "Forzar orientación vertical"

msgid "Always display the sleep screen in portrait mode."
msgstr "Mostrar siempre la pantalla de reposo en orientación vertical."

msgid "Force landscape"
msgstr "Forzar orientación horizontal"

msgid "Always display the sleep screen in landscape mode."
msgstr "Mostrar siempre la pantalla de reposo en orientación horizontal."

msgid "Force upside-down portrait"
msgstr "Forzar orientación vertical invertida"

msgid "Always display the sleep screen in inverted portrait mode."
msgstr "Mostrar siempre la pantalla de reposo en orientación vertical invertida."

msgid "Force upside-down landscape"
msgstr "Forzar orientación horizontal invertida"

msgid "Always display the sleep screen in inverted landscape mode."
msgstr "Mostrar siempre la pantalla de reposo en orientación horizontal invertida."

msgid "Battery time calculation"
msgstr "Cálculo de autonomía de batería"

msgid "Method used to estimate remaining battery life."
msgstr "Método utilizado para estimar la autonomía restante de la batería."

msgid "Since last charge"
msgstr "Desde la última carga"

msgid "Uses combined awake and sleeping battery drain since last charge"
msgstr "Usa el consumo combinado en activo y en reposo desde la última carga"

msgid "Awake since last charge"
msgstr "Tiempo activo desde la última carga"

msgid "Uses only active reading battery drain (more conservative estimate)"
msgstr "Usa solo el consumo durante la lectura activa (estimación más conservadora)"

msgid "Sleeping since last charge"
msgstr "Tiempo en reposo desde la última carga"

msgid "Uses only sleep mode battery drain"
msgstr "Usa solo el consumo en modo reposo"

msgid "Manual calculation"
msgstr "Cálculo manual"

msgid "Use a custom battery drain rate (1-10% per hour)"
msgstr "Usar una tasa de descarga personalizada (1–10 % por hora)"

msgid "Set manual drain rate"
msgstr "Establecer tasa de descarga manual"

msgid "Battery drain rate (% per hour)"
msgstr "Tasa de descarga (% por hora)"

msgid "Typical devices drain 1-5% per hour while reading."
msgstr "Los dispositivos típicos consumen 1–5 % por hora durante la lectura."

msgid "Daily statistics scope"
msgstr "Ámbito de estadísticas diarias"

msgid "Controls whether today's reading time and page count applies to the\ncurrent book only, or all books read today. Note: reading streak and\nweekly goal achievement always reflect all books regardless of this\nsetting."
msgstr "Controla si el tiempo de lectura y el recuento de páginas de hoy se aplican solo al libro actual o a todos los libros leídos hoy. Nota: la racha de lectura y el logro del objetivo semanal siempre reflejan todos los libros, independientemente de esta configuración."

msgid "All books"
msgstr "Todos los libros"

msgid "Today's reading time and page count across all books read today"
msgstr "Tiempo de lectura y páginas de hoy para todos los libros leídos hoy"

msgid "Current book only"
msgstr "Solo el libro actual"

msgid "Today's reading time and page count for the current book only"
msgstr "Tiempo de lectura y páginas de hoy solo para el libro actual"

msgid "Show in file manager (outside of book)"
msgstr "Mostrar en el gestor de archivos (fuera de un libro)"

msgid "When enabled, the customisable sleep screen will display in file manager\nusing the last saved book data."
msgstr "Cuando está activado, la pantalla de reposo personalizable se muestra en el gestor de archivos usando los últimos datos de libro guardados."

msgid "Hide built-in presets (except Default)"
msgstr "Ocultar preajustes integrados (excepto Predeterminado)"

msgid "Hide the built-in presets from the preset list, keeping only the Default\npreset and your custom presets visible."
msgstr "Oculta los preajustes integrados de la lista, dejando visibles solo el preajuste Predeterminado y sus preajustes personalizados."

msgid "Setting saved. Preset list will update when you reopen this menu."
msgstr "Ajuste guardado. La lista se actualizará al reabrir este menú."

msgid "Export sleep screen to file"
msgstr "Exportar pantalla de reposo a archivo"

msgid "When enabled, a screenshot of the sleep screen will be saved as
'screensaver.png' in the selected export folder each time a book is
closed."
msgstr "Cuando está activado, se guardará una captura de la pantalla de reposo como
'screensaver.png' en la carpeta de exportación seleccionada cada vez que se cierre un libro."

msgid "Sleep screen export disabled."
msgstr "Exportación de pantalla de reposo desactivada."

msgid "No export folder set. Please set an export folder first."
msgstr "No se ha establecido carpeta de exportación. Por favor, establezca primero una carpeta de exportación."

#, lua-format
msgid "Sleep screen will be exported to:
%s/screensaver.png"
msgstr "La pantalla de reposo se exportará a:
%s/screensaver.png"

msgid "Set export folder"
msgstr "Establecer carpeta de exportación"

msgid "Choose the folder where screensaver.png will be saved."
msgstr "Elija la carpeta donde se guardará screensaver.png."

#, lua-format
msgid "Export folder set to:
%s"
msgstr "Carpeta de exportación establecida en:
%s"

msgid "Presets"
msgstr "Preajustes"

msgid "Save, load, and manage presets."
msgstr "Guardar, cargar y gestionar preajustes."

msgid "Display modes"
msgstr "Modos de visualización"

msgid "Global appearance settings."
msgstr "Ajustes de apariencia globales."

msgid "Contents"
msgstr "Contenido"

msgid "Control which sections appear and what information they display."
msgstr "Controlar qué secciones aparecen y qué información muestran."

msgid "Layout & Spacing"
msgstr "Diseño y espaciado"

msgid "Adjust the spatial settings of the information box."
msgstr "Ajustar los parámetros espaciales del cuadro de información."

msgid "Colours, Icons & Bars"
msgstr "Colores, iconos y barras"

msgid "Customise section colours, icon appearance, and progress bar styling."
msgstr "Personalizar colores de sección, apariencia de iconos y estilo de barras."

msgid "Fonts & Text"
msgstr "Fuentes y texto"

msgid "Configure text appearance."
msgstr "Configurar la apariencia del texto."

msgid "Background"
msgstr "Fondo"

msgid "Choose what appears behind the information box."
msgstr "Elegir qué aparece detrás del cuadro de información."

msgid "Advanced"
msgstr "Avanzado"

msgid "Advanced configuration options."
msgstr "Opciones de configuración avanzadas."

msgid "About"
msgstr "Acerca de"

#, lua-format
msgid "%s\nVersion: %s\n\nFor updates and issues:\ngithub.com/%s"
msgstr "%s\nVersión: %s\n\nPara actualizaciones e incidencias:\ngithub.com/%s"

msgid "Top left"
msgstr "Arriba izquierda"

msgid "Top centre"
msgstr "Arriba centro"

msgid "Top right"
msgstr "Arriba derecha"

msgid "Middle left"
msgstr "Centro izquierda"

msgid "Centre"
msgstr "Centro"

msgid "Middle right"
msgstr "Centro derecha"

msgid "Bottom left"
msgstr "Abajo izquierda"

msgid "Bottom centre"
msgstr "Abajo centro"

msgid "Bottom right"
msgstr "Abajo derecha"

msgid "Dark mode"
msgstr "Modo oscuro"

msgid "Inverts the colour scheme. Text becomes white and backgrounds becomes\nblack. Useful for reading in low-light conditions. Can be combined with\nmonochrome mode."
msgstr "Invierte el esquema de colores. El texto se vuelve blanco y los fondos negros. Útil para leer con poca luz. Se puede combinar con el modo monocromo."

msgid "Monochrome mode"
msgstr "Modo monocromo"

msgid "Suitable for B&W e-readers. Assigns one colour to all sections using\nmonochrome light or monochrome dark hex values. Overwrites individual\nassigned section colours. Can be combined with dark mode."
msgstr "Adecuado para lectores electrónicos B&N. Asigna un color a todas las secciones usando valores hexadecimales monocromo claro u oscuro. Sobrescribe los colores de sección individuales. Se puede combinar con el modo oscuro."

msgid "Section gaps"
msgstr "Separación entre secciones"

msgid "Add transparent gaps between sections to make each appear as a separate\nbox"
msgstr "Añadir separaciones transparentes entre secciones para que cada una aparezca como una caja independiente"

msgid "Enable section gaps"
msgstr "Activar separación entre secciones"

msgid "Section gap size"
msgstr "Tamaño de la separación entre secciones"

msgid "Spacing between sections when gaps are enabled."
msgstr "Espaciado entre secciones cuando las separaciones están activadas."

msgid "Section gap size (pixels)"
msgstr "Tamaño de la separación entre secciones (píxeles)"

msgid "10–20px gives a subtle separation. 30–50px makes sections feel like\ndistinct cards."
msgstr "10–20 px da una separación sutil. 30–50 px hace que las secciones parezcan tarjetas independientes."

msgid "Position"
msgstr "Posición"

msgid "Screen location where the information box appears."
msgstr "Ubicación en pantalla donde aparece el cuadro de información."

msgid "Position offset"
msgstr "Desplazamiento de posición"

msgid "Nudge the box from its anchor position. Useful for pushing rounded
corners off-screen."
msgstr "Desplazar el cuadro desde su posición de anclaje. Útil para empujar las esquinas
redondeadas fuera de la pantalla."

msgid "Horizontal offset (px)"
msgstr "Desplazamiento horizontal (px)"

msgid "Nudges the box left (-) or right (+) from its anchor. Useful for pushing
rounded corners off-screen."
msgstr "Desplaza el cuadro a la izquierda (-) o derecha (+) desde su anclaje. Útil para empujar
esquinas redondeadas fuera de la pantalla."

msgid "Vertical offset (px)"
msgstr "Desplazamiento vertical (px)"

msgid "Nudges the box up (+) or down (-) from its anchor. Useful for pushing
rounded corners off-screen."
msgstr "Desplaza el cuadro hacia arriba (+) o abajo (-) desde su anclaje. Útil para empujar
esquinas redondeadas fuera de la pantalla."

msgid "Width"
msgstr "Anchura"

msgid "Horizontal width of the information box as a percentage of screen width."
msgstr "Anchura horizontal del cuadro de información como porcentaje del ancho de pantalla."

msgid "Box width (%)"
msgstr "Ancho del cuadro (%)"

msgid "60–70% suits portrait screens."
msgstr "60–70% es adecuado para pantallas verticales."

msgid "Opacity"
msgstr "Opacidad"

msgid "Transparency of the information box."
msgstr "Transparencia del cuadro de información."

msgid "Opacity (%)"
msgstr "Opacidad (%)"

msgid "75% is semi-transparent. 100% is fully opaque."
msgstr "75% es semitransparente. 100% es completamente opaco."

msgid "Border size"
msgstr "Tamaño del borde"

msgid "Thickness of the primary border around sections."
msgstr "Grosor del borde principal alrededor de las secciones."

msgid "Border size (px)"
msgstr "Tamaño del borde (px)"

msgid "0 for no border. 1–2px is subtle, 4–6px is bold and visible."
msgstr "0 para sin borde. 1–2px es sutil, 4–6px es llamativo y visible."

msgid "Border trim size"
msgstr "Tamaño del borde decorativo"

msgid "Secondary decorative border surrounding the primary border."
msgstr "Borde decorativo secundario que rodea el borde principal."

msgid "Border trim size (px)"
msgstr "Tamaño del ribete del borde (px)"

msgid "0 for no trim. 1–2px is subtle, 4–6px is a bold decorative outline
around the primary border."
msgstr "0 para sin ribete. 1–2px es sutil, 4–6px es un contorno decorativo llamativo
alrededor del borde primario."

msgid "Corner radius"
msgstr "Radio de esquina"

msgid "Round the corners of the info box. Also moves progress bars inline with
the text when active."
msgstr "Redondear las esquinas del cuadro de información. También mueve las barras de progreso
en línea con el texto cuando está activo."

msgid "Corner radius (px)"
msgstr "Radio de esquina (px)"

msgid "0 for square corners. 15–30px for softly rounded. 150px+ for a
pill-shaped box (depending on the section box height)."
msgstr "0 para esquinas cuadradas. 15–30px para suavemente redondeadas. 150px+ para un
cuadro en forma de píldora (según la altura del cuadro de sección)."

msgid "Internal padding"
msgstr "Relleno interno"

msgid "Space between section borders and their content, configurable per side."
msgstr "Espacio entre los bordes de sección y su contenido, configurable por lado."

msgid "Top"
msgstr "Arriba"

msgid "Internal padding — top (px)"
msgstr "Relleno interno — arriba (px)"

msgid "Space above section content."
msgstr "Espacio sobre el contenido de la sección."

msgid "Bottom"
msgstr "Abajo"

msgid "Internal padding — bottom (px)"
msgstr "Relleno interno — abajo (px)"

msgid "Space below section content."
msgstr "Espacio bajo el contenido de la sección."

msgid "Left"
msgstr "Izquierda"

msgid "Internal padding — left (px)"
msgstr "Relleno interno — izquierda (px)"

msgid "Space to the left of section content. Increase when using large corner
radii."
msgstr "Espacio a la izquierda del contenido de la sección. Aumentar con radios de esquina grandes."

msgid "Right"
msgstr "Derecha"

msgid "Internal padding — right (px)"
msgstr "Relleno interno — derecha (px)"

msgid "Space to the right of section content. Increase when using large corner
radii."
msgstr "Espacio a la derecha del contenido de la sección. Aumentar con radios de esquina grandes."

msgid "Set all sides equally"
msgstr "Establecer todos los lados igual"

msgid "Internal padding — all sides (px)"
msgstr "Relleno interno — todos los lados (px)"

msgid "Sets top, bottom, left and right padding to the same value in one step."
msgstr "Establece el relleno superior, inferior, izquierdo y derecho al mismo valor en un paso."

msgid "Icon to text gap"
msgstr "Separación icono-texto"

msgid "Horizontal spacing between section icons and their accompanying text."
msgstr "Espaciado horizontal entre los iconos de sección y el texto acompañante."

msgid "Icon to text gap (px)"
msgstr "Espacio icono a texto (px)"

msgid "8–12px gives comfortable breathing room between icon and text. 0 is
flush."
msgstr "8–12px da un espacio cómodo entre icono y texto. 0 es
al ras."

msgid "No icon sets found in customisablesleepscreen.koplugin/icons/"
msgstr "No se encontraron conjuntos de iconos en customisablesleepscreen.koplugin/icons/"

msgid "Colours (progress bars)"
msgstr "Colores (barras de progreso)"

msgid "Set the progress bar colours for each section."
msgstr "Establece los colores de la barra de progreso para cada sección."

msgid "Use saved colours for icon fill"
msgstr "Usar colores guardados para el relleno de iconos"

msgid "When enabled, icons will match the colour of their section's progress\nbar."
msgstr "Cuando está activado, los iconos coincidirán con el color de la barra de progreso de su sección."

msgid "Book section"
msgstr "Sección libro"

msgid "Chapter section"
msgstr "Sección capítulo"

msgid "Daily goal section"
msgstr "Sección meta diaria"

msgid "Battery section (High)"
msgstr "Sección batería (Alta)"

msgid "Battery section (Med)"
msgstr "Sección batería (Media)"

msgid "Battery section (Low)"
msgstr "Sección batería (Baja)"

msgid "Battery section (Charging)"
msgstr "Sección batería (Cargando)"

msgid "Message section"
msgstr "Sección mensaje"

msgid "Colours (modes)"
msgstr "Colores (modos)"

msgid "Configure colours for monochrome mode, infobox background, and text.\nLight and dark correspond to the current dark mode setting. Monochrome\nreplaces all colours with that single chosen color."
msgstr "Configura los colores para el modo monocromático, el fondo de la caja de información y el texto. Claro y oscuro corresponden a la configuración actual del modo oscuro. Monocromático reemplaza todos los colores por ese único color elegido."

msgid "Monochrome mode (light)"
msgstr "Modo monocromo (claro)"

msgid "Monochrome mode (dark)"
msgstr "Modo monocromo (oscuro)"

msgid "Background (light)"
msgstr "Fondo (claro)"

msgid "Background (dark)"
msgstr "Fondo (oscuro)"

msgid "Text (light)"
msgstr "Texto (claro)"

msgid "Text (dark)"
msgstr "Texto (oscuro)"

msgid "Icon set"
msgstr "Conjunto de iconos"

msgid "Choose from different icon styles."
msgstr "Elegir entre diferentes estilos de iconos."

msgid "Icon size"
msgstr "Tamaño de iconos"

msgid "Size of section icons."
msgstr "Tamaño de los iconos de sección."

msgid "Icon size (px)"
msgstr "Tamaño de icono (px)"

msgid "32–48px suits most layouts."
msgstr "32–48px es adecuado para la mayoría de diseños."

msgid "Progress bar height"
msgstr "Altura de la barra de progreso"

msgid "Thickness of the horizontal progress bars shown in each section."
msgstr "Grosor de las barras de progreso horizontales mostradas en cada sección."

msgid "Bar height (px)"
msgstr "Altura de barra (px)"

msgid "4–8px is subtle. 12–16px is standard. 20+px is heavy."
msgstr "4–8px es sutil. 12–16px es estándar. 20+px es grueso."

msgid "Show icons"
msgstr "Mostrar iconos"

msgid "Display decorative icons at the start of each section."
msgstr "Mostrar iconos decorativos al inicio de cada sección."

msgid "Show progress bars"
msgstr "Mostrar barras de progreso"

msgid "Display horizontal progress bars showing completion percentage."
msgstr "Mostrar barras de progreso horizontales con el porcentaje de avance."

msgid "Show decorative bar on message section"
msgstr "Mostrar barra decorativa en la sección de mensajes"

msgid "Displays a purely decorative progress bar under the message section,\nmatching the message section colour and the progress bars in other\nsections."
msgstr "Muestra una barra de progreso puramente decorativa bajo la sección de mensajes, con el color de dicha sección y de las barras de progreso de otras secciones."

msgid "Inline progress bars"
msgstr "Barras de progreso en línea"

msgid "Progress bars sit inside the text area rather than spanning the full
section width. Automatically enabled when corner radius > 0."
msgstr "Las barras de progreso se sitúan dentro del área de texto en vez de abarcar el ancho
completo de la sección. Se activa automáticamente cuando el radio de esquina > 0."

msgid "Enable inline bars"
msgstr "Activar barras en línea"

msgid "When section gaps are enabled and corner radius > 0, inline bars are automatically enabled."
msgstr "Cuando los espacios de sección están activados y el radio de esquina > 0, las barras en línea se activan automáticamente."

msgid "Inline bars are force-enabled because section gaps and corner radius are both set. Set corner radius to 0 or disable section gaps to toggle inline bars independently."
msgstr "Las barras en línea están forzadas porque los espacios de sección y el radio de esquina están configurados. Establezca el radio en 0 o desactive los espacios de sección para alternarlas independientemente."

msgid "Inline bar border size"
msgstr "Tamaño del borde de barra en línea"

msgid "Thickness of the border around the inline progress bar."
msgstr "Grosor del borde alrededor de la barra de progreso en línea."

msgid "Inline bar border size (px)"
msgstr "Tamaño del borde de barra en línea (px)"

msgid "0 for no border. 1–2px adds a subtle outline around the bar."
msgstr "0 para sin borde. 1–2px añade un contorno sutil alrededor de la barra."

msgid "Bar width"
msgstr "Ancho de barra"

msgid "Width of the inline progress bar as a percentage of the available text
column. Alignment follows the text alignment setting."
msgstr "Ancho de la barra de progreso en línea como porcentaje de la columna de texto disponible.
La alineación sigue la configuración de alineación de texto."

msgid "Inline bar width (%)"
msgstr "Ancho de barra en línea (%)"

msgid "100% fills the text column. The bar is aligned to match your text
alignment setting."
msgstr "100% rellena la columna de texto. La barra se alinea según la
configuración de alineación de texto."

msgid "Title font face"
msgstr "Tipografía del título"

msgid "Choose the font face for the main heading text in each section"
msgstr "Elegir la tipografía para el texto de encabezado principal en cada sección"

msgid "Title font size"
msgstr "Tamaño de fuente del título"

msgid "Choose the font size for the main heading text in each section."
msgstr "Elegir el tamaño de fuente para el texto de encabezado principal en cada sección."

msgid "10–12px works well for most screens."
msgstr "10–12px funciona bien para la mayoría de pantallas."

msgid "Subtitle font face"
msgstr "Tipografía del subtítulo"

msgid "Choose the font face for the information below the main heading text."
msgstr "Elegir la tipografía para la información debajo del texto de encabezado principal."

msgid "Subtitle font size"
msgstr "Tamaño de fuente del subtítulo"

msgid "Choose the font size for the information below the main heading text."
msgstr "Elegir el tamaño de fuente para la información debajo del texto de encabezado principal."

msgid "9–11px works well for most screens."
msgstr "9–11px funciona bien para la mayoría de pantallas."

msgid "Text alignment"
msgstr "Alineación del texto"

msgid "Horizontal alignment of all text within sections."
msgstr "Alineación horizontal de todo el texto en las secciones."

msgid "Book multiline titles"
msgstr "Títulos de libro en varias líneas"

msgid "If deselected book titles will be truncated to a single line with an\nellipsis"
msgstr "Si está deseleccionado, los títulos de libro se truncarán a una sola línea con puntos suspensivos"

msgid "Chapter multiline titles"
msgstr "Títulos de capítulo en varias líneas"

msgid "If deselected chapter titles will be truncated to a single line with an\nellipsis"
msgstr "Si está deseleccionado, los títulos de capítulo se truncarán a una sola línea con puntos suspensivos"

msgid "Clean chapter titles"
msgstr "Limpiar títulos de capítulo"

msgid "Removes structural prefixes like 'Chapter 5:' or 'Part II' from chapter\ntitles and normalises capitalisation. Only works correctly with English\nchapter titles - disable for non-English books."
msgstr "Elimina prefijos estructurales como 'Capítulo 5:' o 'Parte II' de los títulos de capítulo y normaliza las mayúsculas. Solo funciona correctamente con títulos de capítulo en inglés — desactivar para libros en otros idiomas."

msgid "Make titles bold"
msgstr "Poner títulos en negrita"

msgid "Display the section titles in bold font weight for extra emphasis."
msgstr "Mostrar los títulos de sección en negrita para mayor énfasis."

msgid "No background"
msgstr "Sin fondo"

msgid "Book cover"
msgstr "Portada del libro"

msgid "Solid colour"
msgstr "Color sólido"

msgid "Random image from folder"
msgstr "Imagen aleatoria de una carpeta"

msgid "Stretch book cover to fill"
msgstr "Estirar portada para rellenar"

msgid "When disabled, book cover will be scaled to fit within the screen while\npreserving aspect ratio."
msgstr "Cuando está desactivado, la portada se escalará para ajustarse a la pantalla conservando la relación de aspecto."

msgid "Cover fill colour"
msgstr "Color de relleno de portada"

msgid "Background colour for non-stretched covers."
msgstr "Color de fondo para portadas no estiradas."

msgid "Pick cover fill colour"
msgstr "Seleccionar color de relleno de portada"

msgid "Cover alignment"
msgstr "Alineación de portada"

msgid "Horizontal alignment of the cover image when not stretched."
msgstr "Alineación horizontal de la imagen de portada cuando no está estirada."

msgid "Solid background colour"
msgstr "Color de fondo sólido"

msgid "Pick background colour"
msgstr "Seleccionar color de fondo"

msgid "Background folder path"
msgstr "Ruta de la carpeta de fondos"

msgid "No images found in the selected folder. No background will be shown."
msgstr "No se encontraron imágenes en la carpeta seleccionada. No se mostrará ningún fondo."

msgid "Background type"
msgstr "Tipo de fondo"

msgid "Background overlay"
msgstr "Superposición de fondo"

msgid "Add a colour layer over the background to reduce contrast."
msgstr "Añadir una capa de color sobre el fondo para reducir el contraste."

msgid "Overlay colour"
msgstr "Color de superposición"

msgid "Background overlay colour"
msgstr "Color de superposición del fondo"

msgid "Overlay opacity"
msgstr "Opacidad de superposición"

msgid "Overlay opacity (%)"
msgstr "Opacidad de superposición (%)"

msgid "0% is no overlay. 20–40% adds a soft tint. 100% is fully opaque."
msgstr "0% es sin superposición. 20–40% añade un tinte suave. 100% es completamente opaco."

msgid "Reset layout & spacing settings to default"
msgstr "Restablecer ajustes de diseño y espaciado"

msgid "Are you sure you want to reset layout & spacing settings?"
msgstr "¿Restablecer los ajustes de diseño y espaciado?"

msgid "Layout & spacing settings reset to defaults"
msgstr "Ajustes de diseño y espaciado restablecidos"

msgid "Reset contents settings to default"
msgstr "Restablecer ajustes de contenido"

msgid "Are you sure you want to reset contents settings?"
msgstr "¿Restablecer los ajustes de contenido?"

msgid "Contents settings reset to defaults"
msgstr "Ajustes de contenido restablecidos"

msgid "Reset colours, icons & bars settings to default"
msgstr "Restablecer ajustes de colores, iconos y barras"

msgid "Are you sure you want to reset colours, icons & bars settings?"
msgstr "¿Restablecer los ajustes de colores, iconos y barras?"

msgid "Colours, icons & bars settings reset to defaults"
msgstr "Ajustes de colores, iconos y barras restablecidos"

msgid "Reset fonts & text settings to default"
msgstr "Restablecer ajustes de fuentes y texto"

msgid "Are you sure you want to reset fonts & text settings?"
msgstr "¿Restablecer los ajustes de fuentes y texto?"

msgid "Fonts & text settings reset to defaults"
msgstr "Ajustes de fuentes y texto restablecidos"

msgid "Reset background settings to default"
msgstr "Restablecer ajustes de fondo"

msgid "Are you sure you want to reset background settings?"
msgstr "¿Restablecer los ajustes de fondo?"

msgid "Background settings reset to defaults"
msgstr "Ajustes de fondo restablecidos"

msgid "Reset the settings in this part of the menu to their defaults."
msgstr "Restablecer los ajustes de esta parte del menú a sus valores predeterminados."

msgid "factory defaults"
msgstr "valores predeterminados de fábrica"

#, lua-format
msgid "Values will be restored from: %s"
msgstr "Los valores se restaurarán desde: %s"

msgid "Reset"
msgstr "Restablecer"

msgid "Save"
msgstr "Guardar"

msgid "None"
msgstr "Ninguno"

msgid "Active preset: "
msgstr "Preajuste activo: "

msgid "Save current settings as new preset"
msgstr "Guardar ajustes actuales como nuevo preajuste"

#, lua-format
msgid "What would you like to do with preset '%s'?"
msgstr "¿Qué desea hacer con el preajuste '%s'?"

msgid "Update"
msgstr "Actualizar"

#, lua-format
msgid "Are you sure you want to overwrite preset '%s' with current settings?"
msgstr "¿Sobrescribir el preajuste '%s' con los ajustes actuales?"

#, lua-format
msgid "Preset '%s' was updated with current settings"
msgstr "El preajuste '%s' se actualizó con los ajustes actuales"

#, lua-format
