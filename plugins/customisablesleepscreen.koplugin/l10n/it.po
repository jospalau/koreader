msgstr "[ I tuoi preset personalizzati ]"

msgid "Book info"
msgstr "Info libro"

msgid "Chapter info"
msgstr "Info capitolo"

msgid "Daily info"
msgstr "Info giornaliera"

msgid "Battery info"
msgstr "Info batteria"

msgid "Message info"
msgstr "Info messaggio"

msgid "Reorder sections"
msgstr "Riordina sezioni"

msgid "Section order"
msgstr "Ordine sezioni"

msgid "At least one section must remain visible."
msgstr "Almeno una sezione deve rimanere visibile."

msgid "Show cover image above book info"
msgstr "Mostra immagine di copertina sopra le info del libro"

msgid "Display the book's cover image above the title and progress in the book
section."
msgstr "Visualizza l'immagine di copertina del libro sopra il titolo e il progresso nella sezione
del libro."

msgid "Cover image size"
msgstr "Dimensione immagine di copertina"

msgid "Height limit for the cover image in pixels."
msgstr "Limite di altezza per l'immagine di copertina in pixel."

msgid "Cover image size (pixels)"
msgstr "Dimensione immagine di copertina (pixel)"

msgid "100–150px fits neatly in most layouts. Go up to 250px+ for a prominent
cover."
msgstr "100–150px si adatta bene alla maggior parte dei layout. Fino a 250px+ per una copertina prominente."

msgid "Cover border size"
msgstr "Dimensione bordo copertina"

msgid "Width of the border drawn around the cover image. Set to 0 for no
border."
msgstr "Larghezza del bordo disegnato intorno all'immagine di copertina. Impostare a 0 per
nessun bordo."

msgid "Cover border size (pixels)"
msgstr "Dimensione bordo copertina (pixel)"

msgid "1–3px for a subtle outline. 0 to disable."
msgstr "1–3px per un contorno sottile. 0 per disattivare."

msgid "Align cover to text alignment"
msgstr "Allinea copertina all'allineamento testo"

msgid "When enabled, the cover image follows the text alignment setting instead
of always being centered."
msgstr "Quando attivato, l'immagine di copertina segue l'impostazione di allineamento testo invece
di essere sempre centrata."

msgid "Cover image"
msgstr "Immagine di copertina"

msgid "Configure the book cover image shown above the book section."
msgstr "Configura l'immagine di copertina del libro mostrata sopra la sezione del libro."

msgid "Show book author"
msgstr "Mostra autore del libro"

msgid "Display the author name below the book title."
msgstr "Mostra il nome dell'autore sotto il titolo del libro."

msgid "Show series name"
msgstr "Mostra nome della serie"

msgid "Display the book's series name and index below the title."
msgstr "Mostra il nome della serie e l'indice del libro sotto il titolo."

msgid "Show book pages (pg x of x)"
msgstr "Mostra pagine del libro (pag. x di x)"

msgid "Display total page count for the entire book."
msgstr "Mostra il numero totale di pagine del libro."

msgid "Show book time remaining"
msgstr "Mostra tempo di lettura rimanente"

msgid "Estimated reading time left to finish the book, based on your average\nreading speed."
msgstr "Tempo di lettura stimato per finire il libro, basato sulla velocità di lettura media."

msgid "Show chapter count (ch x of x)"
msgstr "Mostra numero capitoli (cap. x di x)"

msgid "Display current chapter number and total chapters (e.g., 'Chapter 5 of\n12')."
msgstr "Mostra il numero del capitolo corrente e il totale (es. 'Capitolo 5 di 12')."

msgid "Show chapter pages (pg x of x)"
msgstr "Mostra pagine del capitolo (pag. x di x)"

msgid "Display the number of pages in the current chapter."
msgstr "Mostra il numero di pagine nel capitolo corrente."

msgid "Show chapter time remaining"
msgstr "Mostra tempo rimanente del capitolo"

msgid "Estimated time to finish the current chapter, based on your reading\nspeed."
msgstr "Tempo stimato per finire il capitolo corrente, basato sulla velocità di lettura."

msgid "Title Line"
msgstr "Riga del titolo"

msgid "Choose what the top line of the daily info section displays."
msgstr "Scegli cosa mostra la prima riga della sezione informazioni giornaliere."

msgid "Pages read today"
msgstr "Pagine lette oggi"

msgid "e.g. '35 pages read today'"
msgstr "es. '35 pagine lette oggi'"

msgid "Time read today"
msgstr "Tempo letto oggi"

msgid "e.g. '42 mins read today'"
msgstr "es. '42 min letti oggi'"

msgid "Pages and time read today"
msgstr "Pagine e tempo letti oggi"

msgid "e.g. '35 pgs & 42 mins read today'"
msgstr "es. '35 pag. & 42 min letti oggi'"

msgid "Goal type"
msgstr "Tipo di obiettivo"

msgid "Choose whether your daily goal tracks pages read or time spent reading."
msgstr "Scegli se il tuo obiettivo giornaliero tiene traccia delle pagine lette o del tempo di lettura."

msgid "Page goal"
msgstr "Obiettivo di pagine"

msgid "Track daily progress by number of pages read."
msgstr "Monitora il progresso giornaliero in base al numero di pagine lette."

msgid "Time goal"
msgstr "Obiettivo di tempo"

msgid "Track daily progress by minutes spent reading."
msgstr "Monitora il progresso giornaliero in base ai minuti di lettura."

msgid "Daily page goal"
msgstr "Obiettivo di pagine giornaliero"

msgid "Set how many pages you aim to read each day."
msgstr "Imposta quante pagine vuoi leggere ogni giorno."

msgid "Daily page goal (pages)"
msgstr "Obiettivo pagine giornaliero (pagine)"

msgid "20–50 pages for a daily habit. 50–100 for dedicated reading sessions."
msgstr "20–50 pagine per un'abitudine quotidiana. 50–100 per sessioni di lettura dedicate."

msgid "Daily time goal"
msgstr "Obiettivo di tempo giornaliero"

msgid "Set how many minutes you aim to read each day."
msgstr "Imposta quanti minuti vuoi leggere ogni giorno."

msgid "Daily time goal (minutes)"
msgstr "Obiettivo di tempo giornaliero (minuti)"

msgid "20–30 mins for a daily habit. 60+ mins for dedicated reading sessions."
msgstr "20–30 min per un'abitudine quotidiana. 60+ min per sessioni di lettura dedicate."

msgid "Show current reading streak"
msgstr "Mostra serie di lettura attuale"

msgid "Display consecutive days you've met your reading goal."
msgstr "Mostra i giorni consecutivi in cui l'obiettivo di lettura è stato raggiunto."

msgid "Show weekly progress"
msgstr "Mostra progresso settimanale"

msgid "Days this week you have met your reading goal, shown as completed days\nout of the current weekday (Monday = 1... Sunday = 7). For example:\nThursday with goals met on Monday and Tuesday will show 2/4."
msgstr "Giorni di questa settimana in cui hai raggiunto il tuo obiettivo di lettura, mostrati come giorni completati rispetto al giorno corrente della settimana (lunedì = 1... domenica = 7). Esempio: giovedì con obiettivi raggiunti lunedì e martedì mostrerà 2/4."

msgid "Show daily goal"
msgstr "Mostra obiettivo giornaliero"

msgid "Target page mode: e.g. 50 page goal. Target time mode: e.g. 1hr 15min\ntime goal."
msgstr "Modalità obiettivo pagine: es. 50 pagine come obiettivo. Modalità obiettivo tempo: es. 1h 15min come obiettivo."

msgid "Show current time/date on separate line"
msgstr "Mostra ora/data corrente su riga separata"

msgid "Display time/date on its own line below battery percentage instead of\ninline."
msgstr "Mostra l'ora/data su una riga propria sotto la percentuale della batteria anziché in linea."

msgid "Enable 'Show battery time remaining' to use this option"
msgstr "Abilita 'Mostra tempo rimanente batteria' per usare questa opzione"

msgid "Show date instead of time"
msgstr "Mostra data invece dell'ora"

msgid "Display current date (e.g. '29th Jan') instead of time in battery\nsection"
msgstr "Mostra la data corrente (es. '29 gen') invece dell'ora nella sezione batteria"

msgid "Show battery consumption rate"
msgstr "Mostra tasso di consumo batteria"

msgid "Display battery drain percentage per hour based on recent usage or\nmanual input (see advanced menu)"
msgstr "Mostra la percentuale di scarica della batteria all'ora basata sull'uso recente o sull'input manuale (vedi menu avanzate)"

msgid "Show battery time remaining"
msgstr "Mostra tempo rimanente batteria"

msgid "Estimated hours and minutes until battery is depleted, based on current\ndrain rate."
msgstr "Ore e minuti stimati fino all'esaurimento della batteria, basati sul tasso di scarica corrente."

msgid "Custom message"
msgstr "Messaggio personalizzato"

msgid "Use a separate custom message just for Customisable Sleep Screen"
msgstr "Usa un messaggio personalizzato separato solo per la schermata di riposo personalizzabile"

msgid "Book highlights"
msgstr "Evidenziazioni del libro"

msgid "Show a random highlight from the current book"
msgstr "Mostra un'evidenziazione casuale dal libro corrente"

msgid "Custom quotes"
msgstr "Citazioni personalizzate"

msgid "Show a random quote from the custom_quotes.lua file in the plugin\nfolder."
msgstr "Mostra una citazione casuale dal file custom_quotes.lua nella cartella del plugin."

msgid "KOReader sleep message"
msgstr "Messaggio di riposo KOReader"

msgid "Uses KOReaders own sleep screen message function. Enable 'Add custom\nmessage to sleep screen' to use this (Settings → Screen → Sleep screen\n→ Sleep screen message)."
msgstr "Usa la propria funzione di messaggio della schermata di riposo di KOReader. Abilita 'Aggiungi messaggio personalizzato alla schermata di riposo' per utilizzarla (Impostazioni → Schermo → Schermata di riposo → Messaggio schermata di riposo)."

msgid "Show message header"
msgstr "Mostra intestazione messaggio"

msgid "Show or hide the header label above the message text."
msgstr "Mostra o nascondi l'etichetta di intestazione sopra il testo del messaggio."

msgid "Message header"
msgstr "Intestazione messaggio"

msgid "Custom header text displayed above the message. Supports variables: %d,\n%y, %t, %b, %r."
msgstr "Testo di intestazione personalizzato mostrato sopra il messaggio. Supporta le variabili: %d, %y, %t, %b, %r."

msgid "Change custom message header"
msgstr "Modifica intestazione messaggio personalizzato"

msgid "Edit custom message"
msgstr "Modifica messaggio personalizzato"

msgid "Write your custom message text. Only active when 'Custom message' is\nselected. Supports variables: %d, %y, %t, %b, %r."
msgstr "Scrivi il testo del messaggio personalizzato. Attivo solo quando è selezionato 'Messaggio personalizzato'. Supporta le variabili: %d, %y, %t, %b, %r."

msgid "Custom Customisable Sleep Screen message"
msgstr "Messaggio personalizzato della schermata di riposo personalizzabile"

msgid "Book highlight maximum length"
msgstr "Lunghezza massima delle evidenziazioni del libro"

msgid "Maximum characters to display for highlights (0 = no limit)."
msgstr "Numero massimo di caratteri da mostrare per le evidenziazioni (0 = nessun limite)."

msgid "Maximum highlight length (characters)"
msgstr "Lunghezza massima evidenziazione (caratteri)"

msgid "100–150 chars keeps highlights readable. Set to 0 to show the full
highlight."
msgstr "100–150 caratteri mantiene le evidenziazioni leggibili. Imposta a 0 per mostrare l'intera
evidenziazione."

msgid "Add quotation marks to highlights"
msgstr "Aggiungi virgolette alle evidenziazioni"

msgid "Wraps all highlights in curly double quotes, removing any pre-existing\nquotation marks."
msgstr "Racchiude tutte le evidenziazioni tra virgolette tipografiche doppie, rimuovendo eventuali virgolette preesistenti."

msgid "Show highlight location"
msgstr "Mostra posizione dell'evidenziazione"

msgid "Display the chapter title and page number where the highlight is found,\nshown below the highlight text."
msgstr "Mostra il titolo del capitolo e il numero di pagina dove si trova l'evidenziazione, sotto il testo evidenziato."

msgid "Show quote attribution"
msgstr "Mostra attribuzione della citazione"

msgid "Display the author and book name below the quote, if provided in\ncustom_quotes.lua."
msgstr "Mostra autore e titolo del libro sotto la citazione, se forniti in custom_quotes.lua."

msgid "Show titles (top line)"
msgstr "Mostra titoli (riga superiore)"

msgid "Display the main heading text in each section. At least one of titles or\nsubtitles must be visible."
msgstr "Mostra il testo del titolo principale in ciascuna sezione. Almeno uno tra titoli e sottotitoli deve essere visibile."

msgid "Cannot hide both titles and subtitles. At least one must be visible."
msgstr "Non è possibile nascondere sia i titoli che i sottotitoli. Almeno uno deve essere visibile."

msgid "Show subtitles (bottom lines)"
msgstr "Mostra sottotitoli (righe inferiori)"

msgid "Display information below main heading text in each section. At least\none of titles or subtitles must be visible."
msgstr "Mostra le informazioni sotto il testo del titolo principale in ciascuna sezione. Almeno uno tra titoli e sottotitoli deve essere visibile."

msgid "Displayed sections"
msgstr "Sezioni visualizzate"

msgid "Toggle which sections show on the sleep screen. At least one must be\nvisible."
msgstr "Attiva/disattiva le sezioni mostrate sulla schermata di riposo. Almeno una deve essere visibile."

msgid "[ Section Content ]"
msgstr "[ Contenuto sezione ]"

msgid "Configure book-specific details."
msgstr "Configura i dettagli specifici del libro."

msgid "Configure chapter-specific details"
msgstr "Configura i dettagli specifici del capitolo"

msgid "Configure reading goal details"
msgstr "Configura i dettagli dell'obiettivo di lettura"

msgid "Battery section"
msgstr "Sezione batteria"

msgid "Configure battery & time/date details"
msgstr "Configura i dettagli di batteria e ora/data"

msgid "Configure message-specific details"
msgstr "Configura i dettagli specifici del messaggio"

msgid "Customisable sleep screen settings"
msgstr "Impostazioni della schermata di riposo personalizzabile"

msgid "Customisable sleep screen presets"
msgstr "Preset della schermata di riposo personalizzabile"

msgid "Cycle through customisable sleep screen presets"
msgstr "Scorri i preset della schermata di riposo personalizzabile"

msgid "Customisable sleep screen"
msgstr "Schermata di riposo personalizzabile"

msgid "Enable customisable sleep screen"
msgstr "Abilita schermata di riposo personalizzabile"

msgid "Customisable Sleep Screen: no book data found.\n\nOpen a book and trigger the sleep screen at least once before it will\nwork in the file manager."
msgstr "Schermata di riposo personalizzabile: nessun dato del libro trovato.\n\nApri un libro e attiva la schermata di riposo almeno una volta prima che funzioni nel gestore file."
