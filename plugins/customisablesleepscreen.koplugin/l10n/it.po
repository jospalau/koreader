#. ---- All other strings (menu items, help text, headers, buttons) ----
msgid "Pick a colour"
msgstr "Scegli un colore"

msgid "Cancel"
msgstr "Annulla"

msgid "Apply"
msgstr "Applica"

#, lua-format
msgid "Brightness: %d%%"
msgstr "Luminosità: %d%%"

msgid "Enter hex"
msgstr "Inserisci hex"

msgid "Enter hex colour code"
msgstr "Inserisci il codice colore hex"

msgid "Invalid hex code. Use format: #RRGGBB"
msgstr "Codice hex non valido. Usa il formato: #RRGGBB"

msgid "Delete all custom presets"
msgstr "Elimina tutti i preset personalizzati"

msgid "Permanently removes all custom presets you've created. The built-in\n'Default' preset will remain. This cannot be undone."
msgstr "Rimuove definitivamente tutti i preset personalizzati creati. Il preset integrato 'Predefinito' rimarrà. L'operazione non può essere annullata."

msgid "Are you sure you want to delete all custom presets? (built-in presets\nwill remain)"
msgstr "Eliminare tutti i preset personalizzati? (i preset integrati rimarranno)"

msgid "Delete"
msgstr "Elimina"

msgid "All custom presets deleted. Built-in presets remain."
msgstr "Tutti i preset personalizzati eliminati. I preset integrati rimangono."

msgid "Sleep screen orientation"
msgstr "Orientamento della schermata di riposo"

msgid "Force the sleep screen to display in a specific orientation, regardless\nof how the device is held."
msgstr "Forza la schermata di riposo a essere visualizzata in un orientamento specifico, indipendentemente da come viene tenuto il dispositivo."

msgid "Auto (follow device)"
msgstr "Automatico (segui dispositivo)"

msgid "Use whatever orientation the device is currently in."
msgstr "Usa l'orientamento attuale del dispositivo."

msgid "Force portrait"
msgstr "Forza orientamento verticale"

msgid "Always display the sleep screen in portrait mode."
msgstr "Mostra sempre la schermata di riposo in modalità verticale."

msgid "Force landscape"
msgstr "Forza orientamento orizzontale"

msgid "Always display the sleep screen in landscape mode."
msgstr "Mostra sempre la schermata di riposo in modalità orizzontale."

msgid "Force upside-down portrait"
msgstr "Forza orientamento verticale capovolto"

msgid "Always display the sleep screen in inverted portrait mode."
msgstr "Mostra sempre la schermata di riposo in modalità verticale capovolta."

msgid "Force upside-down landscape"
msgstr "Forza orientamento orizzontale capovolto"

msgid "Always display the sleep screen in inverted landscape mode."
msgstr "Mostra sempre la schermata di riposo in modalità orizzontale capovolta."

msgid "Battery time calculation"
msgstr "Calcolo autonomia batteria"

msgid "Method used to estimate remaining battery life."
msgstr "Metodo utilizzato per stimare l'autonomia residua della batteria."

msgid "Since last charge"
msgstr "Dall'ultima carica"

msgid "Uses combined awake and sleeping battery drain since last charge"
msgstr "Usa il consumo combinato in attivo e in standby dall'ultima carica"

msgid "Awake since last charge"
msgstr "Tempo attivo dall'ultima carica"

msgid "Uses only active reading battery drain (more conservative estimate)"
msgstr "Usa solo il consumo durante la lettura attiva (stima più prudente)"

msgid "Sleeping since last charge"
msgstr "Tempo in standby dall'ultima carica"

msgid "Uses only sleep mode battery drain"
msgstr "Usa solo il consumo in modalità standby"

msgid "Manual calculation"
msgstr "Calcolo manuale"

msgid "Use a custom battery drain rate (1-10% per hour)"
msgstr "Usa un tasso di scarica personalizzato (1–10 % all'ora)"

msgid "Set manual drain rate"
msgstr "Imposta tasso di scarica manuale"

msgid "Battery drain rate (% per hour)"
msgstr "Tasso di scarica batteria (% all'ora)"

msgid "Typical devices drain 1-5% per hour while reading."
msgstr "I dispositivi tipici consumano 1–5 % all'ora durante la lettura."

msgid "Daily statistics scope"
msgstr "Ambito delle statistiche giornaliere"

msgid "Controls whether today's reading time and page count applies to the\ncurrent book only, or all books read today. Note: reading streak and\nweekly goal achievement always reflect all books regardless of this\nsetting."
msgstr "Controlla se il tempo di lettura e il conteggio delle pagine di oggi si applicano solo al libro corrente o a tutti i libri letti oggi. Nota: la serie di lettura e il raggiungimento dell'obiettivo settimanale riflettono sempre tutti i libri, indipendentemente da questa impostazione."

msgid "All books"
msgstr "Tutti i libri"

msgid "Today's reading time and page count across all books read today"
msgstr "Tempo di lettura e pagine di oggi per tutti i libri letti oggi"

msgid "Current book only"
msgstr "Solo il libro corrente"

msgid "Today's reading time and page count for the current book only"
msgstr "Tempo di lettura e pagine di oggi solo per il libro corrente"

msgid "Show in file manager (outside of book)"
msgstr "Mostra nel gestore file (fuori da un libro)"

msgid "When enabled, the customisable sleep screen will display in file manager\nusing the last saved book data."
msgstr "Se abilitato, la schermata di riposo personalizzabile viene mostrata nel gestore file con gli ultimi dati del libro salvati."

msgid "Hide built-in presets (except Default)"
msgstr "Nascondi i preset integrati (eccetto Predefinito)"

msgid "Hide the built-in presets from the preset list, keeping only the Default\npreset and your custom presets visible."
msgstr "Nasconde i preset integrati dall'elenco, lasciando visibili solo il preset Predefinito e i tuoi preset personalizzati."

msgid "Setting saved. Preset list will update when you reopen this menu."
msgstr "Impostazione salvata. L'elenco si aggiornerà alla riapertura di questo menu."

msgid "Export sleep screen to file"
msgstr "Esporta schermata di standby in file"

msgid "When enabled, a screenshot of the sleep screen will be saved as
'screensaver.png' in the selected export folder each time a book is
closed."
msgstr "Quando attivato, uno screenshot della schermata di standby verrà salvato come
'screensaver.png' nella cartella di esportazione selezionata ogni volta che un libro viene chiuso."

msgid "Sleep screen export disabled."
msgstr "Esportazione schermata di standby disattivata."

msgid "No export folder set. Please set an export folder first."
msgstr "Nessuna cartella di esportazione impostata. Imposta prima una cartella di esportazione."

#, lua-format
msgid "Sleep screen will be exported to:
%s/screensaver.png"
msgstr "La schermata di standby verrà esportata in:
%s/screensaver.png"

msgid "Set export folder"
msgstr "Imposta cartella di esportazione"

msgid "Choose the folder where screensaver.png will be saved."
msgstr "Scegli la cartella in cui verrà salvato screensaver.png."

#, lua-format
msgid "Export folder set to:
%s"
msgstr "Cartella di esportazione impostata su:
%s"

msgid "Presets"
msgstr "Preset"

msgid "Save, load, and manage presets."
msgstr "Salva, carica e gestisci i preset."

msgid "Display modes"
msgstr "Modalità di visualizzazione"

msgid "Global appearance settings."
msgstr "Impostazioni di aspetto globali."

msgid "Contents"
msgstr "Contenuto"

msgid "Control which sections appear and what information they display."
msgstr "Controlla quali sezioni appaiono e quali informazioni mostrano."

msgid "Layout & Spacing"
msgstr "Layout e spaziatura"

msgid "Adjust the spatial settings of the information box."
msgstr "Regola le impostazioni spaziali del riquadro informazioni."

msgid "Colours, Icons & Bars"
msgstr "Colori, icone e barre"

msgid "Customise section colours, icon appearance, and progress bar styling."
msgstr "Personalizza i colori delle sezioni, l'aspetto delle icone e lo stile delle barre."

msgid "Fonts & Text"
msgstr "Caratteri e testo"

msgid "Configure text appearance."
msgstr "Configura l'aspetto del testo."

msgid "Background"
msgstr "Sfondo"

msgid "Choose what appears behind the information box."
msgstr "Scegli cosa appare dietro il riquadro informazioni."

msgid "Advanced"
msgstr "Avanzate"

msgid "Advanced configuration options."
msgstr "Opzioni di configurazione avanzate."

msgid "About"
msgstr "Informazioni"

#, lua-format
msgid "%s\nVersion: %s\n\nFor updates and issues:\ngithub.com/%s"
msgstr "%s\nVersione: %s\n\nPer aggiornamenti e segnalazioni:\ngithub.com/%s"

msgid "Top left"
msgstr "In alto a sinistra"

msgid "Top centre"
msgstr "In alto al centro"

msgid "Top right"
msgstr "In alto a destra"

msgid "Middle left"
msgstr "A sinistra al centro"

msgid "Centre"
msgstr "Centro"

msgid "Middle right"
msgstr "A destra al centro"

msgid "Bottom left"
msgstr "In basso a sinistra"

msgid "Bottom centre"
msgstr "In basso al centro"

msgid "Bottom right"
msgstr "In basso a destra"

msgid "Dark mode"
msgstr "Modalità scura"

msgid "Inverts the colour scheme. Text becomes white and backgrounds becomes\nblack. Useful for reading in low-light conditions. Can be combined with\nmonochrome mode."
msgstr "Inverte la combinazione di colori. Il testo diventa bianco e gli sfondi diventano neri. Utile per leggere in condizioni di scarsa illuminazione. Può essere combinata con la modalità monocromatica."

msgid "Monochrome mode"
msgstr "Modalità monocromatica"

msgid "Suitable for B&W e-readers. Assigns one colour to all sections using\nmonochrome light or monochrome dark hex values. Overwrites individual\nassigned section colours. Can be combined with dark mode."
msgstr "Adatta per e-reader in B&N. Assegna un colore a tutte le sezioni usando valori esadecimali monocromatici chiari o scuri. Sovrascrive i colori individuali delle sezioni. Può essere combinata con la modalità scura."

msgid "Section gaps"
msgstr "Spazi tra sezioni"

msgid "Add transparent gaps between sections to make each appear as a separate\nbox"
msgstr "Aggiunge spazi trasparenti tra le sezioni per far apparire ciascuna come un riquadro separato"

msgid "Enable section gaps"
msgstr "Abilita spazi tra sezioni"

msgid "Section gap size"
msgstr "Dimensione spazio tra sezioni"

msgid "Spacing between sections when gaps are enabled."
msgstr "Spaziatura tra le sezioni quando gli spazi sono abilitati."

msgid "Section gap size (pixels)"
msgstr "Dimensione spazio tra sezioni (pixel)"

msgid "10–20px gives a subtle separation. 30–50px makes sections feel like\ndistinct cards."
msgstr "10–20 px dà una separazione sottile. 30–50 px fa sembrare ogni sezione una scheda distinta."

msgid "Position"
msgstr "Posizione"

msgid "Screen location where the information box appears."
msgstr "Posizione sullo schermo dove appare il riquadro informazioni."

msgid "Position offset"
msgstr "Offset di posizione"

msgid "Nudge the box from its anchor position. Useful for pushing rounded
corners off-screen."
msgstr "Sposta il riquadro dalla sua posizione di ancoraggio. Utile per spingere gli angoli
arrotondati fuori dallo schermo."

msgid "Horizontal offset (px)"
msgstr "Offset orizzontale (px)"

msgid "Nudges the box left (-) or right (+) from its anchor. Useful for pushing
rounded corners off-screen."
msgstr "Sposta il riquadro a sinistra (-) o destra (+) dall'ancoraggio. Utile per spingere
gli angoli arrotondati fuori dallo schermo."

msgid "Vertical offset (px)"
msgstr "Offset verticale (px)"

msgid "Nudges the box up (+) or down (-) from its anchor. Useful for pushing
rounded corners off-screen."
msgstr "Sposta il riquadro verso l'alto (+) o in basso (-) dall'ancoraggio. Utile per spingere
gli angoli arrotondati fuori dallo schermo."

msgid "Width"
msgstr "Larghezza"

msgid "Horizontal width of the information box as a percentage of screen width."
msgstr "Larghezza orizzontale del riquadro informazioni come percentuale della larghezza dello schermo."

msgid "Box width (%)"
msgstr "Larghezza riquadro (%)"

msgid "60–70% suits portrait screens."
msgstr "60–70% è adatto agli schermi in verticale."

msgid "Opacity"
msgstr "Opacità"

msgid "Transparency of the information box."
msgstr "Trasparenza del riquadro informazioni."

msgid "Opacity (%)"
msgstr "Opacità (%)"

msgid "75% is semi-transparent. 100% is fully opaque."
msgstr "75% è semitrasparente. 100% è completamente opaco."

msgid "Border size"
msgstr "Dimensione bordo"

msgid "Thickness of the primary border around sections."
msgstr "Spessore del bordo principale attorno alle sezioni."

msgid "Border size (px)"
msgstr "Dimensione bordo (px)"

msgid "0 for no border. 1–2px is subtle, 4–6px is bold and visible."
msgstr "0 per nessun bordo. 1–2px è sottile, 4–6px è deciso e visibile."

msgid "Border trim size"
msgstr "Dimensione bordo decorativo"

msgid "Secondary decorative border surrounding the primary border."
msgstr "Bordo decorativo secondario che circonda il bordo principale."

msgid "Border trim size (px)"
msgstr "Dimensione bordo decorativo (px)"

msgid "0 for no trim. 1–2px is subtle, 4–6px is a bold decorative outline
around the primary border."
msgstr "0 per nessun bordo decorativo. 1–2px è sottile, 4–6px è un contorno decorativo deciso
intorno al bordo principale."

msgid "Corner radius"
msgstr "Raggio degli angoli"

msgid "Round the corners of the info box. Also moves progress bars inline with
the text when active."
msgstr "Arrotonda gli angoli del riquadro informazioni. Sposta anche le barre di avanzamento
in linea con il testo quando attivo."

msgid "Corner radius (px)"
msgstr "Raggio degli angoli (px)"

msgid "0 for square corners. 15–30px for softly rounded. 150px+ for a
pill-shaped box (depending on the section box height)."
msgstr "0 per angoli quadrati. 15–30px per angoli morbidamente arrotondati. 150px+ per un
riquadro a forma di pillola (in base all'altezza del riquadro di sezione)."

msgid "Internal padding"
msgstr "Spaziatura interna"

msgid "Space between section borders and their content, configurable per side."
msgstr "Spazio tra i bordi della sezione e il loro contenuto, configurabile per lato."

msgid "Top"
msgstr "Alto"

msgid "Internal padding — top (px)"
msgstr "Spaziatura interna — alto (px)"

msgid "Space above section content."
msgstr "Spazio sopra il contenuto della sezione."

msgid "Bottom"
msgstr "Basso"

msgid "Internal padding — bottom (px)"
msgstr "Spaziatura interna — basso (px)"

msgid "Space below section content."
msgstr "Spazio sotto il contenuto della sezione."

msgid "Left"
msgstr "Sinistra"

msgid "Internal padding — left (px)"
msgstr "Spaziatura interna — sinistra (px)"

msgid "Space to the left of section content. Increase when using large corner
radii."
msgstr "Spazio a sinistra del contenuto della sezione. Aumentare con raggi degli angoli grandi."

msgid "Right"
msgstr "Destra"

msgid "Internal padding — right (px)"
msgstr "Spaziatura interna — destra (px)"

msgid "Space to the right of section content. Increase when using large corner
radii."
msgstr "Spazio a destra del contenuto della sezione. Aumentare con raggi degli angoli grandi."

msgid "Set all sides equally"
msgstr "Imposta tutti i lati ugualmente"

msgid "Internal padding — all sides (px)"
msgstr "Spaziatura interna — tutti i lati (px)"

msgid "Sets top, bottom, left and right padding to the same value in one step."
msgstr "Imposta la spaziatura superiore, inferiore, sinistra e destra allo stesso valore in un solo passaggio."

msgid "Icon to text gap"
msgstr "Spazio icona-testo"

msgid "Horizontal spacing between section icons and their accompanying text."
msgstr "Spaziatura orizzontale tra le icone delle sezioni e il testo associato."

msgid "Icon to text gap (px)"
msgstr "Distanza icona-testo (px)"

msgid "8–12px gives comfortable breathing room between icon and text. 0 is
flush."
msgstr "8–12px dà un comodo spazio tra icona e testo. 0 è
a filo."

msgid "No icon sets found in customisablesleepscreen.koplugin/icons/"
msgstr "Nessun set di icone trovato in customisablesleepscreen.koplugin/icons/"

msgid "Colours (progress bars)"
msgstr "Colori (barre di avanzamento)"

msgid "Set the progress bar colours for each section."
msgstr "Imposta i colori della barra di avanzamento per ogni sezione."

msgid "Use saved colours for icon fill"
msgstr "Usa colori salvati per il riempimento delle icone"

msgid "When enabled, icons will match the colour of their section's progress\nbar."
msgstr "Se abilitato, le icone corrisponderanno al colore della barra di avanzamento della rispettiva sezione."

msgid "Book section"
msgstr "Sezione libro"

msgid "Chapter section"
msgstr "Sezione capitolo"

msgid "Daily goal section"
msgstr "Sezione obiettivo giornaliero"

msgid "Battery section (High)"
msgstr "Sezione batteria (Alta)"

msgid "Battery section (Med)"
msgstr "Sezione batteria (Media)"

msgid "Battery section (Low)"
msgstr "Sezione batteria (Bassa)"

msgid "Battery section (Charging)"
msgstr "Sezione batteria (In carica)"

msgid "Message section"
msgstr "Sezione messaggio"

msgid "Colours (modes)"
msgstr "Colori (modalità)"

msgid "Configure colours for monochrome mode, infobox background, and text.\nLight and dark correspond to the current dark mode setting. Monochrome\nreplaces all colours with that single chosen color."
msgstr "Configura i colori per la modalità monocromatica, lo sfondo della casella informazioni e il testo. Chiaro e scuro corrispondono all'impostazione corrente della modalità scura. Monocromatico sostituisce tutti i colori con quell'unico colore scelto."

msgid "Monochrome mode (light)"
msgstr "Modalità monocromatica (chiara)"

msgid "Monochrome mode (dark)"
msgstr "Modalità monocromatica (scura)"

msgid "Background (light)"
msgstr "Sfondo (chiaro)"

msgid "Background (dark)"
msgstr "Sfondo (scuro)"

msgid "Text (light)"
msgstr "Testo (chiaro)"

msgid "Text (dark)"
msgstr "Testo (scuro)"

msgid "Icon set"
msgstr "Set di icone"

msgid "Choose from different icon styles."
msgstr "Scegli tra diversi stili di icone."

msgid "Icon size"
msgstr "Dimensione icone"

msgid "Size of section icons."
msgstr "Dimensione delle icone delle sezioni."

msgid "Icon size (px)"
msgstr "Dimensione icona (px)"

msgid "32–48px suits most layouts."
msgstr "32–48px è adatto alla maggior parte dei layout."

msgid "Progress bar height"
msgstr "Altezza barra di avanzamento"

msgid "Thickness of the horizontal progress bars shown in each section."
msgstr "Spessore delle barre di avanzamento orizzontali mostrate in ciascuna sezione."

msgid "Bar height (px)"
msgstr "Altezza barra (px)"

msgid "4–8px is subtle. 12–16px is standard. 20+px is heavy."
msgstr "4–8px è sottile. 12–16px è standard. 20+px è spesso."

msgid "Show icons"
msgstr "Mostra icone"

msgid "Display decorative icons at the start of each section."
msgstr "Mostra icone decorative all'inizio di ciascuna sezione."

msgid "Show progress bars"
msgstr "Mostra barre di avanzamento"

msgid "Display horizontal progress bars showing completion percentage."
msgstr "Mostra barre di avanzamento orizzontali con la percentuale di completamento."

msgid "Show decorative bar on message section"
msgstr "Mostra barra decorativa nella sezione messaggi"

msgid "Displays a purely decorative progress bar under the message section,\nmatching the message section colour and the progress bars in other\nsections."
msgstr "Mostra una barra di avanzamento puramente decorativa sotto la sezione messaggi, con il colore della sezione messaggi e delle barre di avanzamento delle altre sezioni."

msgid "Inline progress bars"
msgstr "Barre di avanzamento in linea"

msgid "Progress bars sit inside the text area rather than spanning the full
section width. Automatically enabled when corner radius > 0."
msgstr "Le barre di avanzamento si trovano nell'area di testo anziché coprire l'intera
larghezza della sezione. Attivato automaticamente quando il raggio degli angoli > 0."

msgid "Enable inline bars"
msgstr "Attiva barre in linea"

msgid "When section gaps are enabled and corner radius > 0, inline bars are automatically enabled."
msgstr "Quando i gap di sezione sono abilitati e il raggio degli angoli > 0, le barre in linea vengono abilitate automaticamente."

msgid "Inline bars are force-enabled because section gaps and corner radius are both set. Set corner radius to 0 or disable section gaps to toggle inline bars independently."
msgstr "Le barre in linea sono forzate perché i gap di sezione e il raggio degli angoli sono impostati. Impostare il raggio a 0 o disabilitare i gap di sezione per attivarle indipendentemente."

msgid "Inline bar border size"
msgstr "Dimensione bordo barra in linea"

msgid "Thickness of the border around the inline progress bar."
msgstr "Spessore del bordo intorno alla barra di avanzamento in linea."

msgid "Inline bar border size (px)"
msgstr "Dimensione bordo barra in linea (px)"

msgid "0 for no border. 1–2px adds a subtle outline around the bar."
msgstr "0 per nessun bordo. 1–2px aggiunge un contorno sottile intorno alla barra."

msgid "Bar width"
msgstr "Larghezza barra"

msgid "Width of the inline progress bar as a percentage of the available text
column. Alignment follows the text alignment setting."
msgstr "Larghezza della barra di avanzamento in linea come percentuale della colonna di testo disponibile.
L'allineamento segue l'impostazione di allineamento testo."

msgid "Inline bar width (%)"
msgstr "Larghezza barra in linea (%)"

msgid "100% fills the text column. The bar is aligned to match your text
alignment setting."
msgstr "100% riempie la colonna di testo. La barra è allineata secondo l'impostazione
di allineamento testo."

msgid "Title font face"
msgstr "Carattere del titolo"

msgid "Choose the font face for the main heading text in each section"
msgstr "Scegli il carattere per il testo del titolo principale in ciascuna sezione"

msgid "Title font size"
msgstr "Dimensione carattere titolo"

msgid "Choose the font size for the main heading text in each section."
msgstr "Scegli la dimensione del carattere per il testo del titolo principale in ciascuna sezione."

msgid "10–12px works well for most screens."
msgstr "10–12px funziona bene per la maggior parte degli schermi."

msgid "Subtitle font face"
msgstr "Carattere del sottotitolo"

msgid "Choose the font face for the information below the main heading text."
msgstr "Scegli il carattere per le informazioni sotto il testo del titolo principale."

msgid "Subtitle font size"
msgstr "Dimensione carattere sottotitolo"

msgid "Choose the font size for the information below the main heading text."
msgstr "Scegli la dimensione del carattere per le informazioni sotto il testo del titolo principale."

msgid "9–11px works well for most screens."
msgstr "9–11px funziona bene per la maggior parte degli schermi."

msgid "Text alignment"
msgstr "Allineamento testo"

msgid "Horizontal alignment of all text within sections."
msgstr "Allineamento orizzontale di tutto il testo nelle sezioni."

msgid "Book multiline titles"
msgstr "Titoli libro su più righe"

msgid "If deselected book titles will be truncated to a single line with an\nellipsis"
msgstr "Se deselezionato, i titoli del libro verranno troncati a una sola riga con i puntini di sospensione"

msgid "Chapter multiline titles"
msgstr "Titoli capitolo su più righe"

msgid "If deselected chapter titles will be truncated to a single line with an\nellipsis"
msgstr "Se deselezionato, i titoli del capitolo verranno troncati a una sola riga con i puntini di sospensione"

msgid "Clean chapter titles"
msgstr "Pulisci titoli capitolo"

msgid "Removes structural prefixes like 'Chapter 5:' or 'Part II' from chapter\ntitles and normalises capitalisation. Only works correctly with English\nchapter titles - disable for non-English books."
msgstr "Rimuove i prefissi strutturali come 'Capitolo 5:' o 'Parte II' dai titoli dei capitoli e normalizza l'uso delle maiuscole. Funziona correttamente solo con titoli in inglese — disabilitare per libri in altre lingue."

msgid "Make titles bold"
msgstr "Rendi i titoli in grassetto"

msgid "Display the section titles in bold font weight for extra emphasis."
msgstr "Visualizza i titoli di sezione in grassetto per maggiore enfasi."

msgid "No background"
msgstr "Nessuno sfondo"

msgid "Book cover"
msgstr "Copertina del libro"

msgid "Solid colour"
msgstr "Colore pieno"

msgid "Random image from folder"
msgstr "Immagine casuale da cartella"

msgid "Stretch book cover to fill"
msgstr "Estendi copertina per riempire"

msgid "When disabled, book cover will be scaled to fit within the screen while\npreserving aspect ratio."
msgstr "Se disabilitato, la copertina verrà ridimensionata per adattarsi allo schermo mantenendo le proporzioni."

msgid "Cover fill colour"
msgstr "Colore di riempimento copertina"

msgid "Background colour for non-stretched covers."
msgstr "Colore di sfondo per le copertine non estese."

msgid "Pick cover fill colour"
msgstr "Scegli colore di riempimento copertina"

msgid "Cover alignment"
msgstr "Allineamento copertina"

msgid "Horizontal alignment of the cover image when not stretched."
msgstr "Allineamento orizzontale dell'immagine di copertina quando non è estesa."

msgid "Solid background colour"
msgstr "Colore di sfondo pieno"

msgid "Pick background colour"
msgstr "Scegli colore di sfondo"

msgid "Background folder path"
msgstr "Percorso cartella sfondo"

msgid "No images found in the selected folder. No background will be shown."
msgstr "Nessuna immagine trovata nella cartella selezionata. Non verrà mostrato alcuno sfondo."

msgid "Background type"
msgstr "Tipo di sfondo"

msgid "Background overlay"
msgstr "Sovrapposizione sfondo"

msgid "Add a colour layer over the background to reduce contrast."
msgstr "Aggiunge un livello di colore sullo sfondo per ridurre il contrasto."

msgid "Overlay colour"
msgstr "Colore sovrapposizione"

msgid "Background overlay colour"
msgstr "Colore sovrapposizione sfondo"

msgid "Overlay opacity"
msgstr "Opacità del livello"

msgid "Overlay opacity (%)"
msgstr "Opacità del livello (%)"

msgid "0% is no overlay. 20–40% adds a soft tint. 100% is fully opaque."
msgstr "0% è senza livello. 20–40% aggiunge una tinta morbida. 100% è completamente opaco."

msgid "Reset layout & spacing settings to default"
msgstr "Ripristina impostazioni layout e spaziatura"

msgid "Are you sure you want to reset layout & spacing settings?"
msgstr "Ripristinare le impostazioni di layout e spaziatura?"

msgid "Layout & spacing settings reset to defaults"
msgstr "Impostazioni layout e spaziatura ripristinate"

msgid "Reset contents settings to default"
msgstr "Ripristina impostazioni contenuto"

msgid "Are you sure you want to reset contents settings?"
msgstr "Ripristinare le impostazioni del contenuto?"

msgid "Contents settings reset to defaults"
msgstr "Impostazioni contenuto ripristinate"

msgid "Reset colours, icons & bars settings to default"
msgstr "Ripristina impostazioni colori, icone e barre"

msgid "Are you sure you want to reset colours, icons & bars settings?"
msgstr "Ripristinare le impostazioni di colori, icone e barre?"

msgid "Colours, icons & bars settings reset to defaults"
msgstr "Impostazioni colori, icone e barre ripristinate"

msgid "Reset fonts & text settings to default"
msgstr "Ripristina impostazioni caratteri e testo"

msgid "Are you sure you want to reset fonts & text settings?"
msgstr "Ripristinare le impostazioni di caratteri e testo?"

msgid "Fonts & text settings reset to defaults"
msgstr "Impostazioni caratteri e testo ripristinate"

msgid "Reset background settings to default"
msgstr "Ripristina impostazioni sfondo"

msgid "Are you sure you want to reset background settings?"
msgstr "Ripristinare le impostazioni dello sfondo?"

msgid "Background settings reset to defaults"
msgstr "Impostazioni sfondo ripristinate"

msgid "Reset the settings in this part of the menu to their defaults."
msgstr "Ripristina le impostazioni di questa parte del menu ai valori predefiniti."

msgid "factory defaults"
msgstr "impostazioni predefinite di fabbrica"

#, lua-format
msgid "Values will be restored from: %s"
msgstr "I valori verranno ripristinati da: %s"

