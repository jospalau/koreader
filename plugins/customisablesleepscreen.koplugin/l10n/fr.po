#. ---- All other strings (menu items, help text, headers, buttons) ----
msgid "Pick a colour"
msgstr "Choisir une couleur"

msgid "Cancel"
msgstr "Annuler"

msgid "Apply"
msgstr "Appliquer"

#, lua-format
msgid "Brightness: %d%%"
msgstr "Luminosité : %d%%"

msgid "Enter hex"
msgstr "Saisir hex"

msgid "Enter hex colour code"
msgstr "Saisir le code couleur hex"

msgid "Invalid hex code. Use format: #RRGGBB"
msgstr "Code hex invalide. Utiliser le format : #RRGGBB"

msgid "Delete all custom presets"
msgstr "Supprimer tous les préréglages personnalisés"

msgid "Permanently removes all custom presets you've created. The built-in\n'Default' preset will remain. This cannot be undone."
msgstr "Supprime définitivement tous les préréglages personnalisés créés. Le préréglage intégré 'Par défaut' sera conservé. Cette action est irréversible."

msgid "Are you sure you want to delete all custom presets? (built-in presets\nwill remain)"
msgstr "Supprimer tous les préréglages personnalisés ? (les préréglages intégrés seront conservés)"

msgid "Delete"
msgstr "Supprimer"

msgid "All custom presets deleted. Built-in presets remain."
msgstr "Tous les préréglages personnalisés supprimés. Les préréglages intégrés sont conservés."

msgid "Sleep screen orientation"
msgstr "Orientation de l'écran de veille"

msgid "Force the sleep screen to display in a specific orientation, regardless\nof how the device is held."
msgstr "Forcer l'écran de veille à s'afficher dans une orientation spécifique, quelle que soit la position de l'appareil."

msgid "Auto (follow device)"
msgstr "Automatique (suivre l'appareil)"

msgid "Use whatever orientation the device is currently in."
msgstr "Utiliser l'orientation actuelle de l'appareil."

msgid "Force portrait"
msgstr "Forcer le mode portrait"

msgid "Always display the sleep screen in portrait mode."
msgstr "Toujours afficher l'écran de veille en mode portrait."

msgid "Force landscape"
msgstr "Forcer le mode paysage"

msgid "Always display the sleep screen in landscape mode."
msgstr "Toujours afficher l'écran de veille en mode paysage."

msgid "Force upside-down portrait"
msgstr "Forcer le mode portrait inversé"

msgid "Always display the sleep screen in inverted portrait mode."
msgstr "Toujours afficher l'écran de veille en mode portrait inversé."

msgid "Force upside-down landscape"
msgstr "Forcer le mode paysage inversé"

msgid "Always display the sleep screen in inverted landscape mode."
msgstr "Toujours afficher l'écran de veille en mode paysage inversé."

msgid "Battery time calculation"
msgstr "Calcul de l'autonomie"

msgid "Method used to estimate remaining battery life."
msgstr "Méthode utilisée pour estimer l'autonomie restante."

msgid "Since last charge"
msgstr "Depuis la dernière charge"

msgid "Uses combined awake and sleeping battery drain since last charge"
msgstr "Utilise la consommation combinée en veille et en activité depuis la dernière charge"

msgid "Awake since last charge"
msgstr "Temps actif depuis la dernière charge"

msgid "Uses only active reading battery drain (more conservative estimate)"
msgstr "Utilise uniquement la consommation en lecture active (estimation plus prudente)"

msgid "Sleeping since last charge"
msgstr "Temps en veille depuis la dernière charge"

msgid "Uses only sleep mode battery drain"
msgstr "Utilise uniquement la consommation en mode veille"

msgid "Manual calculation"
msgstr "Calcul manuel"

msgid "Use a custom battery drain rate (1-10% per hour)"
msgstr "Utiliser un taux de décharge personnalisé (1–10 % par heure)"

msgid "Set manual drain rate"
msgstr "Définir le taux de décharge manuel"

msgid "Battery drain rate (% per hour)"
msgstr "Taux de décharge (% par heure)"

msgid "Typical devices drain 1-5% per hour while reading."
msgstr "Les appareils typiques consomment 1–5 % par heure en lecture."

msgid "Daily statistics scope"
msgstr "Portée des statistiques quotidiennes"

msgid "Controls whether today's reading time and page count applies to the\ncurrent book only, or all books read today. Note: reading streak and\nweekly goal achievement always reflect all books regardless of this\nsetting."
msgstr "Détermine si le temps de lecture et le nombre de pages d'aujourd'hui s'appliquent uniquement au livre actuel ou à tous les livres lus aujourd'hui. Remarque : la série de lecture et l'atteinte de l'objectif hebdomadaire reflètent toujours tous les livres, indépendamment de ce paramètre."

msgid "All books"
msgstr "Tous les livres"

msgid "Today's reading time and page count across all books read today"
msgstr "Temps de lecture et nombre de pages du jour pour tous les livres lus aujourd'hui"

msgid "Current book only"
msgstr "Livre actuel uniquement"

msgid "Today's reading time and page count for the current book only"
msgstr "Temps de lecture et nombre de pages du jour uniquement pour le livre actuel"

msgid "Show in file manager (outside of book)"
msgstr "Afficher dans le gestionnaire de fichiers (hors livre)"

msgid "When enabled, the customisable sleep screen will display in file manager\nusing the last saved book data."
msgstr "Quand activé, l'écran de veille personnalisable s'affiche dans le gestionnaire de fichiers avec les dernières données de livre enregistrées."

msgid "Hide built-in presets (except Default)"
msgstr "Masquer les préréglages intégrés (sauf Par défaut)"

msgid "Hide the built-in presets from the preset list, keeping only the Default\npreset and your custom presets visible."
msgstr "Masque les préréglages intégrés dans la liste, ne laissant visibles que le préréglage Par défaut et vos préréglages personnalisés."

msgid "Setting saved. Preset list will update when you reopen this menu."
msgstr "Paramètre enregistré. La liste se mettra à jour à la réouverture de ce menu."

msgid "Export sleep screen to file"
msgstr "Exporter l'écran de veille vers un fichier"

msgid "When enabled, a screenshot of the sleep screen will be saved as
'screensaver.png' in the selected export folder each time a book is
closed."
msgstr "Lorsqu'activé, une capture de l'écran de veille sera enregistrée sous
'screensaver.png' dans le dossier d'exportation sélectionné à chaque fermeture d'un livre."

msgid "Sleep screen export disabled."
msgstr "Exportation de l'écran de veille désactivée."

msgid "No export folder set. Please set an export folder first."
msgstr "Aucun dossier d'exportation défini. Veuillez d'abord définir un dossier d'exportation."

#, lua-format
msgid "Sleep screen will be exported to:
%s/screensaver.png"
msgstr "L'écran de veille sera exporté vers :
%s/screensaver.png"

msgid "Set export folder"
msgstr "Définir le dossier d'exportation"

msgid "Choose the folder where screensaver.png will be saved."
msgstr "Choisissez le dossier où screensaver.png sera enregistré."

#, lua-format
msgid "Export folder set to:
%s"
msgstr "Dossier d'exportation défini sur :
%s"

msgid "Presets"
msgstr "Préréglages"

msgid "Save, load, and manage presets."
msgstr "Enregistrer, charger et gérer les préréglages."

msgid "Display modes"
msgstr "Modes d'affichage"

msgid "Global appearance settings."
msgstr "Paramètres d'apparence globaux."

msgid "Contents"
msgstr "Contenu"

msgid "Control which sections appear and what information they display."
msgstr "Contrôler quelles sections apparaissent et quelles informations elles affichent."

msgid "Layout & Spacing"
msgstr "Mise en page & espacement"

msgid "Adjust the spatial settings of the information box."
msgstr "Ajuster les paramètres spatiaux de la boîte d'informations."

msgid "Colours, Icons & Bars"
msgstr "Couleurs, icônes & barres"

msgid "Customise section colours, icon appearance, and progress bar styling."
msgstr "Personnaliser les couleurs des sections, l'apparence des icônes et le style des barres."

msgid "Fonts & Text"
msgstr "Polices & texte"

msgid "Configure text appearance."
msgstr "Configurer l'apparence du texte."

msgid "Background"
msgstr "Arrière-plan"

msgid "Choose what appears behind the information box."
msgstr "Choisir ce qui apparaît derrière la boîte d'informations."

msgid "Advanced"
msgstr "Avancé"

msgid "Advanced configuration options."
msgstr "Options de configuration avancées."

msgid "About"
msgstr "À propos"

#, lua-format
msgid "%s\nVersion: %s\n\nFor updates and issues:\ngithub.com/%s"
msgstr "%s\nVersion : %s\n\nPour les mises à jour et signalements :\ngithub.com/%s"

msgid "Top left"
msgstr "En haut à gauche"

msgid "Top centre"
msgstr "En haut au centre"

msgid "Top right"
msgstr "En haut à droite"

msgid "Middle left"
msgstr "Milieu gauche"

msgid "Centre"
msgstr "Centre"

msgid "Middle right"
msgstr "Milieu droit"

msgid "Bottom left"
msgstr "En bas à gauche"

msgid "Bottom centre"
msgstr "En bas au centre"

msgid "Bottom right"
msgstr "En bas à droite"

msgid "Dark mode"
msgstr "Mode sombre"

msgid "Inverts the colour scheme. Text becomes white and backgrounds becomes\nblack. Useful for reading in low-light conditions. Can be combined with\nmonochrome mode."
msgstr "Inverse le schéma de couleurs. Le texte devient blanc et les fonds deviennent noirs. Utile pour lire dans des conditions de faible éclairage. Peut être combiné avec le mode monochrome."

msgid "Monochrome mode"
msgstr "Mode monochrome"

msgid "Suitable for B&W e-readers. Assigns one colour to all sections using\nmonochrome light or monochrome dark hex values. Overwrites individual\nassigned section colours. Can be combined with dark mode."
msgstr "Adapté aux liseuses N&B. Attribue une couleur à toutes les sections en utilisant des valeurs hexadécimales monochrome clair ou monochrome foncé. Écrase les couleurs de section individuellement attribuées. Peut être combiné avec le mode sombre."

msgid "Section gaps"
msgstr "Espacement des sections"

msgid "Add transparent gaps between sections to make each appear as a separate\nbox"
msgstr "Ajouter des espacements transparents entre les sections pour que chacune apparaisse comme une boîte séparée"

msgid "Enable section gaps"
msgstr "Activer les espacements entre sections"

msgid "Section gap size"
msgstr "Taille de l'espacement entre sections"

msgid "Spacing between sections when gaps are enabled."
msgstr "Espacement entre les sections lorsque les espacements sont activés."

msgid "Section gap size (pixels)"
msgstr "Taille de l'espacement entre sections (pixels)"

msgid "10–20px gives a subtle separation. 30–50px makes sections feel like\ndistinct cards."
msgstr "10–20 px donne une séparation subtile. 30–50 px donne à chaque section l'aspect d'une carte distincte."

msgid "Position"
msgstr "Position"

msgid "Screen location where the information box appears."
msgstr "Emplacement à l'écran où apparaît la boîte d'informations."

msgid "Position offset"
msgstr "Décalage de position"

msgid "Nudge the box from its anchor position. Useful for pushing rounded
corners off-screen."
msgstr "Déplacer légèrement le cadre depuis sa position d'ancrage. Utile pour pousser les coins
arrondis hors de l'écran."

msgid "Horizontal offset (px)"
msgstr "Décalage horizontal (px)"

msgid "Nudges the box left (-) or right (+) from its anchor. Useful for pushing
rounded corners off-screen."
msgstr "Déplace le cadre vers la gauche (-) ou la droite (+) depuis son ancrage. Utile pour pousser
les coins arrondis hors de l'écran."

msgid "Vertical offset (px)"
msgstr "Décalage vertical (px)"

msgid "Nudges the box up (+) or down (-) from its anchor. Useful for pushing
rounded corners off-screen."
msgstr "Déplace le cadre vers le haut (+) ou le bas (-) depuis son ancrage. Utile pour pousser
les coins arrondis hors de l'écran."

msgid "Width"
msgstr "Largeur"

msgid "Horizontal width of the information box as a percentage of screen width."
msgstr "Largeur horizontale de la boîte d'informations en pourcentage de la largeur d'écran."

msgid "Box width (%)"
msgstr "Largeur du cadre (%)"

msgid "60–70% suits portrait screens."
msgstr "60–70 % convient aux écrans en mode portrait."

msgid "Opacity"
msgstr "Opacité"

msgid "Transparency of the information box."
msgstr "Transparence de la boîte d'informations."

msgid "Opacity (%)"
msgstr "Opacité (%)"

msgid "75% is semi-transparent. 100% is fully opaque."
msgstr "75 % est semi-transparent. 100 % est entièrement opaque."

msgid "Border size"
msgstr "Taille de la bordure"

msgid "Thickness of the primary border around sections."
msgstr "Épaisseur de la bordure principale autour des sections."

msgid "Border size (px)"
msgstr "Taille de la bordure (px)"

msgid "0 for no border. 1–2px is subtle, 4–6px is bold and visible."
msgstr "0 pour aucune bordure. 1–2 px est subtil, 4–6 px est gras et visible."

msgid "Border trim size"
msgstr "Taille de la bordure décorative"

msgid "Secondary decorative border surrounding the primary border."
msgstr "Bordure décorative secondaire entourant la bordure principale."

msgid "Border trim size (px)"
msgstr "Taille du liseré de bordure (px)"

msgid "0 for no trim. 1–2px is subtle, 4–6px is a bold decorative outline
around the primary border."
msgstr "0 pour aucun liseré. 1–2 px est subtil, 4–6 px est un contour décoratif gras
autour de la bordure principale."

msgid "Corner radius"
msgstr "Rayon des coins"

msgid "Round the corners of the info box. Also moves progress bars inline with
the text when active."
msgstr "Arrondir les coins du cadre d'information. Déplace également les barres de progression
en ligne avec le texte lorsqu'actif."

msgid "Corner radius (px)"
msgstr "Rayon des coins (px)"

msgid "0 for square corners. 15–30px for softly rounded. 150px+ for a
pill-shaped box (depending on the section box height)."
msgstr "0 pour des coins carrés. 15–30 px pour un arrondi doux. 150 px+ pour un
cadre en forme de pilule (selon la hauteur du cadre de section)."

msgid "Internal padding"
msgstr "Marge intérieure"

msgid "Space between section borders and their content, configurable per side."
msgstr "Espace entre les bordures de section et leur contenu, configurable par côté."

msgid "Top"
msgstr "Haut"

msgid "Internal padding — top (px)"
msgstr "Rembourrage interne — haut (px)"

msgid "Space above section content."
msgstr "Espace au-dessus du contenu de la section."

msgid "Bottom"
msgstr "Bas"

msgid "Internal padding — bottom (px)"
msgstr "Rembourrage interne — bas (px)"

msgid "Space below section content."
msgstr "Espace en dessous du contenu de la section."

msgid "Left"
msgstr "Gauche"

msgid "Internal padding — left (px)"
msgstr "Rembourrage interne — gauche (px)"

msgid "Space to the left of section content. Increase when using large corner
radii."
msgstr "Espace à gauche du contenu de la section. Augmenter avec de grands rayons de coins."

msgid "Right"
msgstr "Droite"

msgid "Internal padding — right (px)"
msgstr "Rembourrage interne — droite (px)"

msgid "Space to the right of section content. Increase when using large corner
radii."
msgstr "Espace à droite du contenu de la section. Augmenter avec de grands rayons de coins."

msgid "Set all sides equally"
msgstr "Définir tous les côtés de manière égale"

msgid "Internal padding — all sides (px)"
msgstr "Rembourrage interne — tous les côtés (px)"

msgid "Sets top, bottom, left and right padding to the same value in one step."
msgstr "Définit le rembourrage haut, bas, gauche et droite à la même valeur en une étape."

msgid "Icon to text gap"
msgstr "Espacement icône-texte"

msgid "Horizontal spacing between section icons and their accompanying text."
msgstr "Espacement horizontal entre les icônes de section et le texte associé."

msgid "Icon to text gap (px)"
msgstr "Écart icône-texte (px)"

msgid "8–12px gives comfortable breathing room between icon and text. 0 is
flush."
msgstr "8–12 px donne un espace confortable entre l'icône et le texte. 0 est
en ras."

msgid "No icon sets found in customisablesleepscreen.koplugin/icons/"
msgstr "Aucun jeu d'icônes trouvé dans customisablesleepscreen.koplugin/icons/"

msgid "Colours (progress bars)"
msgstr "Couleurs (barres de progression)"

msgid "Set the progress bar colours for each section."
msgstr "Définit les couleurs des barres de progression pour chaque section."

msgid "Use saved colours for icon fill"
msgstr "Utiliser les couleurs enregistrées pour le remplissage des icônes"

msgid "When enabled, icons will match the colour of their section's progress\nbar."
msgstr "Quand activé, les icônes correspondront à la couleur de la barre de progression de leur section."

msgid "Book section"
msgstr "Section livre"

msgid "Chapter section"
msgstr "Section chapitre"

msgid "Daily goal section"
msgstr "Section objectif quotidien"

msgid "Battery section (High)"
msgstr "Section batterie (Haute)"

msgid "Battery section (Med)"
msgstr "Section batterie (Moyenne)"

msgid "Battery section (Low)"
msgstr "Section batterie (Faible)"

msgid "Battery section (Charging)"
msgstr "Section batterie (En charge)"

msgid "Message section"
msgstr "Section message"

msgid "Colours (modes)"
msgstr "Couleurs (modes)"

msgid "Configure colours for monochrome mode, infobox background, and text.\nLight and dark correspond to the current dark mode setting. Monochrome\nreplaces all colours with that single chosen color."
msgstr "Configure les couleurs pour le mode monochrome, l'arrière-plan de la boîte d'information et le texte. Clair et sombre correspondent au réglage actuel du mode sombre. Monochrome remplace toutes les couleurs par cette unique couleur choisie."

msgid "Monochrome mode (light)"
msgstr "Mode monochrome (clair)"

msgid "Monochrome mode (dark)"
msgstr "Mode monochrome (foncé)"

msgid "Background (light)"
msgstr "Arrière-plan (clair)"

msgid "Background (dark)"
msgstr "Arrière-plan (foncé)"

msgid "Text (light)"
msgstr "Texte (clair)"

msgid "Text (dark)"
msgstr "Texte (foncé)"

msgid "Icon set"
msgstr "Jeu d'icônes"

msgid "Choose from different icon styles."
msgstr "Choisir parmi différents styles d'icônes."

msgid "Icon size"
msgstr "Taille des icônes"

msgid "Size of section icons."
msgstr "Taille des icônes de section."

msgid "Icon size (px)"
msgstr "Taille de l'icône (px)"

msgid "32–48px suits most layouts."
msgstr "32–48 px convient à la plupart des mises en page."

msgid "Progress bar height"
msgstr "Hauteur de la barre de progression"

msgid "Thickness of the horizontal progress bars shown in each section."
msgstr "Épaisseur des barres de progression horizontales affichées dans chaque section."

msgid "Bar height (px)"
msgstr "Hauteur de barre (px)"

msgid "4–8px is subtle. 12–16px is standard. 20+px is heavy."
msgstr "4–8 px est subtil. 12–16 px est standard. 20+ px est épais."

msgid "Show icons"
msgstr "Afficher les icônes"

msgid "Display decorative icons at the start of each section."
msgstr "Afficher des icônes décoratives au début de chaque section."

msgid "Show progress bars"
msgstr "Afficher les barres de progression"

msgid "Display horizontal progress bars showing completion percentage."
msgstr "Afficher des barres de progression horizontales indiquant le pourcentage d'avancement."

msgid "Show decorative bar on message section"
msgstr "Afficher la barre décorative dans la section des messages"

msgid "Displays a purely decorative progress bar under the message section,\nmatching the message section colour and the progress bars in other\nsections."
msgstr "Affiche une barre de progression purement décorative sous la section message, reprenant la couleur de cette section et des barres de progression des autres sections."

msgid "Inline progress bars"
msgstr "Barres de progression en ligne"

msgid "Progress bars sit inside the text area rather than spanning the full
section width. Automatically enabled when corner radius > 0."
msgstr "Les barres de progression se trouvent dans la zone de texte plutôt que de couvrir toute
la largeur de la section. Activé automatiquement lorsque le rayon des coins > 0."

msgid "Enable inline bars"
msgstr "Activer les barres en ligne"

msgid "When section gaps are enabled and corner radius > 0, inline bars are automatically enabled."
msgstr "Lorsque les espaces de section sont activés et que le rayon de coin > 0, les barres en ligne sont automatiquement activées."

msgid "Inline bars are force-enabled because section gaps and corner radius are both set. Set corner radius to 0 or disable section gaps to toggle inline bars independently."
msgstr "Les barres en ligne sont forcées car les espaces de section et le rayon de coin sont définis. Réglez le rayon sur 0 ou désactivez les espaces de section pour les basculer indépendamment."

msgid "Inline bar border size"
msgstr "Taille de la bordure de barre en ligne"

msgid "Thickness of the border around the inline progress bar."
msgstr "Épaisseur de la bordure autour de la barre de progression en ligne."

msgid "Inline bar border size (px)"
msgstr "Taille de la bordure de barre en ligne (px)"

msgid "0 for no border. 1–2px adds a subtle outline around the bar."
msgstr "0 pour aucune bordure. 1–2 px ajoute un contour subtil autour de la barre."

msgid "Bar width"
msgstr "Largeur de barre"

msgid "Width of the inline progress bar as a percentage of the available text
column. Alignment follows the text alignment setting."
msgstr "Largeur de la barre de progression en ligne en pourcentage de la colonne de texte disponible.
L'alignement suit le réglage d'alignement du texte."

msgid "Inline bar width (%)"
msgstr "Largeur de barre en ligne (%)"

msgid "100% fills the text column. The bar is aligned to match your text
alignment setting."
msgstr "100 % remplit la colonne de texte. La barre est alignée selon votre
réglage d'alignement du texte."

msgid "Title font face"
msgstr "Police du titre"

msgid "Choose the font face for the main heading text in each section"
msgstr "Choisir la police pour le texte de titre principal dans chaque section"

msgid "Title font size"
msgstr "Taille de police du titre"

msgid "Choose the font size for the main heading text in each section."
msgstr "Choisir la taille de police pour le texte de titre principal dans chaque section."

msgid "10–12px works well for most screens."
msgstr "10–12 px fonctionne bien pour la plupart des écrans."

msgid "Subtitle font face"
msgstr "Police du sous-titre"

msgid "Choose the font face for the information below the main heading text."
msgstr "Choisir la police pour les informations sous le texte de titre principal."

msgid "Subtitle font size"
msgstr "Taille de police du sous-titre"

msgid "Choose the font size for the information below the main heading text."
msgstr "Choisir la taille de police pour les informations sous le texte de titre principal."

msgid "9–11px works well for most screens."
msgstr "9–11 px fonctionne bien pour la plupart des écrans."

msgid "Text alignment"
msgstr "Alignement du texte"

msgid "Horizontal alignment of all text within sections."
msgstr "Alignement horizontal de tout le texte dans les sections."

msgid "Book multiline titles"
msgstr "Titres de livre multiligne"

msgid "If deselected book titles will be truncated to a single line with an\nellipsis"
msgstr "Si désélectionné, les titres de livre seront tronqués à une seule ligne avec des points de suspension"

msgid "Chapter multiline titles"
msgstr "Titres de chapitre multiligne"

msgid "If deselected chapter titles will be truncated to a single line with an\nellipsis"
msgstr "Si désélectionné, les titres de chapitre seront tronqués à une seule ligne avec des points de suspension"

msgid "Clean chapter titles"
