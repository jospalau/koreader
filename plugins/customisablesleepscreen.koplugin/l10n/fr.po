msgstr "Temps estimé pour finir le chapitre actuel, basé sur votre vitesse de lecture."

msgid "Title Line"
msgstr "Ligne de titre"

msgid "Choose what the top line of the daily info section displays."
msgstr "Choisir ce qu'affiche la première ligne de la section informations du jour."

msgid "Pages read today"
msgstr "Pages lues aujourd'hui"

msgid "e.g. '35 pages read today'"
msgstr "ex. '35 pages lues aujourd'hui'"

msgid "Time read today"
msgstr "Temps de lecture aujourd'hui"

