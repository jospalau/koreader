#. ---- All other strings (menu items, help text, headers, buttons) ----

msgid "Pick a colour"
msgstr "Kies een kleur"

msgid "Cancel"
msgstr "Annuleren"

msgid "Apply"
msgstr "Toepassen"

#, lua-format
msgid "Brightness: %d%%"
msgstr "Helderheid: %d%%"

msgid "Enter hex"
msgstr "Voer hex in"

msgid "Enter hex colour code"
msgstr "Voer hexadecimale kleurcode in"

msgid "Invalid hex code. Use format: #RRGGBB"
msgstr "Ongeldige hexcode. Gebruik formaat: #RRGGBB"

msgid "Delete all custom presets"
msgstr "Alle aangepaste presets verwijderen"

msgid "Permanently removes all custom presets you've created. The built-in 'Default' preset will remain. This cannot be undone."
msgstr "Verwijdert permanent alle door u gemaakte aangepaste presets. De ingebouwde 'Standaard' preset blijft behouden. Dit kan niet ongedaan worden gemaakt."

msgid "Are you sure you want to delete all custom presets? (built-in presets will remain)"
msgstr "Weet u zeker dat u alle aangepaste presets wilt verwijderen? (ingebouwde presets blijven behouden)"

msgid "Delete"
msgstr "Verwijderen"

msgid "All custom presets deleted. Built-in presets remain."
msgstr "Alle aangepaste presets verwijderd. Ingebouwde presets blijven behouden."

msgid "Sleep screen orientation"
msgstr "Oriëntatie slaapscherm"

msgid "Force the sleep screen to display in a specific orientation, regardless of how the device is held."
msgstr "Dwingt het slaapscherm om in een bepaalde oriëntatie weer te geven, ongeacht hoe het apparaat wordt vastgehouden."

msgid "Auto (follow device)"
msgstr "Automatisch (apparaat volgen)"

msgid "Use whatever orientation the device is currently in."
msgstr "Gebruik de huidige oriëntatie van het apparaat."

msgid "Force portrait"
msgstr "Portret afdwingen"

msgid "Always display the sleep screen in portrait mode."
msgstr "Altijd het slaapscherm in portretmodus weergeven."

msgid "Force landscape"
msgstr "Landschap afdwingen"

msgid "Always display the sleep screen in landscape mode."
msgstr "Altijd het slaapscherm in landschapsmodus weergeven."

msgid "Force upside-down portrait"
msgstr "Omgekeerd portret afdwingen"

msgid "Always display the sleep screen in inverted portrait mode."
msgstr "Altijd het slaapscherm in omgekeerde portretmodus weergeven."

msgid "Force upside-down landscape"
msgstr "Omgekeerd landschap afdwingen"

msgid "Always display the sleep screen in inverted landscape mode."
msgstr "Altijd het slaapscherm in omgekeerde landschapsmodus weergeven."

msgid "Battery time calculation"
msgstr "Berekening batterijduur"

msgid "Method used to estimate remaining battery life."
msgstr "Methode die wordt gebruikt om de resterende batterijduur te schatten."

msgid "Since last charge"
msgstr "Sinds laatste oplading"

msgid "Uses combined awake and sleeping battery drain since last charge"
msgstr "Gebruikt gecombineerd batterijverbruik in actieve en slaapstand sinds laatste oplading"

msgid "Awake since last charge"
msgstr "Actief sinds laatste oplading"

msgid "Uses only active reading battery drain (more conservative estimate)"
msgstr "Gebruikt alleen batterijverbruik tijdens actief lezen (conservatievere schatting)"

msgid "Sleeping since last charge"
msgstr "In slaapstand sinds laatste oplading"

msgid "Uses only sleep mode battery drain"
msgstr "Gebruikt alleen batterijverbruik in slaapstand"

msgid "Manual calculation"
msgstr "Handmatige berekening"

msgid "Use a custom battery drain rate (1-10% per hour)"
msgstr "Gebruik een aangepast batterijverbruikstempo (1-10% per uur)"

msgid "Set manual drain rate"
msgstr "Handmatig verbruikstempo instellen"

msgid "Battery drain rate (% per hour)"
msgstr "Batterijverbruikstempo (% per uur)"

msgid "Typical devices drain 1-5% per hour while reading."
msgstr "Typische apparaten verbruiken 1–5% per uur tijdens het lezen."

msgid "Daily statistics scope"
msgstr "Bereik dagelijkse statistieken"

msgid "Controls whether today's reading time and page count applies to the current book only, or all books read today. Note: reading streak and weekly goal achievement always reflect all books regardless of this setting."
msgstr "Bepaalt of de leestijd en het aantal pagina's van vandaag alleen voor het huidige boek gelden, of voor alle vandaag gelezen boeken. Opmerking: leesreeks en wekelijkse doelbereiking weerspiegelen altijd alle boeken, ongeacht deze instelling."

msgid "All books"
msgstr "Alle boeken"

msgid "Today's reading time and page count across all books read today"
msgstr "Leestijd en aantal pagina's van vandaag voor alle vandaag gelezen boeken"

msgid "Current book only"
msgstr "Alleen huidig boek"

msgid "Today's reading time and page count for the current book only"
msgstr "Leestijd en aantal pagina's van vandaag alleen voor het huidige boek"

msgid "Show in file manager (outside of book)"
msgstr "Tonen in bestandsbeheer (buiten boek)"

msgid "When enabled, the customisable sleep screen will display in file manager using the last saved book data."
msgstr "Indien ingeschakeld wordt het configureerbare slaapscherm weergegeven in het bestandsbeheer met de laatst opgeslagen boekgegevens."

msgid "Hide built-in presets (except Default)"
msgstr "Ingebouwde presets verbergen (behalve Standaard)"

msgid "Hide the built-in presets from the preset list, keeping only the Default preset and your custom presets visible."
msgstr "Verbergt de ingebouwde presets uit de presetlijst, zodat alleen de Standaard preset en uw aangepaste presets zichtbaar zijn."

msgid "Setting saved. Preset list will update when you reopen this menu."
msgstr "Instelling opgeslagen. De presetlijst wordt bijgewerkt wanneer u dit menu opnieuw opent."

msgid "Export sleep screen to file"
msgstr "Slaapscherm exporteren naar bestand"

msgid "When enabled, a screenshot of the sleep screen will be saved as 'screensaver.png' in the selected export folder each time a book is closed."
msgstr "Indien ingeschakeld wordt elke keer dat een boek wordt gesloten een schermafbeelding van het slaapscherm opgeslagen als 'screensaver.png' in de geselecteerde exportmap."

msgid "Sleep screen export disabled."
msgstr "Export slaapscherm uitgeschakeld."

msgid "No export folder set. Please set an export folder first."
msgstr "Geen exportmap ingesteld. Stel eerst een exportmap in."

#, lua-format
msgid "Sleep screen will be exported to:\n%s/screensaver.png"
msgstr "Slaapscherm wordt geëxporteerd naar:\n%s/screensaver.png"

msgid "Set export folder"
msgstr "Exportmap instellen"

msgid "Choose the folder where screensaver.png will be saved."
msgstr "Kies de map waar screensaver.png wordt opgeslagen."

#, lua-format
msgid "Export folder set to:\n%s"
msgstr "Exportmap ingesteld op:\n%s"

msgid "Presets"
msgstr "Presets"

msgid "Save, load, and manage presets."
msgstr "Presets opslaan, laden en beheren."

msgid "Display modes"
msgstr "Weergavemodi"

msgid "Global appearance settings."
msgstr "Algemene uiterlijkinstellingen."

msgid "Contents"
msgstr "Inhoud"

msgid "Control which sections appear and what information they display."
msgstr "Bepaalt welke secties worden weergegeven en welke informatie ze tonen."

msgid "Layout & Spacing"
msgstr "Indeling en ruimte"

msgid "Adjust the spatial settings of the information box."
msgstr "Past de ruimtelijke instellingen van het informatiepaneel aan."

msgid "Colours, Icons & Bars"
msgstr "Kleuren, iconen en balken"

msgid "Customise section colours, icon appearance, and progress bar styling."
msgstr "Pas sectiekleuren, uiterlijk van iconen en stijl van voortgangsbalken aan."

msgid "Fonts & Text"
msgstr "Lettertypen en tekst"

msgid "Configure text appearance."
msgstr "Configureert het uiterlijk van tekst."

msgid "Background"
msgstr "Achtergrond"

msgid "Choose what appears behind the information box."
msgstr "Kies wat achter het informatiepaneel wordt weergegeven."

msgid "Advanced"
msgstr "Geavanceerd"

msgid "Advanced configuration options."
msgstr "Geavanceerde configuratie-opties."

msgid "About"
msgstr "Over"

#, lua-format
msgid ""
"%s\n"
"Version: %s\n"
"\n"
"For updates and issues:\n"
"github.com/%s"
msgstr ""
"%s\n"
"Versie: %s\n"
"\n"
"Voor updates en problemen:\n"
"github.com/%s"

msgid "Top left"
msgstr "Linksboven"

msgid "Top centre"
msgstr "Boven midden"

msgid "Top right"
msgstr "Rechtsboven"

msgid "Middle left"
msgstr "Midden links"

msgid "Centre"
msgstr "Midden"

msgid "Middle right"
msgstr "Midden rechts"

msgid "Bottom left"
msgstr "Linksonder"

msgid "Bottom centre"
msgstr "Onder midden"

msgid "Bottom right"
msgstr "Rechtsonder"

msgid "Dark mode"
msgstr "Donkere modus"

msgid "Inverts the colour scheme. Text becomes white and backgrounds becomes black. Useful for reading in low-light conditions. Can be combined with monochrome mode."
msgstr "Keert het kleurenschema om. Tekst wordt wit en achtergronden worden zwart. Handig voor lezen bij weinig licht. Kan worden gecombineerd met monochrome modus."

msgid "Monochrome mode"
msgstr "Monochrome modus"

msgid "Suitable for B&W e-readers. Assigns one colour to all sections using monochrome light or monochrome dark hex values. Overwrites individual assigned section colours. Can be combined with dark mode."
msgstr "Geschikt voor zwart-wit e-readers. Kent één kleur toe aan alle secties met lichte of donkere monochrome hexwaarden. Overschrijft individueel toegewezen sectiekleuren. Kan worden gecombineerd met donkere modus."

msgid "Section gaps"
msgstr "Ruimte tussen secties"

msgid "Add transparent gaps between sections to make each appear as a separate box"
msgstr "Voegt transparante ruimte toe tussen secties zodat elke sectie als een apart paneel verschijnt"

msgid "Enable section gaps"
msgstr "Ruimte tussen secties inschakelen"

msgid "Section gap size"
msgstr "Grootte ruimte tussen secties"

msgid "Spacing between sections when gaps are enabled."
msgstr "Ruimte tussen secties wanneer tussenruimten zijn ingeschakeld."

msgid "Section gap size (pixels)"
msgstr "Grootte ruimte tussen secties (pixels)"

msgid "10–20px gives a subtle separation. 30–50px makes sections feel like distinct cards."
msgstr "10–20px geeft een subtiele scheiding. 30–50px laat secties aanvoelen als afzonderlijke kaarten."

msgid "Position"
msgstr "Positie"

msgid "Screen location where the information box appears."
msgstr "Schermlocatie waar het informatiepaneel verschijnt."

msgid "Position offset"
msgstr "Positieverschuiving"

msgid "Nudge the box from its anchor position. Useful for pushing rounded corners off-screen."
msgstr "Verschuif het paneel vanuit zijn ankerpositie. Handig om afgeronde hoeken buiten beeld te duwen."

msgid "Horizontal offset (px)"
msgstr "Horizontale verschuiving (px)"

msgid "Nudges the box left (-) or right (+) from its anchor. Useful for pushing rounded corners off-screen."
msgstr "Verschuift het paneel naar links (-) of rechts (+) vanuit zijn anker. Handig om afgeronde hoeken buiten beeld te duwen."

msgid "Vertical offset (px)"
msgstr "Verticale verschuiving (px)"

msgid "Nudges the box up (+) or down (-) from its anchor. Useful for pushing rounded corners off-screen."
msgstr "Verschuift het paneel omhoog (+) of omlaag (-) vanuit zijn anker. Handig om afgeronde hoeken buiten beeld te duwen."

msgid "Width"
msgstr "Breedte"

msgid "Horizontal width of the information box as a percentage of screen width."
msgstr "Horizontale breedte van het informatiepaneel als percentage van de schermbreedte."

msgid "Box width (%)"
msgstr "Paneelbreedte (%)"

msgid "60–70% suits portrait screens."
msgstr "60–70% past goed bij staande schermen."

msgid "Opacity"
msgstr "Dekking"

msgid "Transparency of the information box."
msgstr "Transparantie van het informatiepaneel."

msgid "Opacity (%)"
msgstr "Dekking (%)"

msgid "75% is semi-transparent. 100% is fully opaque."
msgstr "75% is halftransparant. 100% is volledig ondoorzichtig."

msgid "Border size"
msgstr "Randgrootte"

msgid "Thickness of the primary border around sections."
msgstr "Dikte van de primaire rand rondom secties."

msgid "Border size (px)"
msgstr "Randgrootte (px)"

msgid "0 for no border. 1–2px is subtle, 4–6px is bold and visible."
msgstr "0 voor geen rand. 1–2px is subtiel, 4–6px is vet en zichtbaar."

msgid "Border trim size"
msgstr "Grootte decoratieve rand"

msgid "Secondary decorative border surrounding the primary border."
msgstr "Secundaire decoratieve rand rondom de primaire rand."

msgid "Border trim size (px)"
msgstr "Grootte decoratieve rand (px)"

msgid "0 for no trim. 1–2px is subtle, 4–6px is a bold decorative outline around the primary border."
msgstr "0 voor geen rand. 1–2px is subtiel, 4–6px is een vette decoratieve omlijning rondom de primaire rand."

msgid "Corner radius"
msgstr "Hoekradius"

msgid "Round the corners of the info box. Also moves progress bars inline with the text when active."
msgstr "Maakt de hoeken van het informatiepaneel rond. Verplaatst ook voortgangsbalken inline met de tekst wanneer actief."

msgid "Corner radius (px)"
msgstr "Hoekradius (px)"

msgid "0 for square corners. 15–30px for softly rounded. 150px+ for a pill-shaped box (depending on the section box height)."
msgstr "0 voor vierkante hoeken. 15–30px voor zacht afgerond. 150px+ voor een pilvormig paneel (afhankelijk van de hoogte van het sectiepaneel)."

msgid "Internal padding"
msgstr "Interne opvulling"

msgid "Space between section borders and their content, configurable per side."
msgstr "Ruimte tussen sectiegrensen en hun inhoud, per zijde instelbaar."

msgid "Top"
msgstr "Boven"

msgid "Internal padding — top (px)"
msgstr "Interne opvulling — boven (px)"

msgid "Space above section content."
msgstr "Ruimte boven de sectie-inhoud."

msgid "Bottom"
msgstr "Onder"

msgid "Internal padding — bottom (px)"
msgstr "Interne opvulling — onder (px)"

msgid "Space below section content."
msgstr "Ruimte onder de sectie-inhoud."

msgid "Left"
msgstr "Links"

msgid "Internal padding — left (px)"
msgstr "Interne opvulling — links (px)"

msgid "Space to the left of section content. Increase when using large corner radii."
msgstr "Ruimte links van de sectie-inhoud. Vergroot bij gebruik van grote hoekradii."

msgid "Right"
msgstr "Rechts"

msgid "Internal padding — right (px)"
msgstr "Interne opvulling — rechts (px)"

msgid "Space to the right of section content. Increase when using large corner radii."
msgstr "Ruimte rechts van de sectie-inhoud. Vergroot bij gebruik van grote hoekradii."

msgid "Set all sides equally"
msgstr "Alle zijden gelijk instellen"

msgid "Internal padding — all sides (px)"
msgstr "Interne opvulling — alle zijden (px)"

msgid "Sets top, bottom, left and right padding to the same value in one step."
msgstr "Stelt boven-, onder-, linker- en rechteropvulling in één stap in op dezelfde waarde."

msgid "Icon to text gap"
msgstr "Ruimte icoon naar tekst"

msgid "Horizontal spacing between section icons and their accompanying text."
msgstr "Horizontale afstand tussen sectie-iconen en de bijbehorende tekst."

msgid "Icon to text gap (px)"
msgstr "Ruimte icoon naar tekst (px)"

msgid "8–12px gives comfortable breathing room between icon and text. 0 is flush."
msgstr "8–12px geeft comfortabele ademruimte tussen icoon en tekst. 0 is gelijk."

msgid "No icon sets found in customisablesleepscreen.koplugin/icons/"
msgstr "Geen icoonsets gevonden in customisablesleepscreen.koplugin/icons/"

msgid "Colours (progress bars)"
msgstr "Kleuren (voortgangsbalken)"

msgid "Set the progress bar colours for each section."
msgstr "Stelt de kleuren van de voortgangsbalk in voor elke sectie."

msgid "Use saved colours for icon fill"
msgstr "Opgeslagen kleuren gebruiken voor icoonvulling"

msgid "When enabled, icons will match the colour of their section's progress bar."
msgstr "Indien ingeschakeld komen iconen overeen met de kleur van de voortgangsbalk van hun sectie."

msgid "Book section"
msgstr "Boeksectie"

msgid "Chapter section"
msgstr "Hoofdstuksectie"

msgid "Daily goal section"
msgstr "Dagelijks doelsectie"

msgid "Battery section (High)"
msgstr "Batterijsectie (Hoog)"

msgid "Battery section (Med)"
msgstr "Batterijsectie (Midden)"

msgid "Battery section (Low)"
msgstr "Batterijsectie (Laag)"

msgid "Battery section (Charging)"
msgstr "Batterijsectie (Laden)"

msgid "Message section"
msgstr "Berichtsectie"

msgid "Colours (modes)"
msgstr "Kleuren (modi)"

msgid "Configure colours for monochrome mode, infobox background, and text. Light and dark correspond to the current dark mode setting. Monochrome replaces all colours with that single chosen color."
msgstr "Configureer kleuren voor de monochrome modus, de achtergrond van het informatievak en tekst. Licht en donker komen overeen met de huidige instelling van de donkere modus. Monochroom vervangt alle kleuren door die ene gekozen kleur."

msgid "Monochrome mode (light)"
msgstr "Monochrome modus (licht)"

msgid "Monochrome mode (dark)"
msgstr "Monochrome modus (donker)"

msgid "Background (light)"
msgstr "Achtergrond (licht)"

msgid "Background (dark)"
msgstr "Achtergrond (donker)"

msgid "Text (light)"
msgstr "Tekst (licht)"

msgid "Text (dark)"
msgstr "Tekst (donker)"

msgid "Icon set"
msgstr "Icoonset"

msgid "Choose from different icon styles."
msgstr "Kies uit verschillende icoonsstijlen."

msgid "Icon size"
msgstr "Icoongrootte"

msgid "Size of section icons."
msgstr "Grootte van sectie-iconen."

msgid "Icon size (px)"
msgstr "Icoongrootte (px)"

msgid "32–48px suits most layouts."
msgstr "32–48px past bij de meeste indelingen."

msgid "Progress bar height"
msgstr "Hoogte voortgangsbalk"

msgid "Thickness of the horizontal progress bars shown in each section."
msgstr "Dikte van de horizontale voortgangsbalken weergegeven in elke sectie."

msgid "Bar height (px)"
msgstr "Balkshoogte (px)"

msgid "4–8px is subtle. 12–16px is standard. 20+px is heavy."
msgstr "4–8px is subtiel. 12–16px is standaard. 20+px is zwaar."

msgid "Show icons"
msgstr "Iconen tonen"

msgid "Display decorative icons at the start of each section."
msgstr "Toont decoratieve iconen aan het begin van elke sectie."

msgid "Show progress bars"
msgstr "Voortgangsbalken tonen"

msgid "Display horizontal progress bars showing completion percentage."
msgstr "Toont horizontale voortgangsbalken met het voltooiingspercentage."

msgid "Show decorative bar on message section"
msgstr "Decoratiebalk weergeven in berichtsectie"

msgid "Displays a purely decorative progress bar under the message section, matching the message section colour and the progress bars in other sections."
msgstr "Toont een puur decoratieve voortgangsbalk onder de berichtensectie, passend bij de kleur van de berichtensectie en de voortgangsbalken in andere secties."

msgid "Inline progress bars"
msgstr "Inline voortgangsbalken"

msgid "Progress bars sit inside the text area rather than spanning the full section width. Automatically enabled when corner radius > 0."
msgstr "Voortgangsbalken bevinden zich in het tekstgebied in plaats van de volledige sectiebreedte te beslaan. Automatisch ingeschakeld wanneer hoekradius > 0."

msgid "Enable inline bars"
msgstr "Inline balken inschakelen"

msgid "When section gaps are enabled and corner radius > 0, inline bars are automatically enabled."
msgstr "Wanneer sectieafstanden zijn ingeschakeld en de hoekradius > 0 is, worden inlinebalken automatisch ingeschakeld."

msgid "Inline bars are force-enabled because section gaps and corner radius are both set. Set corner radius to 0 or disable section gaps to toggle inline bars independently."
msgstr "Inlinebalken zijn geforceerd ingeschakeld omdat sectieafstanden en hoekradius beide zijn ingesteld. Stel de hoekradius in op 0 of schakel sectieafstanden uit om inlinebalken onafhankelijk te schakelen."

msgid "Inline bar border size"
msgstr "Randgrootte inline balk"

msgid "Thickness of the border around the inline progress bar."
msgstr "Dikte van de rand rondom de inline voortgangsbalk."

msgid "Inline bar border size (px)"
msgstr "Randgrootte inline balk (px)"

msgid "0 for no border. 1–2px adds a subtle outline around the bar."
msgstr "0 voor geen rand. 1–2px voegt een subtiele omlijning toe rondom de balk."

msgid "Bar width"
msgstr "Balkbreedte"

msgid "Width of the inline progress bar as a percentage of the available text column. Alignment follows the text alignment setting."
msgstr "Breedte van de inline voortgangsbalk als percentage van de beschikbare tekstkolom. Uitlijning volgt de tekstuitlijningsinstelling."

msgid "Inline bar width (%)"
msgstr "Breedte inline balk (%)"

msgid "100% fills the text column. The bar is aligned to match your text alignment setting."
msgstr "100% vult de tekstkolom. De balk is uitgelijnd overeenkomstig uw tekstuitlijningsinstelling."

msgid "Title font face"
msgstr "Lettertype titel"

msgid "Choose the font face for the main heading text in each section"
msgstr "Kies het lettertype voor de hoofdkopregel in elke sectie"

msgid "Title font size"
msgstr "Tekengrootte titel"

msgid "Choose the font size for the main heading text in each section."
msgstr "Kies de tekengrootte voor de hoofdkopregel in elke sectie."

msgid "10–12px works well for most screens."
msgstr "10–12px werkt goed voor de meeste schermen."

msgid "Subtitle font face"
msgstr "Lettertype ondertitel"

msgid "Choose the font face for the information below the main heading text."
msgstr "Kies het lettertype voor de informatie onder de hoofdkopregel."

msgid "Subtitle font size"
msgstr "Tekengrootte ondertitel"

msgid "Choose the font size for the information below the main heading text."
msgstr "Kies de tekengrootte voor de informatie onder de hoofdkopregel."

msgid "9–11px works well for most screens."
msgstr "9–11px werkt goed voor de meeste schermen."

msgid "Text alignment"
msgstr "Tekstuitlijning"

msgid "Horizontal alignment of all text within sections."
msgstr "Horizontale uitlijning van alle tekst binnen secties."

msgid "Book multiline titles"
msgstr "Meerdere regels voor boektitels"

msgid "If deselected book titles will be truncated to a single line with an ellipsis"
msgstr "Als uitgeschakeld worden boektitels afgekapt tot één regel met een beletselteken"

msgid "Chapter multiline titles"
msgstr "Meerdere regels voor hoofdstuktitels"

msgid "If deselected chapter titles will be truncated to a single line with an ellipsis"
msgstr "Als uitgeschakeld worden hoofdstuktitels afgekapt tot één regel met een beletselteken"

msgid "Clean chapter titles"
msgstr "Hoofdstuktitels opschonen"

msgid "Removes structural prefixes like 'Chapter 5:' or 'Part II' from chapter titles and normalises capitalisation. Only works correctly with English chapter titles - disable for non-English books."
msgstr "Verwijdert structurele voorvoegsels zoals 'Hoofdstuk 5:' of 'Deel II' uit hoofdstuktitels en normaliseert het gebruik van hoofdletters. Werkt alleen correct met Engelstalige hoofdstuktitels — uitschakelen voor niet-Engelstalige boeken."

msgid "Make titles bold"
msgstr "Titels vetgedrukt maken"

msgid "Display the section titles in bold font weight for extra emphasis."
msgstr "Toont de sectietitels vetgedrukt voor extra nadruk."

msgid "No background"
msgstr "Geen achtergrond"

msgid "Book cover"
msgstr "Boekomslag"

msgid "Solid colour"
msgstr "Effen kleur"

msgid "Random image from folder"
msgstr "Willekeurige afbeelding uit map"

msgid "Stretch book cover to fill"
msgstr "Boekomslag uitrekken om te vullen"

msgid "When disabled, book cover will be scaled to fit within the screen while preserving aspect ratio."
msgstr "Wanneer uitgeschakeld wordt het boekomslag geschaald om op het scherm te passen met behoud van beeldverhouding."

msgid "Cover fill colour"
msgstr "Vulkleur omslag"

msgid "Background colour for non-stretched covers."
msgstr "Achtergrondkleur voor niet-uitgestrekte omslagen."

msgid "Pick cover fill colour"
msgstr "Vulkleur omslag kiezen"

msgid "Cover alignment"
msgstr "Uitlijning omslag"

msgid "Horizontal alignment of the cover image when not stretched."
msgstr "Horizontale uitlijning van de omslagafbeelding wanneer niet uitgerekt."

msgid "Solid background colour"
msgstr "Effen achtergrondkleur"

msgid "Pick background colour"
msgstr "Achtergrondkleur kiezen"

msgid "Background folder path"
msgstr "Pad naar achtergrondmap"

msgid "No images found in the selected folder. No background will be shown."
msgstr "Geen afbeeldingen gevonden in de geselecteerde map. Er wordt geen achtergrond weergegeven."

msgid "Background type"
msgstr "Achtergrondtype"

msgid "Background overlay"
msgstr "Achtergrondoverlay"

msgid "Add a colour layer over the background to reduce contrast."
msgstr "Voegt een kleurlaag over de achtergrond toe om het contrast te verminderen."

msgid "Overlay colour"
msgstr "Overlaykleur"

msgid "Background overlay colour"
msgstr "Achtergrondoverlaykleur"

msgid "Overlay opacity"
msgstr "Dekking overlay"

msgid "Overlay opacity (%)"
msgstr "Dekking overlay (%)"

msgid "0% is no overlay. 20–40% adds a soft tint. 100% is fully opaque."
msgstr "0% is geen overlay. 20–40% voegt een zachte tint toe. 100% is volledig ondoorzichtig."

msgid "Reset layout & spacing settings to default"
msgstr "Indeling en ruimte-instellingen terugzetten naar standaard"

msgid "Are you sure you want to reset layout & spacing settings?"
msgstr "Weet u zeker dat u de indeling en ruimte-instellingen wilt terugzetten?"

msgid "Layout & spacing settings reset to defaults"
msgstr "Indeling en ruimte-instellingen teruggezet naar standaard"

msgid "Reset contents settings to default"
msgstr "Inhoudinstellingen terugzetten naar standaard"

msgid "Are you sure you want to reset contents settings?"
msgstr "Weet u zeker dat u de inhoudinstellingen wilt terugzetten?"

msgid "Contents settings reset to defaults"
msgstr "Inhoudinstellingen teruggezet naar standaard"

msgid "Reset colours, icons & bars settings to default"
msgstr "Kleuren, iconen en balken-instellingen terugzetten naar standaard"

msgid "Are you sure you want to reset colours, icons & bars settings?"
msgstr "Weet u zeker dat u de kleuren, iconen en balken-instellingen wilt terugzetten?"

msgid "Colours, icons & bars settings reset to defaults"
msgstr "Kleuren, iconen en balken-instellingen teruggezet naar standaard"

msgid "Reset fonts & text settings to default"
msgstr "Lettertype en tekst-instellingen terugzetten naar standaard"

msgid "Are you sure you want to reset fonts & text settings?"
msgstr "Weet u zeker dat u de lettertype en tekst-instellingen wilt terugzetten?"

msgid "Fonts & text settings reset to defaults"
msgstr "Lettertype en tekst-instellingen teruggezet naar standaard"

msgid "Reset background settings to default"
msgstr "Achtergrondinstellingen terugzetten naar standaard"

msgid "Are you sure you want to reset background settings?"
msgstr "Weet u zeker dat u de achtergrondinstellingen wilt terugzetten?"

msgid "Background settings reset to defaults"
msgstr "Achtergrondinstellingen teruggezet naar standaard"

msgid "Reset the settings in this part of the menu to their defaults."
msgstr "Zet de instellingen in dit deel van het menu terug naar de standaardwaarden."

msgid "factory defaults"
msgstr "fabrieksstandaarden"

#, lua-format
msgid "Values will be restored from: %s"
msgstr "Waarden worden hersteld van: %s"

