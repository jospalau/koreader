msgstr "Voer een nieuwe presetnaam in"

msgid "[ Built-in Presets ]"
msgstr "[ Ingebouwde presets ]"

msgid "[ Your Custom Presets ]"
msgstr "[ Uw aangepaste presets ]"

msgid "Book info"
msgstr "Boekinformatie"

msgid "Chapter info"
msgstr "Hoofdstukinformatie"

msgid "Daily info"
msgstr "Dagelijkse informatie"

msgid "Battery info"
msgstr "Batterijinformatie"

msgid "Message info"
msgstr "Berichtinformatie"

msgid "Reorder sections"
msgstr "Secties herordenen"

msgid "Section order"
msgstr "Sectievolgorde"

msgid "At least one section must remain visible."
msgstr "Minstens één sectie moet zichtbaar blijven."

msgid "Show cover image above book info"
msgstr "Omslagafbeelding boven boekinformatie tonen"

msgid "Display the book's cover image above the title and progress in the book section."
msgstr "Toont de omslagafbeelding van het boek boven de titel en voortgang in de boeksectie."

msgid "Cover image size"
msgstr "Grootte omslagafbeelding"

msgid "Height limit for the cover image in pixels."
msgstr "Hoogtelimiet voor de omslagafbeelding in pixels."

msgid "Cover image size (pixels)"
msgstr "Grootte omslagafbeelding (pixels)"

msgid "100–150px fits neatly in most layouts. Go up to 250px+ for a prominent cover."
msgstr "100–150px past netjes in de meeste indelingen. Ga tot 250px+ voor een prominente omslag."

msgid "Cover border size"
msgstr "Randgrootte omslag"

msgid "Width of the border drawn around the cover image. Set to 0 for no border."
msgstr "Breedte van de rand rondom de omslagafbeelding. Stel in op 0 voor geen rand."

msgid "Cover border size (pixels)"
msgstr "Randgrootte omslag (pixels)"

msgid "1–3px for a subtle outline. 0 to disable."
msgstr "1–3px voor een subtiele omlijning. 0 om uit te schakelen."

msgid "Align cover to text alignment"
msgstr "Omslag uitlijnen op tekstuitlijning"

msgid "When enabled, the cover image follows the text alignment setting instead of always being centered."
msgstr "Indien ingeschakeld volgt de omslagafbeelding de tekstuitlijningsinstelling in plaats van altijd gecentreerd te zijn."

msgid "Cover image"
msgstr "Omslagafbeelding"

msgid "Configure the book cover image shown above the book section."
msgstr "Configureert de boekomslagafbeelding die boven de boeksectie wordt getoond."

msgid "Show book author"
msgstr "Boekauteur tonen"

msgid "Display the author name below the book title."
msgstr "Toont de naam van de auteur onder de boektitel."

msgid "Show series name"
msgstr "Serienaam tonen"

msgid "Display the book's series name and index below the title."
msgstr "Toont de serienaam en het serienummer van het boek onder de titel."

msgid "Show book pages (pg x of x)"
msgstr "Boekpagina's tonen (pag. x van x)"

msgid "Display total page count for the entire book."
msgstr "Toont het totale aantal pagina's van het hele boek."

msgid "Show book time remaining"
msgstr "Resterende leestijd boek tonen"

msgid "Estimated reading time left to finish the book, based on your average reading speed."
msgstr "Geschatte resterende leestijd om het boek te voltooien, gebaseerd op uw gemiddelde leessnelheid."

msgid "Show chapter count (ch x of x)"
msgstr "Aantal hoofdstukken tonen (hfst. x van x)"

msgid "Display current chapter number and total chapters (e.g., 'Chapter 5 of 12')."
msgstr "Toont het huidige hoofdstuknummer en het totale aantal hoofdstukken (bijv. 'Hoofdstuk 5 van 12')."

msgid "Show chapter pages (pg x of x)"
msgstr "Hoofdstukpagina's tonen (pag. x van x)"

msgid "Display the number of pages in the current chapter."
msgstr "Toont het aantal pagina's in het huidige hoofdstuk."

msgid "Show chapter time remaining"
msgstr "Resterende leestijd hoofdstuk tonen"

msgid "Estimated time to finish the current chapter, based on your reading speed."
msgstr "Geschatte tijd om het huidige hoofdstuk te voltooien, gebaseerd op uw leessnelheid."

msgid "Title Line"
msgstr "Titelregel"

msgid "Choose what the top line of the daily info section displays."
msgstr "Kies wat de bovenste regel van de dagelijkse infosectie toont."

msgid "Pages read today"
msgstr "Vandaag gelezen pagina's"

msgid "e.g. '35 pages read today'"
msgstr "bijv. '35 pagina's vandaag gelezen'"

msgid "Time read today"
msgstr "Vandaag gelezen tijd"

msgid "e.g. '42 mins read today'"
msgstr "bijv. '42 min vandaag gelezen'"

msgid "Pages and time read today"
msgstr "Vandaag gelezen pagina's en tijd"

msgid "e.g. '35 pgs & 42 mins read today'"
msgstr "bijv. '35 pag. & 42 min vandaag gelezen'"

msgid "Goal type"
msgstr "Doeltype"

msgid "Choose whether your daily goal tracks pages read or time spent reading."
msgstr "Kies of uw dagelijks doel gelezen pagina's of bestede leestijd bijhoudt."

msgid "Page goal"
msgstr "Paginadoel"

msgid "Track daily progress by number of pages read."
msgstr "Dagelijkse voortgang bijhouden via het aantal gelezen pagina's."

msgid "Time goal"
msgstr "Tijdsdoel"

msgid "Track daily progress by minutes spent reading."
msgstr "Dagelijkse voortgang bijhouden via bestede leesminuten."

msgid "Daily page goal"
msgstr "Dagelijks paginadoel"

msgid "Set how many pages you aim to read each day."
msgstr "Stel in hoeveel pagina's u elke dag wilt lezen."

msgid "Daily page goal (pages)"
msgstr "Dagelijks paginadoel (pagina's)"

msgid "20–50 pages for a daily habit. 50–100 for dedicated reading sessions."
msgstr "20–50 pagina's voor een dagelijkse gewoonte. 50–100 voor toegewijde leessessies."

msgid "Daily time goal"
msgstr "Dagelijks tijdsdoel"

msgid "Set how many minutes you aim to read each day."
msgstr "Stel in hoeveel minuten u elke dag wilt lezen."

msgid "Daily time goal (minutes)"
msgstr "Dagelijks tijdsdoel (minuten)"

msgid "20–30 mins for a daily habit. 60+ mins for dedicated reading sessions."
msgstr "20–30 min voor een dagelijkse gewoonte. 60+ min voor toegewijde leessessies."

msgid "Show current reading streak"
msgstr "Huidige leestreeks tonen"

msgid "Display consecutive days you've met your reading goal."
msgstr "Toont opeenvolgende dagen waarop u uw leesdoel hebt gehaald."

msgid "Show weekly progress"
msgstr "Wekelijkse voortgang tonen"

msgid "Days this week you have met your reading goal, shown as completed days out of the current weekday (Monday = 1... Sunday = 7). For example: Thursday with goals met on Monday and Tuesday will show 2/4."
msgstr "Dagen deze week waarop u uw leesdoel heeft gehaald, weergegeven als voltooide dagen van de huidige weekdag (maandag = 1... zondag = 7). Bijvoorbeeld: donderdag met doelen gehaald op maandag en dinsdag toont 2/4."

msgid "Show daily goal"
msgstr "Dagelijks doel tonen"

msgid "Target page mode: e.g. 50 page goal. Target time mode: e.g. 1hr 15min time goal."
msgstr "Paginadoel modus: bijv. 50 pagina doel. Tijdsdoel modus: bijv. 1u 15min tijdsdoel."

msgid "Show current time/date on separate line"
msgstr "Huidige tijd/datum op aparte regel tonen"

msgid "Display time/date on its own line below battery percentage instead of inline."
msgstr "Toont tijd/datum op een eigen regel onder het batterijpercentage in plaats van inline."

msgid "Enable 'Show battery time remaining' to use this option"
msgstr "Schakel 'Resterende batterijduur tonen' in om deze optie te gebruiken"

msgid "Show date instead of time"
msgstr "Datum tonen in plaats van tijd"

msgid "Display current date (e.g. '29th Jan') instead of time in battery section"
msgstr "Toont de huidige datum (bijv. '29 jan') in plaats van de tijd in de batterijsectie"

msgid "Show battery consumption rate"
msgstr "Batterijverbruikssnelheid tonen"

msgid "Display battery drain percentage per hour based on recent usage or manual input (see advanced menu)"
msgstr "Toont het batterijverbruikspercentage per uur op basis van recent gebruik of handmatige invoer (zie geavanceerd menu)"

msgid "Show battery time remaining"
msgstr "Resterende batterijduur tonen"

msgid "Estimated hours and minutes until battery is depleted, based on current drain rate."
msgstr "Geschatte uren en minuten tot de batterij leeg is, gebaseerd op de huidige verbruikssnelheid."

msgid "Custom message"
msgstr "Aangepast bericht"

msgid "Use a separate custom message just for Customisable Sleep Screen"
msgstr "Een apart aangepast bericht gebruiken alleen voor het configureerbare slaapscherm"

msgid "Book highlights"
msgstr "Boekaantekeningen"

msgid "Show a random highlight from the current book"
msgstr "Een willekeurige markering uit het huidige boek tonen"

msgid "Custom quotes"
msgstr "Aangepaste citaten"

msgid "Show a random quote from the custom_quotes.lua file in the plugin folder."
msgstr "Toont een willekeurig citaat uit het bestand custom_quotes.lua in de pluginmap."

msgid "KOReader sleep message"
msgstr "KOReader slaapschermbericht"

msgid "Uses KOReaders own sleep screen message function. Enable 'Add custom message to sleep screen' to use this (Settings → Screen → Sleep screen → Sleep screen message)."
msgstr "Gebruikt de eigen berichtfunctie van het KOReader slaapscherm. Schakel 'Aangepast bericht toevoegen aan slaapscherm' in om dit te gebruiken (Instellingen → Scherm → Slaapscherm → Slaapschermbericht)."

msgid "Show message header"
msgstr "Berichtkop tonen"

msgid "Show or hide the header label above the message text."
msgstr "Toont of verbergt het koplabel boven de berichttekst."

msgid "Message header"
msgstr "Berichtkop"

msgid "Custom header text displayed above the message. Supports variables: %d, %y, %t, %b, %r."
msgstr "Aangepaste koptekst weergegeven boven het bericht. Ondersteunt variabelen: %d, %y, %t, %b, %r."

msgid "Change custom message header"
msgstr "Aangepaste berichtkop wijzigen"

msgid "Edit custom message"
msgstr "Aangepast bericht bewerken"

msgid "Write your custom message text. Only active when 'Custom message' is selected. Supports variables: %d, %y, %t, %b, %r."
msgstr "Schrijf uw aangepaste berichttekst. Alleen actief wanneer 'Aangepast bericht' is geselecteerd. Ondersteunt variabelen: %d, %y, %t, %b, %r."

msgid "Custom Customisable Sleep Screen message"
msgstr "Aangepast bericht configureerbaar slaapscherm"

msgid "Book highlight maximum length"
msgstr "Maximale lengte boekmarkering"

msgid "Maximum characters to display for highlights (0 = no limit)."
msgstr "Maximaal aantal tekens voor markeringen (0 = geen limiet)."

msgid "Maximum highlight length (characters)"
msgstr "Maximale markeringslengte (tekens)"

msgid "100–150 chars keeps highlights readable. Set to 0 to show the full highlight."
msgstr "100–150 tekens houdt markeringen leesbaar. Stel in op 0 om de volledige markering te tonen."

msgid "Add quotation marks to highlights"
msgstr "Aanhalingstekens toevoegen aan markeringen"

msgid "Wraps all highlights in curly double quotes, removing any pre-existing quotation marks."
msgstr "Omsluit alle markeringen met krullende dubbele aanhalingstekens en verwijdert bestaande aanhalingstekens."

msgid "Show highlight location"
msgstr "Markeringslocatie tonen"

msgid "Display the chapter title and page number where the highlight is found, shown below the highlight text."
msgstr "Toont de hoofdstuktitel en het paginanummer waar de markering zich bevindt, weergegeven onder de markeringstekst."

msgid "Show quote attribution"
msgstr "Bronvermelding citaat tonen"

msgid "Display the author and book name below the quote, if provided in custom_quotes.lua."
msgstr "Toont de auteur en boektitel onder het citaat, indien opgegeven in custom_quotes.lua."

msgid "Show titles (top line)"
msgstr "Titels tonen (bovenste regel)"

msgid "Display the main heading text in each section. At least one of titles or subtitles must be visible."
msgstr "Toont de hoofdkopregel in elke sectie. Minimaal één van titels of ondertitels moet zichtbaar zijn."

msgid "Cannot hide both titles and subtitles. At least one must be visible."
msgstr "Kan titels en ondertitels niet beide verbergen. Minstens één moet zichtbaar zijn."

msgid "Show subtitles (bottom lines)"
msgstr "Ondertitels tonen (onderste regels)"

msgid "Display information below main heading text in each section. At least one of titles or subtitles must be visible."
msgstr "Toont informatie onder de hoofdkopregel in elke sectie. Minimaal één van titels of ondertitels moet zichtbaar zijn."

msgid "Displayed sections"
msgstr "Weergegeven secties"

msgid "Toggle which sections show on the sleep screen. At least one must be visible."
msgstr "Schakelt in welke secties op het slaapscherm worden getoond. Minstens één moet zichtbaar zijn."

msgid "[ Section Content ]"
msgstr "[ Sectie-inhoud ]"

msgid "Configure book-specific details."
msgstr "Configureert boekspecifieke details."

msgid "Configure chapter-specific details"
msgstr "Configureert hoofdstukspecifieke details"

msgid "Configure reading goal details"
msgstr "Configureert details van het leesdoel"

msgid "Battery section"
msgstr "Batterijsectie"

msgid "Configure battery & time/date details"
msgstr "Configureert batterij en tijd/datum details"

msgid "Configure message-specific details"
msgstr "Configureert berichtspecifieke details"

msgid "Customisable sleep screen settings"
msgstr "Instellingen configureerbaar slaapscherm"

msgid "Customisable sleep screen presets"
msgstr "Presets configureerbaar slaapscherm"

msgid "Cycle through customisable sleep screen presets"
msgstr "Doorloop presets van het configureerbare slaapscherm"

msgid "Customisable sleep screen"
msgstr "Configureerbaar slaapscherm"

msgid "Enable customisable sleep screen"
msgstr "Configureerbaar slaapscherm inschakelen"

msgid ""
"Customisable Sleep Screen: no book data found.\n"
"\n"
"Open a book and trigger the sleep screen at least once before it will work in the file manager."
msgstr ""
"Configureerbaar slaapscherm: geen boekgegevens gevonden.\n"
"\n"
"Open een boek en activeer het slaapscherm minstens één keer voordat het werkt in de bestandsbeheerder."
